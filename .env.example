# AuthGravity API base (no trailing slash). Example: https://authgravity.example.com
# astro dev: Vite proxies /api/authgravity → this URL so localhost avoids CORS.
# Optional override for the proxy target only (defaults to PUBLIC_AUTHGRAVITY_URL):
# AUTHGRAVITY_PROXY_TARGET=https://authgravity.example.com
PUBLIC_AUTHGRAVITY_URL=

# GitHub Personal Access Token (optional). Used at build time for GitHub API rate limits.
# Needs only public_repo scope (or no scope for public data).
# Without a token, unauthenticated requests are limited to 60/hour.
GITHUB_TOKEN=
