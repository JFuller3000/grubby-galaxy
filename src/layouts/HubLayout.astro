---
import MainNav from "../components/aopa/MainNav.astro";
import HubHero from "../components/aopa/HubHero.astro";
import HubSubnav from "../components/aopa/HubSubnav.astro";
import HubBlock from "../components/aopa/HubBlock.astro";
import HubSections from "../components/aopa/HubSections.astro";
import type { HubHeroVariant, HubHeroMinHeight, HubHeroImageWidth, HubHeroImageAlign } from "../components/aopa/hubHeroOptions";

interface HubSubnavLink {
	label: string;
	href: string;
}

interface HubSubnavColumn {
	links: HubSubnavLink[];
}

interface Props {
	pageTitle?: string;

	// HubHero
	hubName?: string;
	pillarName?: string;
	heroTitle?: string;
	heroDescription?: string;
	heroVariant?: HubHeroVariant;
	heroMinHeight?: HubHeroMinHeight;
	heroImage?: { src: string; alt: string };
	heroImageWidth?: HubHeroImageWidth;
	heroImageAlign?: HubHeroImageAlign;
	heroPrimaryCta?: { label: string; href: string };
	heroSecondaryCta?: { label: string; href: string };
	heroSecondaryStyle?: "default" | "alternate";
	heroLockupOverlayOpacity?: number;

	// HubSubnav + HubSections
	subnavLabel: string;
	columns: HubSubnavColumn[];

	// Code block
	blockCode?: string;
}

const {
	pageTitle,
	hubName,
	pillarName,
	heroTitle,
	heroDescription,
	heroVariant,
	heroMinHeight,
	heroImage,
	heroImageWidth,
	heroImageAlign,
	heroPrimaryCta,
	heroSecondaryCta,
	heroSecondaryStyle,
	heroLockupOverlayOpacity,
	subnavLabel,
	columns,
	blockCode,
} = Astro.props;

// ── code block snippet ────────────────────────────────────────────
const q = (v: string | undefined) => JSON.stringify(v ?? "");


const columnsLines = [
	`const columns = [`,
	...columns.map((col) => {
		const inner = col.links
			.map((l) => `      { label: ${JSON.stringify(l.label)}, href: ${JSON.stringify(l.href)} }`)
			.join(",\n");
		return `  {\n    links: [\n${inner},\n    ],\n  }`;
	}),
	`];`,
].join("\n");

const blockCodeConst = blockCode
	? `const blockCode = \`\n${blockCode.split("\n").map((l) => `  ${l}`).join("\n")}\n\`;\n`
	: "";

const slotContent = blockCode
	? `  <Fragment set:html={blockCode} />`
	: `  <!-- slot content -->`;

const layoutAttrs = [
	`  pageTitle=${q(pageTitle)}`,
	`  hubName=${q(hubName)}`,
	`  pillarName=${q(pillarName)}`,
	`  heroTitle=${q(heroTitle)}`,
	`  heroDescription=${q(heroDescription)}`,
	`  heroVariant=${q(heroVariant)}`,
	`  heroMinHeight=${q(heroMinHeight)}`,
	`  heroImage={{ src: ${q(heroImage?.src)}, alt: ${q(heroImage?.alt)} }}`,
	`  heroImageWidth=${q(heroImageWidth)}`,
	`  heroImageAlign=${q(heroImageAlign)}`,
	`  heroPrimaryCta={{ label: ${q(heroPrimaryCta?.label)}, href: ${q(heroPrimaryCta?.href)} }}`,
	`  heroSecondaryCta={{ label: ${q(heroSecondaryCta?.label)}, href: ${q(heroSecondaryCta?.href)} }}`,
	`  heroSecondaryStyle=${q(heroSecondaryStyle)}`,
	`  heroLockupOverlayOpacity={${heroLockupOverlayOpacity ?? "undefined"}}`,
	`  subnavLabel=${q(subnavLabel)}`,
	`  columns={columns}`,
	blockCode && `  blockCode={blockCode}`,
].filter(Boolean).join("\n");

function highlightCode(raw: string): string {
	const esc = (s: string) =>
		s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

	const marks: [string, string][] = [];
	let n = 0;
	const mark = (cls: string, content: string) => {
		const id = `\x01${n++}\x01`;
		marks.push([id, `<span class="hl-${cls}">${esc(content)}</span>`]);
		return id;
	};

	let inTmpl = false;

	const out = raw.split("\n").map((line) => {
		const t = line.trim();
		const ind = line.slice(0, line.length - t.length);
		if (!t) return "";

		if (inTmpl) {
			if (/^`[;,]?$/.test(t) || t.endsWith("`.trim();") || t.endsWith("`;")) inTmpl = false;
			return mark("str", line);
		}
		if (t === "---") return mark("punc", "---");

		// import X from "Y"
		const impM = line.match(/^(\s*)import\s+(.+?)\s+from\s+(".*?"|'.*?');?$/);
		if (impM)
			return impM[1] + mark("kw", "import") + " " + mark("id", impM[2]) + " " + mark("kw", "from") + " " + mark("str", impM[3]);

		// const X = ` (template literal)
		const tmplM = line.match(/^(\s*)const\s+(\w+)\s*=\s*(`.*)$/);
		if (tmplM) {
			inTmpl = !tmplM[3].endsWith("`;");
			return tmplM[1] + mark("kw", "const") + " " + mark("id", tmplM[2]) + " " + mark("punc", "=") + " " + mark("str", tmplM[3]);
		}

		// const X = [ or {
		const constM = line.match(/^(\s*)const\s+(\w+)\s*=\s*([\[{])(.*)/);
		if (constM)
			return constM[1] + mark("kw", "const") + " " + mark("id", constM[2]) + " " + mark("punc", "=") + " " + mark("punc", constM[3]) + constM[4];

		// pure structural: ]; }, { etc.
		if (/^[\][\s{},;.`]+$/.test(t)) return ind + mark("punc", t);

		// closing JSX tag
		if (/^<\/[\w.:-]+>$/.test(t)) return ind + mark("tag", t);
		if (t === "/>") return ind + mark("tag", "/>");
		if (t === ">") return ind + mark("tag", ">");

		// HTML comment
		if (t.startsWith("<!--")) return ind + mark("comment", t);

		// opening JSX tag
		if (t.startsWith("<")) {
			let s = t
				.replace(/^<([\w.:-]+)/, (_, n) => mark("punc", "<") + mark("tag", n))
				.replace(/([\w:.-]+)(=)("(?:[^"\\]|\\.)*?"|'(?:[^'\\]|\\.)*?')/g, (_, n, eq, v) => mark("attr", n) + mark("punc", eq) + mark("str", v))
				.replace(/([\w:.-]+)(=)(\{[^}]*\})/g, (_, n, eq, v) => mark("attr", n) + mark("punc", eq) + mark("expr", v))
				.replace(/\s*\/>$/, " " + mark("tag", "/>"))
				.replace(/>$/, mark("tag", ">"));
			return ind + s;
		}

		// standalone attribute line
		const aStr = t.match(/^([\w:.-]+)(=)("(?:[^"\\]|\\.)*?"|'(?:[^'\\]|\\.)*?')(.*)$/);
		if (aStr) return ind + mark("attr", aStr[1]) + mark("punc", "=") + mark("str", aStr[3]) + aStr[4];
		const aExpr = t.match(/^([\w:.-]+)(=)(\{[^}]*\})(.*)$/);
		if (aExpr) return ind + mark("attr", aExpr[1]) + mark("punc", "=") + mark("expr", aExpr[3]) + aExpr[4];

		// inline strings (object data lines)
		return line.replace(/"(?:[^"\\]|\\.)*?"/g, (v) => mark("str", v));
	});

	const joined = out.join("\n");
	const escaped = joined.split(/(\x01\d+\x01)/).map((p, i) => (i % 2 === 0 ? esc(p) : p)).join("");
	return marks.reduce((s, [id, html]) => s.split(id).join(html), escaped);
}

const codeSnippet = [
	`---`,
	`import HubLayout from "../layouts/HubLayout.astro";`,
	`import { slugify } from "../lib/slugify";`,
	``,
	columnsLines,
	blockCodeConst,
	`---`,
	``,
	`<HubLayout`,
	layoutAttrs,
	`>`,
	slotContent,
	`</HubLayout>`,
].join("\n");
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle ?? "AOPA hub"}</title>
		<style is:global>
			body {
				margin: 0;
				padding-bottom: 4rem;
				min-height: 100vh;
				background: #f5f7fa;
			}

			.hub-code {
				max-width: 72rem;
				margin: 2rem auto 0;
				padding: 0 1rem;
				position: relative;
			}

			.hub-code__actions {
				position: absolute;
				top: 0.55rem;
				right: 1.55rem;
				z-index: 1;
			}

			.hub-code__copy {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.25rem 0.45rem;
				border: 1px solid rgba(255, 255, 255, 0.22);
				border-radius: 0.35rem;
				background: rgba(15, 23, 42, 0.45);
				font-family: "Gotham Book", Gotham, "Helvetica Neue", Arial, sans-serif;
				font-size: 0.8125rem;
				line-height: 1.2;
				color: #e2e8f0;
				cursor: pointer;
			}

			.hub-code__copy:hover {
				background: rgba(15, 23, 42, 0.7);
			}

			.hub-code pre {
				margin: 0;
				padding: 0.85rem 1rem;
				border-radius: 0.5rem;
				border: 1px solid rgba(0, 0, 0, 0.1);
				background: #0f172a;
				color: #e2e8f0;
				font-size: 0.8rem;
				line-height: 1.5;
				overflow-x: auto;
			}

			.hl-kw    { color: #c084fc; }
			.hl-id    { color: #93c5fd; }
			.hl-tag   { color: #7dd3fc; }
			.hl-attr  { color: #f8fafc; }
			.hl-str   { color: #86efac; }
			.hl-expr  { color: #fbbf24; }
			.hl-punc  { color: #94a3b8; }
			.hl-comment { color: #6b7280; font-style: italic; }
		</style>
	</head>
	<body>
		<MainNav />
		<HubHero
			hubName={hubName}
			pillarName={pillarName}
			title={heroTitle}
			description={heroDescription}
			variant={heroVariant}
			minHeight={heroMinHeight}
			image={heroImage}
			imageWidth={heroImageWidth}
			imageAlign={heroImageAlign}
			primaryCta={heroPrimaryCta}
			secondaryCta={heroSecondaryCta}
			secondaryStyle={heroSecondaryStyle}
			lockupOverlayOpacity={heroLockupOverlayOpacity}
		/>
		<HubSubnav label={subnavLabel} columns={columns} />
		<HubBlock>
			<slot />
		</HubBlock>
		<HubSections columns={columns} />
		<section class="hub-code" aria-label="Component code">
			<div class="hub-code__actions">
				<button type="button" class="hub-code__copy" data-hub-copy>
					<span aria-hidden="true">⧉</span>
					<span>Copy</span>
				</button>
			</div>
			<pre><code data-hub-code set:html={highlightCode(codeSnippet)} /></pre>
		</section>
		<script>
			const copyBtn = document.querySelector<HTMLButtonElement>("[data-hub-copy]");
			const codeEl = document.querySelector<HTMLElement>("[data-hub-code]");
			if (copyBtn && codeEl) {
				copyBtn.addEventListener("click", async () => {
					try {
						await navigator.clipboard.writeText(codeEl.textContent ?? "");
						copyBtn.textContent = "Copied";
					} catch {
						copyBtn.textContent = "Copy failed";
					}
					window.setTimeout(() => {
						copyBtn.innerHTML = '<span aria-hidden="true">⧉</span><span>Copy</span>';
					}, 1200);
				});
			}
		</script>
	</body>
</html>
