---
import ImageComparisonSlider from './ImageComparisonSlider.astro';
import SectionHeading from './SectionHeading.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  href?: string;
  tags?: string[];
  comparisonSlider?: {
    beforeImage: string;
    afterImage: string;
    beforeAlt?: string;
    afterAlt?: string;
    labelBefore?: string;
    labelAfter?: string;
  };
}

const { title, description, image, imageAlt, href, tags = [], comparisonSlider } = Astro.props;
---
{href ? (
  <a href={href} class="block h-full text-white no-underline">
    <article class="h-full">
      <div>
        {image && (
          <div class="border-b border-[#34343d]">
            <img 
              src={image} 
              alt={imageAlt ?? title} 
              loading="lazy"
              class="h-[320px] w-full object-cover"
            />
          </div>
        )}
        <div class="px-6 py-6">
          <h3 class="mb-3 text-lg font-extrabold">{title}</h3>
          <p class="text-gray-300 mb-4 text-sm leading-relaxed">{description}</p>
          {comparisonSlider && (
            <div class="mt-4">
              <ImageComparisonSlider 
                beforeImage={comparisonSlider.beforeImage}
                afterImage={comparisonSlider.afterImage}
                beforeAlt={comparisonSlider.beforeAlt}
                afterAlt={comparisonSlider.afterAlt}
                labelBefore={comparisonSlider.labelBefore}
                labelAfter={comparisonSlider.labelAfter}
              />
            </div>
          )}
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {tags.map((tag) => (
                <span class="text-xs font-semibold uppercase tracking-wide text-gray-400" key={tag}>{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </article>
  </a>
) : (
  <article class="h-full">
    <div>
      {image && (
        <div class="border-b border-[#34343d]">
          <img 
            src={image} 
            alt={imageAlt ?? title} 
            loading="lazy"
            class="h-[320px] w-full object-cover"
          />
        </div>
      )}
      <div class="px-6 py-6">
        <SectionHeading text={title} class="mb-3 text-lg" />
        <p class="text-gray-300 mb-4 text-sm leading-relaxed">{description}</p>
        {comparisonSlider && (
          <div class="mt-4">
            <ImageComparisonSlider 
              beforeImage={comparisonSlider.beforeImage}
              afterImage={comparisonSlider.afterImage}
              beforeAlt={comparisonSlider.beforeAlt}
              afterAlt={comparisonSlider.afterAlt}
              labelBefore={comparisonSlider.labelBefore}
              labelAfter={comparisonSlider.labelAfter}
            />
          </div>
        )}
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag) => (
              <span class="text-xs font-semibold uppercase tracking-wide text-gray-400" key={tag}>{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </article>
)}
