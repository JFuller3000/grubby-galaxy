---
interface Props {
  title?: string;
  description?: string;
  content?: string;
}

const { title = "About", description = "A brief overview of my work and interests", content = "" } = Astro.props;
---

<section class="about">
  <h2 class="section-title">{title}</h2>
  <p class="section-description">{description}</p>
  
  <div class="about-content">
    <p>{content}</p>
  </div>
</section>

<style>
  .about {
    margin: 3rem 0;
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0 0 1rem;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .section-description {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .about-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .about-content p {
    margin: 0 0 1.5rem;
  }

  @media (max-width: 768px) {
    .about-content {
      font-size: 1rem;
    }
  }
</style>