---
interface Props {
  beforeImage: string;
  afterImage: string;
  beforeAlt?: string;
  afterAlt?: string;
  labelBefore?: string;
  labelAfter?: string;
  aspectRatio?: string;
}

const { beforeImage, afterImage, beforeAlt = "Before image", afterAlt = "After image", labelBefore = "Before", labelAfter = "After", aspectRatio = "921 / 768" } = Astro.props;
---

<div
  class="relative w-full overflow-hidden"
  data-comparison-slider
  style={`--comparison-position: 50%; --comparison-aspect-ratio: ${aspectRatio};`}
>
  <div class="relative h-full w-full isolate select-none [aspect-ratio:var(--comparison-aspect-ratio)]">
    <img 
      src={beforeImage}
      alt={beforeAlt}
      class="absolute inset-0 block h-full w-full object-contain"
    />

    <div class="absolute inset-0 [clip-path:inset(0_0_0_var(--comparison-position))]">
      <img 
        src={afterImage}
        alt={afterAlt}
        class="block h-full w-full object-contain"
      />
    </div>

    <input
      class="absolute inset-0 z-20 h-full w-full cursor-col-resize appearance-none bg-transparent opacity-0 touch-none [&::-moz-range-thumb]:h-full [&::-moz-range-thumb]:w-11 [&::-moz-range-thumb]:border-0 [&::-moz-range-track]:bg-transparent [&::-webkit-slider-thumb]:h-full [&::-webkit-slider-thumb]:w-11 [&::-webkit-slider-thumb]:appearance-none"
      type="range"
      min="0"
      max="100"
      value="50"
      aria-label={`Compare ${labelBefore} and ${labelAfter} images`}
      data-comparison-range
    />

    <div class="pointer-events-none absolute bottom-0 top-0 left-[var(--comparison-position)] z-10 flex w-2 -translate-x-1/2 items-center justify-center bg-white">
      <span class="h-16 w-1 rounded-full bg-gray-300"></span>
    </div>

    <div class="absolute left-4 top-4 rounded bg-black/50 px-3 py-1 text-sm text-white">
      {labelBefore}
    </div>
    <div class="absolute right-4 top-4 rounded bg-black/50 px-3 py-1 text-sm text-white">
      {labelAfter}
    </div>
  </div>
</div>

<script>
  const clamp = (value: number) => Math.min(100, Math.max(0, value));

  const initComparisonSliders = () => {
    document.querySelectorAll<HTMLElement>("[data-comparison-slider]").forEach((slider) => {
      if (slider.dataset.comparisonReady === "true") return;

      const range = slider.querySelector<HTMLInputElement>("[data-comparison-range]");
      if (!range) return;

      const setPosition = (value: number) => {
        const position = clamp(value);
        slider.style.setProperty("--comparison-position", `${position}%`);
        range.value = String(Math.round(position));
      };

      const setPositionFromPointer = (event: PointerEvent) => {
        const bounds = slider.getBoundingClientRect();
        const percentage = ((event.clientX - bounds.left) / bounds.width) * 100;
        setPosition(percentage);
      };

      range.addEventListener("input", () => setPosition(Number(range.value)));

      slider.addEventListener("pointerdown", (event) => {
        event.preventDefault();
        range.focus({ preventScroll: true });
        setPositionFromPointer(event);
        slider.setPointerCapture(event.pointerId);
      });

      slider.addEventListener("pointermove", (event) => {
        if (slider.hasPointerCapture(event.pointerId)) {
          setPositionFromPointer(event);
        }
      });

      const releasePointer = (event: PointerEvent) => {
        if (slider.hasPointerCapture(event.pointerId)) {
          slider.releasePointerCapture(event.pointerId);
        }
      };

      slider.addEventListener("pointerup", releasePointer);
      slider.addEventListener("pointercancel", releasePointer);

      setPosition(Number(range.value));
      slider.dataset.comparisonReady = "true";
    });
  };

  initComparisonSliders();
  document.addEventListener("astro:page-load", initComparisonSliders);
</script>
