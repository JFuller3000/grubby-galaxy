---
import SectionHeading from './SectionHeading.astro';

interface Props {
  title?: string;
  description?: string;
  steps?: { 
    title: string;
    description: string;
  }[];
}

const { title = "How I Work", steps = [] } = Astro.props;
---

<section class="mt-20">
  <SectionHeading text={title} class="mb-6 text-3xl md:text-4xl" />

  <div class="border border-[#34343d] px-6 py-12 sm:px-10 sm:py-16 lg:px-20 lg:py-20">
    <ol class="space-y-14 sm:space-y-16 lg:space-y-20">
      {steps.map((step, index) => (
        <li class="grid gap-4 md:grid-cols-[5rem_minmax(14rem,24rem)_1fr] md:items-baseline md:gap-8">
          <span class="font-serif text-6xl font-normal leading-none text-white md:text-7xl text-center" aria-hidden="true">
            {index + 1}
          </span>
          <h3 class="font-sans text-xl font-extrabold leading-tight text-white lg:text-2xl">
            {step.title}
          </h3>
          <p class="m-0 leading-relaxed text-gray-100 lg:text-xl lg:leading-relaxed font-extralight">
            {step.description}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>
