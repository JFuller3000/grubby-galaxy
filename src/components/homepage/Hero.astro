---
interface Props {
  name: string;
  title: string;
  description?: string;
}

const { name, title, description } = Astro.props;
---
<div class="hero">
  <h1 class="hero-name">{name}</h1>
  <p class="hero-title">{title}</p>
  {description && <p class="hero-description">{description}</p>}
</div>

<style>
  .hero {
    text-align: center;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    margin: 0 0 0.25rem;
    letter-spacing: 0.02em;
  }

  .hero-title {
    font-size: 1.1rem;
    color: var(--color-muted);
    font-weight: 500;
    margin: 0 0 1rem;
  }

  .hero-description {
    font-size: 0.95rem;
    color: var(--color-muted);
    margin: 0;
    max-width: 40ch;
    margin-inline: auto;
  }
</style>
