---
import SectionHeading from './SectionHeading.astro';

interface Props {
  title?: string;
  description?: string;
  principles?: string[];
}

const { title = "Principles", description = "Core values that guide my work and decision-making", principles = [] } = Astro.props;
---

<section class="h-full">
  <SectionHeading text={title} class="mb-4 text-xl" />
  <p class="text-gray-300 mb-8 text-lg leading-relaxed">{description}</p>
  
  <div class="grid gap-4">
    {principles.map((principle, index) => (
      <div key={index}>
        <div>
          <h3 class="font-serif text-lg font-normal mb-0 text-white leading-tight">{principle}</h3>
        </div>
      </div>
    ))}
  </div>
</section>
