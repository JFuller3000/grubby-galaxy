---
import { fetchGitHubActivity, type ActivityData, type PRInfo, type LanguageInfo, type ContributionWeek } from '../lib/github';

let data: ActivityData | null = null;
let errorMsg: string | null = null;

try {
  const token = import.meta.env.GITHUB_TOKEN as string | undefined;
  data = await fetchGitHubActivity(token);
  if (
    !data.prs.length &&
    !data.languages.length &&
    !data.totalContributions
  ) {
    errorMsg = 'No recent activity';
  }
} catch (e) {
  errorMsg = e instanceof Error ? e.message : String(e);
}

function timeAgo(dateStr: string): string {
  const now = Date.now();
  const then = new Date(dateStr).getTime();
  const diff = Math.floor((now - then) / 1000);
  if (diff < 60) return 'just now';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
  if (diff < 2592000) return Math.floor(diff / 604800) + 'w ago';
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

interface PRWithClass extends PRInfo {
  stateClass: string;
}

interface LangWithBg extends LanguageInfo {
  dotBg: string;
}

const prs: PRWithClass[] = (data?.prs ?? []).map((pr) => ({
  ...pr,
  stateClass: 'gh-state gh-state--' + pr.state.toLowerCase(),
}));

const languages: LangWithBg[] = (data?.languages ?? []).map((lang) => ({
  ...lang,
  dotBg: lang.color ?? '#ccc',
}));

const hasError = errorMsg !== null;
const hasData = data !== null && !hasError;
const isEmpty = hasData && !prs.length && !languages.length && !data.totalContributions;
const showFallback = hasError || isEmpty;
const fallbackMsg = hasError ? errorMsg : 'No recent activity';

const contributionWeeks: ContributionWeek[] = data?.contributionWeeks ?? [];
const contributionTotal = data?.totalContributions ?? 0;

function getLevel(count: number): number {
  if (count === 0) return 0;
  if (count <= 3) return 1;
  if (count <= 7) return 2;
  return 3;
}

const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

function formatTooltip(date: string, count: number): string {
  const d = new Date(date + 'T00:00:00');
  const month = monthNames[d.getMonth()];
  const day = d.getDate();
  const year = d.getFullYear();
  return count + ' contributions on ' + month + ' ' + day + ', ' + year;
}
---

{showFallback ? (
<section class="gh-section" aria-label="GitHub activity">
  <div class="gh-card gh-fallback">
    <p>Activity data unavailable{hasError && errorMsg !== 'No recent activity' ? ': ' + errorMsg : ''}.</p>
  </div>
</section>
) : hasData ? (
<section class="gh-section" aria-label="GitHub activity">
  <div class="gh-grid">
    <article class="gh-card">
      <h3 class="gh-card-title">
        <a href="https://github.com/JFuller3000?tab=pullrequests" target="_blank" rel="noopener noreferrer">Recent PRs</a>
      </h3>
      {prs.length > 0 ? (
      <ul class="gh-list">
        {prs.map((pr) => (
          <li>
            <span class="gh-list-title">{pr.title}</span>
            <span class="gh-meta">
              <span class="gh-repo">{pr.repo}</span>
            </span>
            <span class="gh-meta">
              <span class={pr.stateClass}>{pr.state}</span>
              <span class="gh-time">{timeAgo(pr.date)}</span>
            </span>
          </li>
        ))}
      </ul>
      ) : (
      <p class="gh-empty">No recent pull requests.</p>
      )}
    </article>

    <article class="gh-card">
      <h3 class="gh-card-title">
        <a href="https://github.com/JFuller3000?tab=repositories" target="_blank" rel="noopener noreferrer">Top Languages</a>
      </h3>
      {languages.length > 0 ? (
      <ul class="gh-lang-list">
        {languages.map((lang) => (
          <li>
            <span class="gh-lang-dot" style={"background: " + lang.dotBg}></span>
            <span class="gh-lang-name">{lang.name}</span>
            <span class="gh-lang-count">{lang.count}</span>
          </li>
        ))}
      </ul>
      ) : (
      <p class="gh-empty">No languages found.</p>
      )}
    </article>

    <article class="gh-card gh-contrib-graph">
      <h3 class="gh-card-title">
        <a href="https://github.com/JFuller3000" target="_blank" rel="noopener noreferrer">2026 Contributions</a>
      </h3>
      <div class="gh-graph" role="img" aria-label={contributionTotal + ' contributions in 2026'}>
        <div class="gh-graph-months">
          {contributionWeeks.length > 0 ? (() => {
            let lastMonth = -1;
            let colIndex = 0;
            const labels: { month: string; col: number }[] = [];
            for (const week of contributionWeeks) {
              const firstDay = week.days[0];
              if (firstDay) {
                const d = new Date(firstDay.date + 'T00:00:00');
                const month = d.getMonth();
                if (month !== lastMonth) {
                  labels.push({ month: monthNames[month], col: colIndex });
                  lastMonth = month;
                }
              }
              colIndex++;
            }
            return labels.map((label) => (
              <span class="gh-graph-month" style={{ left: (label.col * 13) + 'px' }}>{label.month}</span>
            ));
          })() : null}
        </div>
        <div class="gh-graph-weeks">
          <div class="gh-graph-days">
            {dayNames.map((_, i) => i % 2 === 1 ? <span class="gh-graph-day-label">{dayNames[i]}</span> : <span></span>)}
          </div>
          {contributionWeeks.map((week) => (
            <div class="gh-graph-week">
              {week.days.map((day) => {
                const level = getLevel(day.count);
                return (
                  <div
                    class={"gh-graph-day gh-graph-day--" + level}
                    title={formatTooltip(day.date, day.count)}
                    data-date={day.date}
                  ></div>
                );
              })}
            </div>
          ))}
        </div>
      </div>
      <p class="gh-graph-total">{contributionTotal} contributions in 2026</p>
    </article>
  </div>
</section>
) : null}

<style>
  .gh-section {
    max-width: var(--max-width);
    margin: 3rem auto 0;
    width: 100%;
  }

  .gh-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .gh-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1.25rem;
  }

  .gh-card-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    margin: 0 0 0.75rem;
    letter-spacing: 0.02em;
  }

  .gh-card-title a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .gh-card-title a:hover {
    text-decoration: underline;
  }

  .gh-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .gh-list li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .gh-list li::before {
    content: '';
    display: none;
  }

  .gh-list-title {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.3;
  }

  .gh-meta {
    font-size: 0.8rem;
    color: var(--color-muted);
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .gh-repo {
    opacity: 0.8;
  }

  .gh-state {
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    padding: 0.1em 0.4em;
    border-radius: 0.25em;
  }

  .gh-state--merged {
    color: #8250df;
    background: #f3e8fd;
  }

  .gh-state--open {
    color: #1a7f37;
    background: #dafbe1;
  }

  .gh-state--closed {
    color: #cf222e;
    background: #ffebe9;
  }

  .gh-time {
    opacity: 0.7;
  }

  .gh-lang-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .gh-lang-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
  }

  .gh-lang-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gh-lang-name {
    flex: 1;
    color: var(--color-text);
  }

  .gh-lang-count {
    color: var(--color-muted);
    font-size: 0.8rem;
  }

  .gh-contrib-graph {
    grid-column: 1 / -1;
  }

  .gh-graph {
    position: relative;
    font-size: 0;
    padding-top: 1.5rem;
  }

  .gh-graph-months {
    position: relative;
    height: 15px;
    margin-bottom: 0.25rem;
    font-size: 0.65rem;
    color: var(--color-muted);
  }

  .gh-graph-month {
    position: absolute;
    top: 0;
  }

  .gh-graph-weeks {
    display: inline-flex;
    gap: 3px;
  }

  .gh-graph-week {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .gh-graph-days {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-right: 0.35rem;
    position: absolute;
    left: 0;
    top: 1.5rem;
  }

  .gh-graph-day-label {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    font-size: 0.65rem;
    color: var(--color-muted);
    height: 10px;
    line-height: 1;
  }

  .gh-graph-day {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    background: #ebedf0;
    outline: 1px solid rgba(27, 31, 35, 0.06);
    outline-offset: -1px;
  }

  .gh-graph-day:hover {
    outline: 1px solid rgba(27, 31, 35, 0.3);
  }

  .gh-graph-day--1 {
    background: #9be9a8;
  }

  .gh-graph-day--2 {
    background: #40c463;
  }

  .gh-graph-day--3 {
    background: #30a14e;
  }

  .gh-graph-total {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0.75rem 0 0;
  }

  .gh-empty {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin: 0;
  }

  .gh-fallback {
    text-align: center;
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .gh-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
