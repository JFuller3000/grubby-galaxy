---
import { fetchGitHubActivity, type ActivityData, type PRInfo, type LanguageInfo, type ContributionWeek } from '../lib/github';

let data: ActivityData | null = null;
let errorMsg: string | null = null;

try {
  const token = import.meta.env.GITHUB_TOKEN as string | undefined;
  data = await fetchGitHubActivity(token);
  if (
    !data.prs.length &&
    !data.languages.length &&
    !data.totalContributions
  ) {
    errorMsg = 'No recent activity';
  }
} catch (e) {
  errorMsg = e instanceof Error ? e.message : String(e);
}

function timeAgo(dateStr: string): string {
  const now = Date.now();
  const then = new Date(dateStr).getTime();
  const diff = Math.floor((now - then) / 1000);
  if (diff < 60) return 'just now';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
  if (diff < 2592000) return Math.floor(diff / 604800) + 'w ago';
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

interface PRWithClass extends PRInfo {
  stateClass: string;
}

interface LangWithBg extends LanguageInfo {
  dotBg: string;
}

const prStateClass = 'inline-flex rounded-[0.25em] px-[0.4em] py-[0.1em] text-[0.7rem] font-semibold uppercase tracking-[0.04em]';
const prStateClasses: Record<PRInfo['state'], string> = {
  MERGED: `${prStateClass} bg-[#f3e8fd] text-[#8250df]`,
  OPEN: `${prStateClass} bg-[#dafbe1] text-[#1a7f37]`,
  CLOSED: `${prStateClass} bg-[#ffebe9] text-[#cf222e]`,
};

const prs: PRWithClass[] = (data?.prs ?? []).map((pr) => ({
  ...pr,
  stateClass: prStateClasses[pr.state],
}));

const languages: LangWithBg[] = (data?.languages ?? []).map((lang) => ({
  ...lang,
  dotBg: lang.color ?? '#ccc',
}));

const hasError = errorMsg !== null;
const hasData = data !== null && !hasError;
const isEmpty = hasData && !prs.length && !languages.length && !data.totalContributions;
const showFallback = hasError || isEmpty;

const contributionWeeks: ContributionWeek[] = data?.contributionWeeks ?? [];
const contributionTotal = data?.totalContributions ?? 0;

function getLevel(count: number): number {
  if (count === 0) return 0;
  if (count <= 3) return 1;
  if (count <= 7) return 2;
  return 3;
}

function getContributionClass(count: number): string {
  const baseClass = 'h-2.5 w-2.5 rounded-[2px] outline outline-1 -outline-offset-1 outline-[rgba(27,31,35,0.06)]';
  const level = getLevel(count);
  if (level === 1) return `${baseClass} bg-[#9be9a8]`;
  if (level === 2) return `${baseClass} bg-[#40c463]`;
  if (level === 3) return `${baseClass} bg-[#30a14e]`;
  return `${baseClass} bg-[#ebedf0]`;
}

const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

function formatTooltip(date: string, count: number): string {
  const d = new Date(date + 'T00:00:00');
  const month = monthNames[d.getMonth()];
  const day = d.getDate();
  const year = d.getFullYear();
  return count + ' contributions on ' + month + ' ' + day + ', ' + year;
}
---

{showFallback ? (
<section class="mx-auto mt-12 w-full max-w-[var(--max-width)]" aria-label="GitHub activity">
  <div class="text-center text-gray-400">
    <p>Activity data unavailable{hasError && errorMsg !== 'No recent activity' ? ': ' + errorMsg : ''}.</p>
  </div>
</section>
) : hasData ? (
<section class="mx-auto mt-12 w-full max-w-[var(--max-width)]" aria-label="GitHub activity">
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-[repeat(auto-fill,minmax(280px,1fr))]">
    <article>
      <h3 class="mb-3 font-serif text-base font-normal tracking-[0.02em]">
        <a class="text-white no-underline" href="https://github.com/JFuller3000?tab=pullrequests" target="_blank" rel="noopener noreferrer">Recent PRs</a>
      </h3>
      {prs.length > 0 ? (
      <ul class="m-0 flex list-none flex-col gap-3 p-0">
        {prs.map((pr) => (
          <li class="flex flex-col gap-1">
            <span class="text-[0.9rem] leading-[1.3] text-gray-200">{pr.title}</span>
            <span class="flex items-center gap-2 text-[0.8rem] text-gray-400">
              <span class="opacity-80">{pr.repo}</span>
            </span>
            <span class="flex items-center gap-2 text-[0.8rem] text-gray-400">
              <span class={pr.stateClass}>{pr.state}</span>
              <span class="opacity-70">{timeAgo(pr.date)}</span>
            </span>
          </li>
        ))}
      </ul>
      ) : (
      <p class="m-0 text-[0.9rem] text-gray-400">No recent pull requests.</p>
      )}
    </article>

    <article>
      <h3 class="mb-3 font-serif text-base font-normal tracking-[0.02em]">
        <a class="text-white no-underline" href="https://github.com/JFuller3000?tab=repositories" target="_blank" rel="noopener noreferrer">Top Languages</a>
      </h3>
      {languages.length > 0 ? (
      <ul class="m-0 flex list-none flex-col gap-2 p-0">
        {languages.map((lang) => (
          <li class="flex items-center gap-2 text-[0.9rem]">
            <span class="h-3 w-3 flex-shrink-0 rounded-full" style={"background: " + lang.dotBg}></span>
            <span class="flex-1 text-gray-200">{lang.name}</span>
            <span class="text-[0.8rem] text-gray-400">{lang.count}</span>
          </li>
        ))}
      </ul>
      ) : (
      <p class="m-0 text-[0.9rem] text-gray-400">No languages found.</p>
      )}
    </article>

    <article class="col-span-full">
      <h3 class="mb-3 font-serif text-base font-normal tracking-[0.02em]">
        <a class="text-white no-underline" href="https://github.com/JFuller3000" target="_blank" rel="noopener noreferrer">2026 Contributions</a>
      </h3>
      <div class="relative pt-6 text-[0]" role="img" aria-label={contributionTotal + ' contributions in 2026'}>
        <div class="relative mb-1 h-[15px] text-[0.65rem] text-gray-400">
          {contributionWeeks.length > 0 ? (() => {
            let lastMonth = -1;
            let colIndex = 0;
            const labels: { month: string; col: number }[] = [];
            for (const week of contributionWeeks) {
              const firstDay = week.days[0];
              if (firstDay) {
                const d = new Date(firstDay.date + 'T00:00:00');
                const month = d.getMonth();
                if (month !== lastMonth) {
                  labels.push({ month: monthNames[month], col: colIndex });
                  lastMonth = month;
                }
              }
              colIndex++;
            }
            return labels.map((label) => (
              <span class="absolute top-0" style={{ left: (label.col * 13) + 'px' }}>{label.month}</span>
            ));
          })() : null}
        </div>
        <div class="inline-flex gap-[3px]">
          <div class="absolute left-0 top-6 mr-[0.35rem] flex flex-col gap-[3px]">
            {dayNames.map((_, i) => i % 2 === 1 ? <span class="flex h-2.5 items-center justify-end text-[0.65rem] leading-none text-gray-400">{dayNames[i]}</span> : <span></span>)}
          </div>
          {contributionWeeks.map((week) => (
            <div class="flex flex-col gap-[3px]">
              {week.days.map((day) => {
                return (
                  <div
                    class={getContributionClass(day.count)}
                    title={formatTooltip(day.date, day.count)}
                    data-date={day.date}
                  ></div>
                );
              })}
            </div>
          ))}
        </div>
      </div>
      <p class="m-0 mt-3 text-[0.8rem] text-gray-400">{contributionTotal} contributions in 2026</p>
    </article>
  </div>
</section>
) : null}
