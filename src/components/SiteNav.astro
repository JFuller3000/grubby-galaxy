---
interface Props {
	currentPath: string;
}
const { currentPath } = Astro.props;
---
<nav class="site-nav" aria-label="Main">
	<ul class="site-nav-list">
		<li>
			<a href="/" class:list={{ active: currentPath === '/' }}>Resume</a>
		</li>
		<li class="site-nav-group">
			<a href="/design-system" class:list={['site-nav-label', { active: currentPath === '/design-system' && !currentPath.startsWith('/design-system/') }]}>Aopa Design System</a>
			<ul class="site-nav-sublist">
				<li>
					<a href="/design-system/documentation" class:list={{ active: currentPath === '/design-system/documentation' }}>design documentation</a>
				</li>
				<li>
					<a href="/design-system/decks" class:list={{ active: currentPath === '/design-system/decks' }}>decks</a>
				</li>
			</ul>
		</li>
	</ul>
</nav>

<style>
	.site-nav {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	.site-nav-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.5rem 1.5rem;
	}

	.site-nav a {
		color: var(--color-muted);
		text-decoration: none;
		font-size: 0.95rem;
	}

	.site-nav a:hover {
		color: var(--color-accent);
	}

	.site-nav a.active {
		color: var(--color-accent);
		font-weight: 500;
	}

	.site-nav-group {
		display: flex;
		align-items: baseline;
		gap: 0.5rem 1rem;
	}

	.site-nav-label {
		font-size: 0.95rem;
		color: var(--color-muted);
		font-weight: 500;
	}

	.site-nav-sublist {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
	}

	.site-nav-sublist a {
		font-size: 0.9rem;
		opacity: 0.9;
	}

	@media (max-width: 600px) {
		.site-nav-list {
			flex-direction: column;
			gap: 0.25rem;
		}

		.site-nav-group {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25rem;
		}

		.site-nav-sublist {
			padding-left: 1rem;
		}
	}
</style>
