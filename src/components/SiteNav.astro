---
interface Props {
	currentPath: string;
}
const { currentPath } = Astro.props;
---
<nav class="print:hidden mb-8 pb-6 border-b border-divider" aria-label="Main">
	<ul class="list-none m-0 p-0 flex flex-wrap items-baseline gap-x-6 gap-y-1">
		<li>
			<a href="/" class:list={["text-sm text-muted no-underline hover:text-accent", { "text-accent font-medium": currentPath === '/' }]}>Resume</a>
		</li>
		<li class="flex items-baseline gap-x-4 flex-col sm:flex-row sm:items-start gap-y-1">
			<a href="/design-system" class:list={["text-sm font-medium text-muted no-underline hover:text-accent", { "text-accent font-medium": currentPath === '/design-system' && !currentPath.startsWith('/design-system/') }]}>Aopa Design System</a>
			<ul class="list-none m-0 p-0 flex flex-wrap gap-x-4 pl-0 sm:pl-4">
				<li>
					<a href="/design-system/documentation" class:list={["text-sm text-muted/90 no-underline hover:text-accent", { "text-accent font-medium": currentPath === '/design-system/documentation' }]}>design documentation</a>
				</li>
				<li>
					<a href="/design-system/decks" class:list={["text-sm text-muted/90 no-underline hover:text-accent", { "text-accent font-medium": currentPath === '/design-system/decks' }]}>decks</a>
				</li>
			</ul>
		</li>
	</ul>
</nav>
