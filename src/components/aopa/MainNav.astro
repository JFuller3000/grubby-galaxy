	userName?: string;
	accountHref?: string;
	brandHref?: string;
}

const {
	userName = "John",
	accountHref = "#",
	brandHref = "#",
} = Astro.props;

const greeting = `Hi ${userName}`;

interface NavGroup {
	label: string;
	links?: string[];
}

interface NavColumn {
	label: string;
	groups: NavGroup[];
}

const membershipGroups: NavGroup[] = [
