				links: [
					"Aviation Scholarships",
					"AOPA Flight Training Scholarships",
					"CFI",
					"JS Firm",
				],
			},
			{ label: "Scholarships" },
		],
	},
	{
		label: "Fly",
		groups: [
			{
				label: "Flight Tools",
				links: ["Flight Planning", "Weather", "Airport Directory", "TFRs"],
			},
			{
				label: "Aircraft Types & Ownership",
				links: [
