	{
		label: "Advocacy",
		groups: [
			{
				label: "Advocacy & Regulatory",
				links: [
					"Key Issues",
					"MOSAIC",
					"BasicMed",
					"100 Unleaded Avgas",
					"Fees Transparency",
				],
			},
			{
				label: "State/Regional",
				links: ["Airport Support Network"],
			},
			{ label: "PAC" },
		],
	},
	{
		label: "Learn",
		groups: [
			{
				label: "Training & Safety",
				links: [
					"Learn to Fly",
					"Flight Schools",
					"Flight School Business",
					"Student Pilots",
					"New Pilots Guide to ATC Communication",
					"PPL Cost",
					"Airspace",
					"AOPA Personal Minimums",
					"Flight Following",
