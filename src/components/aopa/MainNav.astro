const slugify = (value: string) =>
	value
		.toLowerCase()
		.replace(/&/g, "and")
		.replace(/'/g, "")
		.replace(/[^a-z0-9]+/g, "-")
		.replace(/^-+|-+$/g, "");

const hrefFor = (label: string) => `#${slugify(label)}`;
---

<nav class="aopa-main-nav" aria-label="Main navigation" data-aopa-main-nav>
	<div class="aopa-main-nav__bar">
		<div class="aopa-main-nav__left">
			<button
				type="button"
				class="aopa-main-nav__menu"
				aria-expanded="false"
				aria-controls="aopa-main-nav-drawer"
				aria-label="Open menu"
				data-aopa-main-nav-toggle
			>
				<span class="aopa-main-nav__menu-lines" aria-hidden="true"></span>
			</button>
			<a href={brandHref} class="aopa-main-nav__brand">
				<span class="aopa-main-nav__brand-primary">AOPA</span><span class="aopa-main-nav__brand-sep">/</span><span
					class="aopa-main-nav__brand-sub">Advocacy</span>
			</a>
		</div>
		<div class="aopa-main-nav__right">
			<p class="aopa-main-nav__greeting">{greeting}</p>
			<a href={accountHref} class="aopa-main-nav__account">My account</a>
			<button type="button" class="aopa-main-nav__search" aria-label="Search">
				<svg class="aopa-main-nav__search-icon" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2.25"></circle>
					<path
						fill="none"
						stroke="currentColor"
						stroke-width="2.25"
						stroke-linecap="round"
						d="M15 15l6 6"></path>
				</svg>
			</button>
		</div>
	</div>

	<div
		id="aopa-main-nav-drawer"
		class="aopa-main-nav__drawer"
		aria-hidden="true"
		inert
		data-aopa-main-nav-drawer
	>
		<div class="aopa-main-nav__drawer-inner">
  <section class="aopa-main-nav__membership" aria-labelledby="aopa-main-nav-membership-heading">
                <h2 id="aopa-main-nav-membership-heading">Membership</h2>
                <ul class="aopa-main-nav__drawer-list">
                    {membershipGroups.map((group) => (
                        <li>
                            <button class="aopa-main-nav__group-toggle" aria-expanded="false" aria-controls={`aopa-main-nav-membership-${slugify(group.label)}-sublist`}>
                                <span class="aopa-main-nav__group-label">{group.label}</span>
                                {group.links && (
                                    <span class="aopa-main-nav__toggle-icon" aria-hidden="true">▾</span>
                                )}
                            </button>
                            {group.links && (
                                <ul id={`aopa-main-nav-membership-${slugify(group.label)}-sublist`} class="aopa-main-nav__sublist" style="max-height: 0;">
                                    {group.links.map((link) => (
                                        <li>
                                            <a href={hrefFor(link)}>{link}</a>
                                        </li>
                                    ))}
                                </ul>
                            )}
                        </li>
                    ))}
                </ul>
            </section>

  <div class="aopa-main-nav__columns" aria-label="Main menu sections">
                {navColumns.map((column) => (
                  <section class="aopa-main-nav__column" aria-labelledby={`aopa-main-nav-${slugify(column.label)}-heading`}>
                    <h2 id={`aopa-main-nav-${slugify(column.label)}-heading`}>{column.label}</h2>
                    <ul class="aopa-main-nav__drawer-list">
                      {column.groups.map((group) => (
                        <li>
                          <button class="aopa-main-nav__group-toggle" aria-expanded="false" aria-controls={`aopa-main-nav-${slugify(column.label)}-${slugify(group.label)}-sublist`}>
                            <span class="aopa-main-nav__group-label">{group.label}</span>
                            {group.links && (
                                <span class="aopa-main-nav__toggle-icon" aria-hidden="true">▾</span>
                            )}
                          </button>
                          {group.links && (
                            <ul id={`aopa-main-nav-${slugify(column.label)}-${slugify(group.label)}-sublist`} class="aopa-main-nav__sublist" style="max-height: 0;">
                              {group.links.map((link) => (
                                <li>
                                  <a href={hrefFor(link)}>{link}</a>
                                </li>
                              ))}
                            </ul>
                          )}
                        </li>
                      ))}
                    </ul>
                  </section>
                ))}
              </div>
		</div>
	</div>
</nav>

<script>
  const mainNavs = document.querySelectorAll<HTMLElement>("[data-aopa-main-nav]");

  mainNavs.forEach((nav) => {
    const toggle = nav.querySelector<HTMLButtonElement>("[data-aopa-main-nav-toggle]");
    const drawer = nav.querySelector<HTMLElement>("[data-aopa-main-nav-drawer]");

    if (!toggle || !drawer) return;

    const setOpen = (isOpen: boolean) => {
      nav.classList.toggle("is-open", isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
      drawer.setAttribute("aria-hidden", String(!isOpen));

      if (isOpen) {
        drawer.removeAttribute("inert");
      } else {
        drawer.setAttribute("inert", "");
      }
    };

    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });

    drawer.addEventListener("click", (event) => {
      if (event.target instanceof HTMLAnchorElement) setOpen(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        setOpen(false);
        toggle.focus();
      }
    });

    // Handle accordion toggle functionality
    const groupToggles = nav.querySelectorAll<HTMLButtonElement>(".aopa-main-nav__group-toggle");
    groupToggles.forEach(button => {
      button.addEventListener("click", () => {
        const isExpanded = button.getAttribute("aria-expanded") === "true";
        const targetId = button.getAttribute("aria-controls");
        const targetElement = document.getElementById(targetId);
        
        // Close all other accordions first
        groupToggles.forEach(otherButton => {
          if (otherButton !== button) {
            const otherTargetId = otherButton.getAttribute("aria-controls");
            const otherTargetElement = document.getElementById(otherTargetId);
            if (otherTargetElement && otherButton.getAttribute("aria-expanded") === "true") {
              otherButton.setAttribute("aria-expanded", "false");
              otherTargetElement.style.maxHeight = "0";
              const otherIcon = otherButton.querySelector(".aopa-main-nav__toggle-icon");
              if (otherIcon) {
                otherIcon.textContent = "▾";
                otherIcon.style.transform = "rotate(0deg)";
              }
            }
          }
        });
        
        // Toggle current accordion
        button.setAttribute("aria-expanded", String(!isExpanded));
        if (targetElement) {
          if (isExpanded) {
            // Collapsing
            targetElement.style.maxHeight = "0";
            const icon = button.querySelector(".aopa-main-nav__toggle-icon");
            if (icon) {
              icon.textContent = "▾";
              icon.style.transform = "rotate(0deg)";
            }
          } else {
            // Expanding
            targetElement.style.maxHeight = targetElement.scrollHeight + "px";
            const icon = button.querySelector(".aopa-main-nav__toggle-icon");
            if (icon) {
              icon.textContent = "▴";
              icon.style.transform = "rotate(180deg)";
            }
          }
        }
      });
    });
  });
</script>

<style>
	.aopa-main-nav {
		--aopa-nav-blue: #29abe2;
		--aopa-nav-blue-btn: #0082af;
		--aopa-nav-charcoal: #444444;
		--aopa-nav-ink: #444444;
		--aopa-nav-height: clamp(3rem, 2.75rem + 0.75vw, 3.75rem);
		--aopa-nav-font: "Arial Narrow", "Helvetica Neue Condensed", "Helvetica Neue", Arial, sans-serif;
		--aopa-nav-link-size: clamp(1.1875rem, 1rem + 0.55vw, 1.5rem);
		--aopa-nav-slice: clamp(1.75rem, 1rem + 2.5vw, 2.75rem);

		position: relative;
		z-index: 10;
		width: 100%;
		font-family: var(--aopa-nav-font);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		line-height: 1;
		color: var(--aopa-nav-ink);
	}

	/* Strip below the bar: 20% black over the hero (border was blending with nav fill). */
	.aopa-main-nav::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		top: 100%;
		height: 5px;
		background: rgba(0, 0, 0, 0.2);
		pointer-events: none;
		z-index: 1;
	}

	.aopa-main-nav__bar {
		display: flex;
		align-items: stretch;
		min-height: var(--aopa-nav-height);
		width: 100%;
	}

	.aopa-main-nav__left {
		position: relative;
		display: flex;
		align-items: center;
		gap: clamp(0.75rem, 0.5rem + 1vw, 1.25rem);
		flex: 0 1 auto;
		padding-left: clamp(0.75rem, 0.5rem + 1.2vw, 1.5rem);
		padding-right: clamp(2rem, 1.25rem + 3vw, 3.25rem);
		background: var(--aopa-nav-blue);
		clip-path: polygon(0 0, 100% 0, calc(100% - var(--aopa-nav-slice)) 100%, 0 100%);
		z-index: 1;
	}

	.aopa-main-nav__menu {
		display: grid;
		place-items: center;
		width: 2.75rem;
		height: 2.75rem;
		margin: 0;
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--aopa-nav-ink);
		cursor: pointer;
		border-radius: 2px;
	}

	.aopa-main-nav__menu:focus-visible {
		outline: 2px solid #fff;
		outline-offset: 2px;
	}

	.aopa-main-nav__menu-lines,
	.aopa-main-nav__menu-lines::before,
	.aopa-main-nav__menu-lines::after {
		display: block;
		width: 1.375rem;
		height: 2px;
		background: currentColor;
		transition:
			transform 180ms ease,
			opacity 180ms ease;
	}

	.aopa-main-nav__menu-lines {
		position: relative;
	}

	.aopa-main-nav__menu-lines::before,
	.aopa-main-nav__menu-lines::after {
		content: "";
		position: absolute;
		left: 0;
	}

	.aopa-main-nav__menu-lines::before {
		top: -7px;
	}

	.aopa-main-nav__menu-lines::after {
		top: 7px;
	}

	.aopa-main-nav.is-open .aopa-main-nav__menu-lines {
		background: transparent;
	}

	.aopa-main-nav.is-open .aopa-main-nav__menu-lines::before {
		transform: translateY(7px) rotate(45deg);
	}

	.aopa-main-nav.is-open .aopa-main-nav__menu-lines::after {
		transform: translateY(-7px) rotate(-45deg);
	}

	.aopa-main-nav__brand {
		display: flex;
		align-items: baseline;
		gap: 0.08em;
		text-decoration: none;
		color: var(--aopa-nav-ink);
		font-size: var(--aopa-nav-link-size);
		white-space: nowrap;
	}

	.aopa-main-nav__brand:hover {
		opacity: 0.92;
	}

	.aopa-main-nav__brand:focus-visible {
		outline: 2px solid var(--aopa-nav-ink);
		outline-offset: 3px;
	}

	.aopa-main-nav__brand-primary {
		font-size: 1.05em;
	}

	.aopa-main-nav__brand-sep {
		font-weight: 700;
		opacity: 1;
	}

	.aopa-main-nav__brand-sub {
		font-size: 0.72em;
		font-weight: 700;
	}

	.aopa-main-nav__right {
		flex: 1 1 auto;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: clamp(0.75rem, 0.4rem + 1.2vw, 1.5rem);
		padding-right: clamp(0.75rem, 0.5rem + 1.2vw, 1.5rem);
		padding-left: clamp(0.5rem, 0.25rem + 1vw, 1rem);
		background: var(--aopa-nav-charcoal);
		color: #fff;
		margin-left: calc(var(--aopa-nav-slice) * -1);
		padding-left: calc(var(--aopa-nav-slice) + clamp(0.5rem, 0.25rem + 1vw, 1rem));
		min-width: 0;
		position: relative;
		z-index: 0;
	}

	.aopa-main-nav__greeting {
		margin: 0;
		font-size: clamp(1rem, 0.9rem + 0.35vw, 1.1875rem);
		font-weight: 700;
		color: #fff;
		white-space: nowrap;
	}

	.aopa-main-nav__account {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.55em 1.35em 0.5em;
		border-radius: 9999px;
		background: var(--aopa-nav-blue-btn);
		color: #fff;
		text-decoration: none;
		font-size: clamp(0.9375rem, 0.82rem + 0.4vw, 1.125rem);
		font-weight: 700;
		letter-spacing: 0.08em;
		white-space: nowrap;
	}

	.aopa-main-nav__account:hover {
		filter: brightness(1.06);
	}

	.aopa-main-nav__account:focus-visible {
		outline: 2px solid #fff;
		outline-offset: 3px;
	}

	.aopa-main-nav__search {
		display: grid;
		place-items: center;
		width: 2.75rem;
		height: 2.75rem;
		margin: 0;
		padding: 0;
		border: 0;
		background: transparent;
		color: #fff;
		cursor: pointer;
		border-radius: 2px;
	}

	.aopa-main-nav__search:hover {
		opacity: 0.9;
	}

	.aopa-main-nav__search:focus-visible {
		outline: 2px solid #fff;
		outline-offset: 2px;
	}

	.aopa-main-nav__search-icon {
		display: block;
	}

	.aopa-main-nav__drawer {
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		z-index: 2;
		max-height: 0;
		overflow: hidden;
		background: #fff;
		box-shadow: 0 18px 30px rgba(0, 0, 0, 0.18);
		opacity: 0;
		transform: translateY(-0.75rem);
		transition:
			max-height 300ms ease,
			opacity 220ms ease,
			transform 260ms ease;
	}

	.aopa-main-nav.is-open .aopa-main-nav__drawer {
		max-height: 78vh;
		opacity: 1;
		transform: translateY(0);
	}

	.aopa-main-nav__drawer-inner {
		display: grid;
		grid-template-columns: minmax(13rem, 0.9fr) minmax(0, 4fr);
		align-items: stretch;
		max-height: 78vh;
		overflow-y: auto;
		border-top: 5px solid rgba(0, 0, 0, 0.2);
	}

	.aopa-main-nav__membership {
		background: var(--aopa-nav-blue);
		color: var(--aopa-nav-ink);
		padding: clamp(1rem, 0.8rem + 0.8vw, 1.5rem);
	}

.aopa-main-nav__columns {
	display: flex;
	gap: clamp(1rem, 0.5rem + 1.5vw, 2rem);
	padding: clamp(1rem, 0.8rem + 0.8vw, 1.5rem);
	background: #fff;
}

	.aopa-main-nav__column {
		flex: 1;
		min-width: 0;
		padding-right: clamp(1rem, 0.5rem + 1.5vw, 2rem);
		border-right: 1px solid #e0e0e0;
	}

	.aopa-main-nav__column:last-child {
		border-right: none;
		padding-right: 0;
	}

	.aopa-main-nav__membership h2,
	.aopa-main-nav__column h2 {
		margin: 0 0 1rem;
		font-size: clamp(1rem, 0.9rem + 0.35vw, 1.2rem);
		line-height: 1.1;
		letter-spacing: 0.08em;
	}

	.aopa-main-nav__drawer-list,
	.aopa-main-nav__sublist {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.aopa-main-nav__drawer-list {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.aopa-main-nav__drawer-list li {
		margin: 0;
		padding: 0;
	}

	.aopa-main-nav__group-toggle {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		padding: 0.15rem 0;
		min-height: 44px;
		background: none;
		border: none;
		text-align: left;
		color: var(--aopa-nav-ink);
		font-size: 0.9rem;
		font-weight: 700;
		line-height: 1.25;
		cursor: pointer;
	}

	.aopa-main-nav__group-toggle:hover {
		color: var(--aopa-nav-blue-btn);
	}

	.aopa-main-nav__group-toggle:focus-visible {
		outline: 2px solid var(--aopa-nav-ink);
		outline-offset: 2px;
	}

	.aopa-main-nav__group-label {
		flex-grow: 1;
	}

	.aopa-main-nav__toggle-icon {
		font-size: 1.75rem;
		transition: transform 200ms ease;
		display: inline-flex;
		align-items: center;
	}

	.aopa-main-nav__sublist {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin-top: 0.55rem;
		padding-left: 1.5rem;
		transition: max-height 200ms ease;
		overflow: hidden;
	}

	.aopa-main-nav__sublist a {
		display: inline-flex;
		color: var(--aopa-nav-ink);
		text-decoration: none;
		font-family: var(--aopa-nav-font);
		font-size: 0.9rem;
		font-weight: 700;
		line-height: 1.25;
		letter-spacing: 0.08em;
		text-transform: none;
	}

	@media (max-width: 520px) {
		.aopa-main-nav__greeting {
			display: none;
		}

		.aopa-main-nav__right {
			gap: 0.5rem;
		}
	}

	@media (min-width: 561px) and (max-width: 900px) {
		.aopa-main-nav__drawer-inner {
			grid-template-columns: 1fr;
		}

		.aopa-main-nav__columns {
			flex-wrap: wrap;
		}

		.aopa-main-nav__column {
			flex: 1 1 calc(50% - 1rem);
		}

		.aopa-main-nav__column:nth-child(even) {
			border-right: none;
			padding-right: 0;
		}

		.aopa-main-nav__column:nth-child(odd) {
