				],
			},
			{
				label: "Flying Clubs",
				links: ["Flying Clubs Finder"],
			},
			{ label: "Finance & Insurance" },
			{ label: "Legal & PPS" },
			{
				label: "Medical / Medications",
				links: [
					"BasicMed",
					"Mental Health",
					"Airman Medical Certification",
					"Medication Database",
				],
			},
			{ label: "Destinations / Travel" },
			{ label: "International" },
			{ label: "TSA & Security" },
		],
	},
	{
		label: "Community",
		groups: [
			{
				label: "Publications & Media",
				links: [
					"AOPA Pilot",
					"AOPA Pilot Turbine",
					"Flight Training",
					"Digital Editions",
					"Newsletters",
					"Podcasts",
