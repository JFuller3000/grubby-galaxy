---
import type {
	HubHeroBackground,
	HubHeroImagePosition,
	HubHeroMinHeight,
	HubHeroVariant,
} from "./hubHeroOptions";

export interface HubHeroCta {
	label: string;
	href: string;
}

export interface HubHeroImage {
	src: string;
	alt: string;
}

/**
 * Planned option surface for the hub hero (CMS / design parity).
 * Prop names and allowed values are placeholders until your spec is final.
 */
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	/** Primary button */
	primaryCta?: HubHeroCta;
	/** Text link or secondary button */
	secondaryCta?: HubHeroCta;
	/** Optional hero image (split layout) */
	image?: HubHeroImage;
	/** Where the image sits in split layout */
	imagePosition?: HubHeroImagePosition;
	/** Split = media + copy; centered = stacked, max-width copy */
	variant?: HubHeroVariant;
	/** Surface colors */
	background?: HubHeroBackground;
	/** Minimum block height */
	minHeight?: HubHeroMinHeight;
}

const {
	eyebrow,
	title,
	description,
	primaryCta,
	secondaryCta,
	image,
	imagePosition = "right",
	variant = image ? "split" : "centered",
	background = "neutral",
	minHeight = "tall",
} = Astro.props;

const layout = variant === "split" && image ? "split" : "centered";
const splitImageLeft = layout === "split" && imagePosition === "left";
---

<section
	class:list={[
		"aopa-hub-hero",
		`aopa-hub-hero--bg-${background}`,
		`aopa-hub-hero--height-${minHeight}`,
		layout === "split" && "aopa-hub-hero--split",
		layout === "split" && splitImageLeft && "aopa-hub-hero--split-image-left",
	]}
	aria-labelledby="aopa-hub-hero-title"
>
	<div class="aopa-hub-hero__inner">
		{
			layout === "split" && image && (
				<div class="aopa-hub-hero__media">
					<img src={image.src} alt={image.alt} class="aopa-hub-hero__img" width="960" height="640" loading="eager" />
				</div>
			)
		}
		<div class="aopa-hub-hero__content">
			{
				eyebrow && <p class="aopa-hub-hero__eyebrow">{eyebrow}</p>
			}
			<h1 id="aopa-hub-hero-title" class="aopa-hub-hero__title">
				<slot name="title">{title}</slot>
			</h1>
			{
				description && <p class="aopa-hub-hero__description">{description}</p>
			}
			<div class="aopa-hub-hero__slot">
				<slot />
			</div>
			{
				(primaryCta || secondaryCta) && (
					<div class="aopa-hub-hero__actions">
						{primaryCta && (
							<a href={primaryCta.href} class="aopa-hub-hero__cta aopa-hub-hero__cta--primary">
								{primaryCta.label}
							</a>
						)}
						{secondaryCta && (
							<a href={secondaryCta.href} class="aopa-hub-hero__cta aopa-hub-hero__cta--secondary">
								{secondaryCta.label}
							</a>
						)}
					</div>
				)
			}
		</div>
	</div>
</section>

<style>
	.aopa-hub-hero {
		--aopa-hero-font: "Arial Narrow", "Helvetica Neue Condensed", "Helvetica Neue", Arial, sans-serif;
		--aopa-hero-blue: #29abe2;
		--aopa-hero-blue-deep: #0082af;
		--aopa-hero-ink: #1a1a1a;
		--aopa-hero-muted: #4a4a4a;
		--aopa-hero-max: min(72rem, 100% - 2 * clamp(1rem, 0.5rem + 2vw, 2.5rem));

		width: 100%;
		font-family: var(--aopa-hero-font);
		color: var(--aopa-hero-ink);
	}

	.aopa-hub-hero--bg-neutral {
		background: linear-gradient(180deg, #f0f4f6 0%, #e4eaee 100%);
	}

	.aopa-hub-hero--bg-brand {
		background: linear-gradient(135deg, #e8f6fc 0%, #d4ecf7 45%, #c5e5f5 100%);
	}

	.aopa-hub-hero--bg-dark {
		--aopa-hero-ink: #fff;
		--aopa-hero-muted: rgba(255, 255, 255, 0.85);
		background: linear-gradient(145deg, #2a2a2a 0%, #1a1a1a 100%);
	}

	.aopa-hub-hero--height-short {
		min-height: clamp(16rem, 40vh, 22rem);
	}

	.aopa-hub-hero--height-tall {
		min-height: clamp(22rem, 52vh, 36rem);
	}

	.aopa-hub-hero--height-viewport {
		min-height: min(100vh, 52rem);
	}

	.aopa-hub-hero__inner {
		box-sizing: border-box;
		width: min(var(--aopa-hero-max), 100%);
		margin: 0 auto;
		padding: clamp(2rem, 1.25rem + 2.5vw, 4rem) clamp(1rem, 0.5rem + 2vw, 2.5rem);
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-height: inherit;
		gap: clamp(1.5rem, 1rem + 2vw, 2.5rem);
	}

	.aopa-hub-hero--split .aopa-hub-hero__inner {
		display: grid;
		align-items: center;
		grid-template-columns: 1fr;
	}

	@media (min-width: 900px) {
		.aopa-hub-hero--split .aopa-hub-hero__inner {
			grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
		}

		.aopa-hub-hero--split.aopa-hub-hero--split-image-left .aopa-hub-hero__inner {
			grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		}

		.aopa-hub-hero--split.aopa-hub-hero--split-image-left .aopa-hub-hero__media {
			order: -1;
		}
	}

	.aopa-hub-hero__media {
		position: relative;
		border-radius: clamp(0.25rem, 0.1rem + 0.5vw, 0.5rem);
		overflow: hidden;
		box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.12);
	}

	.aopa-hub-hero__img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 3 / 2;
		object-fit: cover;
		vertical-align: middle;
	}

	.aopa-hub-hero__content {
		max-width: 40rem;
	}

	.aopa-hub-hero--centered .aopa-hub-hero__content {
		margin: 0 auto;
		text-align: center;
		max-width: min(40rem, 100%);
	}

	.aopa-hub-hero--centered .aopa-hub-hero__actions {
		justify-content: center;
	}

	.aopa-hub-hero__eyebrow {
		margin: 0 0 0.65rem;
		font-size: clamp(0.8125rem, 0.75rem + 0.25vw, 0.9375rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--aopa-hero-blue-deep);
	}

	.aopa-hub-hero--bg-dark .aopa-hub-hero__eyebrow {
		color: var(--aopa-hero-blue);
	}

	.aopa-hub-hero__title {
		margin: 0 0 1rem;
		font-size: clamp(2rem, 1.35rem + 2.5vw, 3.25rem);
		font-weight: 700;
		line-height: 1.05;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.aopa-hub-hero__description {
		margin: 0 0 1.25rem;
		font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
		font-size: clamp(1rem, 0.92rem + 0.35vw, 1.125rem);
		font-weight: 400;
		line-height: 1.55;
		letter-spacing: normal;
		text-transform: none;
		color: var(--aopa-hero-muted);
		max-width: 36rem;
	}

	.aopa-hub-hero--centered .aopa-hub-hero__description {
		margin-left: auto;
		margin-right: auto;
	}

	.aopa-hub-hero__slot:empty {
		display: none;
	}

	.aopa-hub-hero__slot:not(:empty) {
		margin-bottom: 1rem;
	}

	.aopa-hub-hero__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1.25rem;
		margin-top: 0.25rem;
	}

	.aopa-hub-hero__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65em 1.35em 0.6em;
		font-size: clamp(0.875rem, 0.8rem + 0.25vw, 1rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		text-decoration: none;
		border-radius: 9999px;
		transition: filter 0.15s ease, opacity 0.15s ease;
	}

	.aopa-hub-hero__cta--primary {
		background: var(--aopa-hero-blue-deep);
		color: #fff;
	}

	.aopa-hub-hero__cta--primary:hover {
		filter: brightness(1.08);
	}

	.aopa-hub-hero__cta--secondary {
		background: transparent;
		color: var(--aopa-hero-blue-deep);
		box-shadow: inset 0 0 0 2px currentColor;
	}

	.aopa-hub-hero--bg-dark .aopa-hub-hero__cta--secondary {
		color: #fff;
	}

	.aopa-hub-hero__cta--secondary:hover {
		opacity: 0.88;
	}

	.aopa-hub-hero__cta:focus-visible {
		outline: 2px solid var(--aopa-hero-blue);
		outline-offset: 3px;
	}
</style>
