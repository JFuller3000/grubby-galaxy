---
import type {
	HubHeroCopyTone,
	HubHeroImageAlign,
	HubHeroImageWidth,
	HubHeroMinHeight,
	HubHeroVariant,
} from "./hubHeroOptions";
import {
	DEFAULT_HUB_HERO_LOCKUP_OVERLAY_COLOR,
	DEFAULT_HUB_HERO_PRIMARY_COLOR,
	normalizeHubHeroPrimaryHex,
} from "../../lib/hubHeroSearchParams";

export interface HubHeroCta {
	label: string;
	href: string;
}

export interface HubHeroImage {
	src: string;
	alt: string;
}

/**
 * Planned option surface for the hub hero (CMS / design parity).
 * Prop names and allowed values are placeholders until your spec is final.
 */
interface Props {
	/** Legacy lockup label source; prefer `columnName` for new usage. */
	hubName?: string;
	/** Shown under the wings mark as `AOPA | [columnName]`; omit to hide lockup column. */
	columnName?: string;
	/** Omit or pass empty string to hide the headline. */
	title?: string;
	description?: string;
	/** Primary button */
	primaryCta?: HubHeroCta;
	/** Text link or secondary button */
	secondaryCta?: HubHeroCta;
	/** Split = wider lockup + body grid when lockup is set; full = stacked gray panel */
	variant?: HubHeroVariant;
	/** Hero section fill (`#rgb` or `#rrggbb`); sets `--aopa-hero-primary`. */
	primaryColor?: string;
	/** Minimum block height */
	minHeight?: HubHeroMinHeight;
	/** Optional full-bleed hero background photo (not the lockup panel) */
	image?: HubHeroImage;
	/** Background image width: full bleed or half the hero */
	imageWidth?: HubHeroImageWidth;
	/** When `imageWidth` is half, which side the photo sits on */
	imageAlign?: HubHeroImageAlign;
	/**
	 * Gray panel fill opacity (0–1): split + lockup column and full-variant inner panel.
	 * Omitted = solid. Sets `--aopa-hero-lockup-overlay-opacity` on the section.
	 */
	lockupOverlayOpacity?: number;
	/** Panel fill (`#rgb` / `#rrggbb`); with opacity uses `color-mix` on section. */
	lockupOverlayColor?: string;
	/** Headline + description: `dark` = default ink, `light` for on dark / photo heroes. */
	copyTone?: HubHeroCopyTone;
	/** AOPA + hub line in the lockup column; independent of `copyTone`. */
	lockupCopyTone?: HubHeroCopyTone;
}

const {
	hubName,
	columnName,
	title = "",
	description,
	primaryCta,
	secondaryCta,
	variant = "full",
	primaryColor: primaryColorProp = DEFAULT_HUB_HERO_PRIMARY_COLOR,
	minHeight = "tall",
	image,
	imageWidth = "full",
	imageAlign = "left",
	lockupOverlayOpacity,
	lockupOverlayColor: lockupOverlayColorProp = DEFAULT_HUB_HERO_LOCKUP_OVERLAY_COLOR,
	copyTone = "dark",
	lockupCopyTone = "dark",
} = Astro.props;

const layout = variant === "split" ? "split" : "full";
const lockupColumnName = columnName?.trim() ?? "";
const lockupHubName = hubName?.trim() ?? "";
const hasLockup = lockupColumnName.length > 0 || lockupHubName.length > 0;
const lockupLogoSrc =
	lockupCopyTone === "light"
		? "/images/aopa-wings-logo-white.svg"
		: "/images/aopa-wings-logo-blue.svg";
const titleText = title.trim();
const descText = (description ?? "").trim();
const hasDescription = descText.length > 0;
const hasTitle = Astro.slots.has("title") || titleText.length > 0;
const showPrimaryCta = Boolean(primaryCta?.label.trim());
const showSecondaryCta = Boolean(secondaryCta?.label.trim());
const showActions = showPrimaryCta || showSecondaryCta;

const hasHeroBgImage = Boolean(image?.src);
const heroBgCssVars = image?.src
	? { "--hub-hero-bg-image": `url(${JSON.stringify(image.src)})` }
	: undefined;

const primaryHex =
	normalizeHubHeroPrimaryHex(primaryColorProp) ?? DEFAULT_HUB_HERO_PRIMARY_COLOR;
const lockupOverlayHex =
	normalizeHubHeroPrimaryHex(lockupOverlayColorProp) ??
	DEFAULT_HUB_HERO_LOCKUP_OVERLAY_COLOR;

const hubHeroSectionStyle: Record<string, string> = {
	...(heroBgCssVars ?? {}),
	"--aopa-hero-primary": primaryHex,
	"--aopa-hero-lockup-overlay-color": lockupOverlayHex,
};
if (lockupOverlayOpacity != null && Number.isFinite(lockupOverlayOpacity)) {
	hubHeroSectionStyle["--aopa-hero-lockup-overlay-opacity"] = String(
		Math.min(1, Math.max(0, lockupOverlayOpacity)),
	);
}
const hubHeroSectionStyleAttr = hubHeroSectionStyle;
---

<section
	data-hub-hero-root
	class:list={[
		"aopa-hub-hero",
		`aopa-hub-hero--height-${minHeight}`,
		layout === "full" && "aopa-hub-hero--variant-full",
		hasLockup && "aopa-hub-hero--has-lockup",
		layout === "split" && "aopa-hub-hero--split",
		hasHeroBgImage && "aopa-hub-hero--has-hero-image",
		hasHeroBgImage && imageWidth === "full" && "aopa-hub-hero--hero-image-full",
		hasHeroBgImage && imageWidth === "half" && "aopa-hub-hero--hero-image-half",
		copyTone === "light" && "aopa-hub-hero--copy-light",
		hasLockup && lockupCopyTone === "light" && "aopa-hub-hero--lockup-copy-light",
	]}
	style={hubHeroSectionStyleAttr}
	aria-labelledby={
		hasTitle ? "aopa-hub-hero-title" : hasDescription ? "aopa-hub-hero-description" : undefined
	}
	aria-label={!hasTitle && !hasDescription ? "Hero" : undefined}
>
	<div
		class:list={[
			"aopa-hub-hero__bg",
			hasHeroBgImage && imageWidth === "half" && imageAlign === "right" && "aopa-hub-hero__bg--half-right",
			hasHeroBgImage && imageWidth === "half" && imageAlign !== "right" && "aopa-hub-hero__bg--half-left",
		]}
		data-hub-hero-bg
		aria-hidden="true"
		hidden={!hasHeroBgImage}
	>
	</div>
	<div class="aopa-hub-hero__inner">
		<div class="aopa-hub-hero__lockup-col" data-hub-lockup-wrap hidden={!hasLockup}>
			<div class="aopa-hub-hero__lockup">
					<img
						class="aopa-hub-hero__lockup-brand"
						src={lockupLogoSrc}
						data-hub-lockup-logo
						data-lockup-logo-light="/images/aopa-wings-logo-white.svg"
						data-lockup-logo-dark="/images/aopa-wings-logo-blue.svg"
						alt="AOPA wings logo"
						loading="lazy"
						decoding="async"
					/>
				<p class="aopa-hub-hero__lockup-column">
					<span class="aopa-hub-hero__lockup-prefix" data-hub-lockup-prefix
						>AOPA{lockupColumnName.length > 0 ? " | " : ""}</span
					>
					<span
						class="aopa-hub-hero__lockup-column-value"
						data-hub-lockup-column
						hidden={lockupColumnName.length === 0}>{lockupColumnName}</span
					>
				</p>
				<p class="aopa-hub-hero__lockup-hub" data-hub-lockup-hub hidden={lockupHubName.length === 0}>
					{lockupHubName}
				</p>
			</div>
		</div>
		<div class="aopa-hub-hero__body">
			<div class="aopa-hub-hero__content">
				<h1
					id="aopa-hub-hero-title"
					class="aopa-hub-hero__title"
					data-hub-title-root
					hidden={!hasTitle}
				>
					<span data-hub-title><slot name="title">{title}</slot></span>
				</h1>
				<p
					id="aopa-hub-hero-description"
					class="aopa-hub-hero__description"
					data-hub-description
					hidden={!hasDescription}
				>
					{description ?? ""}
				</p>
				<div class="aopa-hub-hero__slot">
					<slot />
				</div>
				<div class="aopa-hub-hero__actions" data-hub-actions hidden={!showActions}>
					<a
						href={primaryCta?.href ?? "#"}
						class="aopa-hub-hero__cta aopa-hub-hero__cta--primary"
						data-hub-cta-primary
						hidden={!showPrimaryCta}>{primaryCta?.label ?? ""}</a>
					<a
						href={secondaryCta?.href ?? "#"}
						class="aopa-hub-hero__cta aopa-hub-hero__cta--secondary"
						data-hub-cta-secondary
						hidden={!showSecondaryCta}>{secondaryCta?.label ?? ""}</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.aopa-hub-hero {
		--aopa-hero-font: "Arial Narrow", "Helvetica Neue Condensed", "Helvetica Neue", Arial, sans-serif;
		--aopa-hero-blue: #29abe2;
		--aopa-hero-blue-deep: #0082af;
		--aopa-hero-ink: #333338;
		--aopa-hero-muted: #5c5c64;
		--aopa-hero-lockup-overlay-color: #eaeaea;

		position: relative;
		z-index: 0;
		width: 100%;
		font-family: var(--aopa-hero-font);
		color: var(--aopa-hero-ink);
		background: var(--aopa-hero-primary, #d4ecf7);
	}

	.aopa-hub-hero__bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		background-image: var(--hub-hero-bg-image);
		background-repeat: no-repeat;
		background-size: cover;
		background-position: center;
	}

	.aopa-hub-hero__bg--half-left {
		inset: 0 auto 0 0;
		width: 50%;
		background-position: left center;
	}

	.aopa-hub-hero__bg--half-right {
		inset: 0 0 0 auto;
		width: 50%;
		background-position: right center;
	}

	.aopa-hub-hero--has-hero-image .aopa-hub-hero__inner {
		position: relative;
		z-index: 1;
	}

	/* Hero background photo (overrides section fill) */
	.aopa-hub-hero--has-hero-image.aopa-hub-hero--hero-image-full {
		background: #0f1724;
	}

	.aopa-hub-hero--height-short {
		min-height: clamp(16rem, 40vh, 22rem);
	}

	.aopa-hub-hero--height-tall {
		min-height: clamp(22rem, 52vh, 36rem);
	}

	.aopa-hub-hero--height-viewport {
		min-height: min(100vh, 52rem);
	}

	.aopa-hub-hero__inner {
		box-sizing: border-box;
		width: 100%;
		margin: 0;
		padding: clamp(2rem, 1.25rem + 2.5vw, 4rem) clamp(1rem, 0.5rem + 2vw, 2.5rem);
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-height: inherit;
		gap: clamp(1.5rem, 1rem + 2vw, 2.5rem);
	}

	/* Full variant: hero keeps min-height; gray panel is only as tall as content */
	.aopa-hub-hero--variant-full {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.aopa-hub-hero--variant-full .aopa-hub-hero__inner {
		min-height: 0;
		height: fit-content;
		flex: 0 0 auto;
		background: color-mix(
			in srgb,
			var(--aopa-hero-lockup-overlay-color) calc(var(--aopa-hero-lockup-overlay-opacity, 1) * 100%),
			transparent
		);
		/* top-right + bottom-left only */
		border-radius: 0 112px 0 112px;
	}

	/* Full + lockup: gray panel (whole inner) capped and centered */
	.aopa-hub-hero--variant-full.aopa-hub-hero--has-lockup .aopa-hub-hero__inner {
		max-width: 1440px;
		margin-inline: auto;
	}

	.aopa-hub-hero--has-lockup .aopa-hub-hero__inner {
		display: grid;
		align-items: stretch;
		grid-template-columns: 1fr;
		justify-items: stretch;
	}

	@media (min-width: 720px) {
		/* Full variant + lockup: 40/60 (lockup / body) */
		.aopa-hub-hero--has-lockup:not(.aopa-hub-hero--split) .aopa-hub-hero__inner {
			grid-template-columns: 2fr 3fr;
			column-gap: clamp(1.25rem, 0.75rem + 2vw, 2.5rem);
		}

		/* Split + lockup: 40/60 outer columns */
		.aopa-hub-hero--has-lockup.aopa-hub-hero--split .aopa-hub-hero__inner {
			grid-template-columns: 2fr 3fr;
			column-gap: clamp(1.25rem, 0.75rem + 2vw, 2.5rem);
		}

		.aopa-hub-hero--variant-full.aopa-hub-hero--has-lockup .aopa-hub-hero__lockup-col {
			justify-self: center;
			width: fit-content;
			max-width: 100%;
		}
	}

	.aopa-hub-hero__lockup-col {
		display: grid;
		place-items: center;
		text-align: center;
		min-width: 0;
	}

	.aopa-hub-hero__lockup {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2em;
	}

	.aopa-hub-hero__lockup-brand {
		display: block;
		width: clamp(9rem, 7rem + 8vw, 15.5rem);
		max-width: 100%;
		height: auto;
	}

	.aopa-hub-hero__lockup-column {
		margin: 0;
		margin-bottom: 0.35rem;
		font-family: "Gotham Book", Gotham, "Gotham", "Helvetica Neue", Arial, sans-serif;
		font-size: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
		font-weight: 400;
		line-height: 1.2;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--aopa-hero-ink);
		max-width: 13rem;
	}

	.aopa-hub-hero__lockup-hub {
		margin: 0;
		font-family: "Gotham Bold", Gotham, "Gotham", "Helvetica Neue", Arial, sans-serif;
		font-size: clamp(0.9375rem, 0.82rem + 0.45vw, 1.125rem);
		font-weight: 700;
		line-height: 1.15;
		text-transform: uppercase;
		letter-spacing: 0.22em;
		color: var(--aopa-hero-ink);
		max-width: 12rem;
	}

	.aopa-hub-hero__lockup-prefix {
		opacity: 0.9;
	}

	.aopa-hub-hero__lockup-column-value {
		color: inherit;
	}

	.aopa-hub-hero--lockup-copy-light .aopa-hub-hero__lockup-brand {
		filter: drop-shadow(0 0 0.4rem rgba(0, 0, 0, 0.25));
	}

	.aopa-hub-hero--lockup-copy-light .aopa-hub-hero__lockup-column,
	.aopa-hub-hero--lockup-copy-light .aopa-hub-hero__lockup-column-value,
	.aopa-hub-hero--lockup-copy-light .aopa-hub-hero__lockup-hub {
		color: #f8fafc;
	}

	.aopa-hub-hero__body {
		min-width: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	/* Right column (copy + CTAs): center block when beside lockup */
	.aopa-hub-hero--has-lockup .aopa-hub-hero__body {
		align-items: center;
	}

	.aopa-hub-hero--has-lockup .aopa-hub-hero__content {
		width: min(100%, 40rem);
		margin-inline: auto;
	}

	.aopa-hub-hero--variant-full.aopa-hub-hero--has-lockup .aopa-hub-hero__body {
		align-items: stretch;
	}

	/* Split + lockup: gray behind lockup column */
	.aopa-hub-hero--split.aopa-hub-hero--has-lockup .aopa-hub-hero__lockup-col {
		box-sizing: border-box;
		/* max-width alone shrinks to content; width uses the full 420px when the track allows */
		width: min(100%, 420px);
		max-width: 420px;
		min-height: 360px;
		max-height: 360px;
		justify-self: center;
		align-self: center;
		background: color-mix(
			in srgb,
			var(--aopa-hero-lockup-overlay-color) calc(var(--aopa-hero-lockup-overlay-opacity, 1) * 100%),
			transparent
		);
		border-radius: 0 112px 0 112px;
		padding: clamp(1rem, 0.65rem + 1vw, 1.5rem);
	}

	/* Split without lockup: gray panel behind copy (same role as full variant inner) */
	.aopa-hub-hero--split:not(.aopa-hub-hero--has-lockup) .aopa-hub-hero__content {
		background: color-mix(
			in srgb,
			var(--aopa-hero-lockup-overlay-color) calc(var(--aopa-hero-lockup-overlay-opacity, 1) * 100%),
			transparent
		);
		border-radius: 0 112px 0 112px;
		padding: clamp(1rem, 0.65rem + 1vw, 1.5rem);
	}

	.aopa-hub-hero__content {
		max-width: 40rem;
	}

	.aopa-hub-hero__title {
		margin: 0 0 1rem;
		font-family: "Gotham Bold", Gotham, "Gotham", "Helvetica Neue", Arial, sans-serif;
		font-size: clamp(0.9375rem, 0.82rem + 0.45vw, 1.1875rem);
		font-weight: 700;
		line-height: 1.25;
		text-transform: none;
		letter-spacing: normal;
		color: var(--aopa-hero-ink);
	}

	.aopa-hub-hero__description {
		margin: 0 0 1.25rem;
		font-family: "Gotham Book", Gotham, "Gotham", "Helvetica Neue", Arial, sans-serif;
		font-size: clamp(1rem, 0.92rem + 0.35vw, 1.125rem);
		font-weight: 400;
		line-height: 1.55;
		letter-spacing: normal;
		text-transform: none;
		color: var(--aopa-hero-muted);
		max-width: 36rem;
	}

	/* Full + lockup: right column copy should fully use its grid track. */
	.aopa-hub-hero--variant-full.aopa-hub-hero--has-lockup .aopa-hub-hero__content {
		width: 100%;
		max-width: none;
		margin-inline-start: 0;
		margin-inline-end: clamp(1.5rem, 2.75vw, 3rem);
	}

	.aopa-hub-hero--variant-full.aopa-hub-hero--has-lockup .aopa-hub-hero__description {
		max-width: 40rem;
	}

	.aopa-hub-hero--copy-light .aopa-hub-hero__title {
		color: #f8fafc;
	}

	.aopa-hub-hero--copy-light .aopa-hub-hero__description {
		color: rgba(226, 232, 240, 0.9);
	}

	.aopa-hub-hero__slot:empty {
		display: none;
	}

	.aopa-hub-hero__slot:not(:empty) {
		margin-bottom: 1rem;
	}

	.aopa-hub-hero__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1.25rem;
		margin-top: 0.25rem;
	}

	/* `hidden` must win over flex/inline-flex (otherwise empty-label toggles still show pills). */
	.aopa-hub-hero__actions[hidden] {
		display: none !important;
	}

	.aopa-hub-hero__cta[hidden] {
		display: none !important;
	}

	.aopa-hub-hero__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65em 1.35em 0.6em;
		font-size: clamp(0.875rem, 0.8rem + 0.25vw, 1rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		text-decoration: none;
		border-radius: 9999px;
		transition: filter 0.15s ease, opacity 0.15s ease;
	}

	.aopa-hub-hero__cta--primary,
	.aopa-hub-hero__cta--secondary {
		background: var(--aopa-hero-blue-deep);
		color: #fff;
	}

	.aopa-hub-hero__cta--primary:hover,
	.aopa-hub-hero__cta--secondary:hover {
		filter: brightness(1.08);
	}

	.aopa-hub-hero__cta:focus-visible {
		outline: 2px solid var(--aopa-hero-blue);
		outline-offset: 3px;
	}
</style>
