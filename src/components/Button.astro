---
// Button component
// Variants: primary, secondary, outline, ghost. Renders as <a> when href is provided.
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit';
  href?: string;
  disabled?: boolean;
  class?: string;
}
const {
  variant = 'primary',
  size = 'md',
  type = 'button',
  href,
  disabled = false,
  class: className = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center font-semibold rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-doc-accent disabled:opacity-50 disabled:pointer-events-none';

const variants = {
  primary:
    'bg-doc-accent text-white hover:bg-doc-accent/90 focus:ring-doc-accent',
  secondary:
    'bg-doc-text text-white hover:bg-doc-text/90 focus:ring-doc-text',
  outline:
    'border-2 border-doc-accent text-doc-accent bg-transparent hover:bg-doc-accent/10 focus:ring-doc-accent',
  ghost:
    'text-doc-accent bg-transparent hover:bg-gray-100 focus:ring-doc-accent',
};

const sizes = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-4 py-2 text-base',
  lg: 'px-6 py-3 text-lg',
};

const classes = [base, variants[variant], sizes[size], className].filter(Boolean).join(' ');
const common = { class: classes, disabled: href ? undefined : disabled };
---

{href ? (
  <a href={href} {...common}>
    <slot />
  </a>
) : (
  <button type={type} {...common}>
    <slot />
  </button>
)}
