---
import Layout from '../layouts/Layout.astro';
import Resume from '../components/Resume.astro';
---
<Layout title="John S Fuller — Resume" description="John S Fuller — Resume. Front End Visual & UX Designer.">
	<Resume />
</Layout>
<style>
	.resume header {
		text-align: center;
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--color-border);
	}

	.name {
		font-family: var(--font-serif);
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: 400;
		margin: 0 0 0.25rem;
		letter-spacing: 0.02em;
	}

	.title {
		font-size: 1.1rem;
		color: var(--color-muted);
		font-weight: 500;
		margin: 0 0 1rem;
	}

	.contact {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem 1.25rem;
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.contact a {
		color: var(--color-accent);
		text-decoration: none;
	}

	.contact a:hover {
		text-decoration: underline;
	}

	.contact span:not(.sep) {
		opacity: 0.85;
	}

	.resume section {
		margin-bottom: 2rem;
	}

	.resume h2 {
		font-family: var(--font-serif);
		font-size: 1.25rem;
		font-weight: 400;
		margin: 0 0 1rem;
		color: var(--color-text);
		letter-spacing: 0.02em;
	}

	.summary p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	.skills-grid {
		display: grid;
		gap: 1.25rem 2rem;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
	}

	.skill-group h3 {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
		margin: 0 0 0.5rem;
	}

	.skill-group p {
		font-size: 0.9rem;
		color: var(--color-muted);
		margin: 0;
		line-height: 1.5;
	}

	.job {
		margin-bottom: 1.75rem;
	}

	.job:last-child {
		margin-bottom: 0;
	}

	.job-header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.job-company {
		font-weight: 600;
		font-size: 1rem;
	}

	.job-role {
		font-size: 0.95rem;
		color: var(--color-muted);
	}

	.job-date {
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	.job ul {
		margin: 0;
		padding-left: 1.25rem;
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.55;
	}

	.job li {
		margin-bottom: 0.35rem;
	}

	.education p {
		margin: 0 0 0.5rem;
		font-size: 0.95rem;
		color: var(--color-muted);
	}

	.education p:last-child {
		margin-bottom: 0;
	}

	@media print {
		body {
			background: #fff;
			padding: 1rem;
		}
		.contact a {
			color: var(--color-text);
		}
		.site-nav {
			display: none;
		}
		.resume {
			max-width: none;
		}
	}
</style>
