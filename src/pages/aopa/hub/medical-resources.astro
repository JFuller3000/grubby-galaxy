---
import MainNav from "../../../components/aopa/MainNav.astro";
import HubHero from "../../../components/aopa/HubHero.astro";
import HubSubnav from "../../../components/aopa/HubSubnav.astro";
import HubSections from "../../../components/aopa/HubSections.astro";
import { slugify } from "../../../lib/slugify";

const medicalSubnavLabel = "Medical\nResource\nLinks";
const medicalColumns = [
	{
		links: [
			"BasicMed Pilot Resources",
			"Airman Medical",
			"Certification",
		].map((label) => ({ label, href: `#${slugify(label)}` })),
	},
	{
		links: [
			"Health Conditions",
			"Submitting to the FAA Medications Database",
			"Special Issuance",
		].map((label) => ({ label, href: `#${slugify(label)}` })),
	},
	{
		links: ["Special Issuance Renewals"].map((label) => ({ label, href: `#${slugify(label)}` })),
	},
];

const hubHeroCode = `<HubHero
  hubName="Medical Resources"
  pillarName="Fly"
  title="Find answers here"
  description="Do you have questions or need information about an airman medical topic? Look through the information on these pages, and feel free to contact AOPA's Medical Certification Specialists."
  variant="full"
  minHeight="tall"
  imageWidth="half"
  imageAlign="left"
  image={{ src: "https://www.aopa.org/-/media/Images/AOPA-Main/News-and-Media/2018/October/1031_aopa_colombia.jpg", alt: "Hero background" }}
  primaryCta={{ label: "Contact Info", href: "#" }}
  lockupOverlayOpacity={0.9}
/>`;

const columnsCode = [
	`---`,
	`const columns = [`,
	...medicalColumns.map((col) => {
		const inner = col.links
			.map((l) => `      { label: ${JSON.stringify(l.label)}, href: ${JSON.stringify(l.href)} }`)
			.join(",\n");
		return `  {\n    links: [\n${inner},\n    ],\n  }`;
	}),
	`];\n---`,
].join("\n");

const codeSnippet = [
	columnsCode,
	``,
	hubHeroCode,
	``,
	`<HubSubnav label=${JSON.stringify(medicalSubnavLabel)} columns={columns} />`,
	`<HubSections columns={columns} />`,
].join("\n");
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>AOPA hub — medical resources</title>
		<style is:global>
			body {
				margin: 0;
				padding-bottom: 4rem;
				min-height: 100vh;
				background: #f5f7fa;
			}

			.hub-code {
				max-width: 72rem;
				margin: 2rem auto 0;
				padding: 0 1rem;
				position: relative;
			}

			.hub-code__actions {
				position: absolute;
				top: 0.55rem;
				right: 1.55rem;
				z-index: 1;
			}

			.hub-code__copy {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.25rem 0.45rem;
				border: 1px solid rgba(255, 255, 255, 0.22);
				border-radius: 0.35rem;
				background: rgba(15, 23, 42, 0.45);
				font-family: "Gotham Book", Gotham, "Helvetica Neue", Arial, sans-serif;
				font-size: 0.8125rem;
				line-height: 1.2;
				color: #e2e8f0;
				cursor: pointer;
			}

			.hub-code__copy:hover {
				background: rgba(15, 23, 42, 0.7);
			}

			.hub-code pre {
				margin: 0;
				padding: 0.85rem 1rem;
				border-radius: 0.5rem;
				border: 1px solid rgba(0, 0, 0, 0.1);
				background: #0f172a;
				color: #e2e8f0;
				font-size: 0.8rem;
				line-height: 1.5;
				overflow-x: auto;
			}
		</style>
	</head>
	<body>
		<MainNav />
		<HubHero
			hubName="Medical Resources"
			pillarName="Fly"
			title="Find answers here"
			description="Do you have questions or need information about an airman medical topic? Look through the information on these pages, and feel free to contact AOPA's Medical Certification Specialists."
			variant="full"
			minHeight="tall"
			imageWidth="half"
			imageAlign="left"
			image={{
				src: "https://www.aopa.org/-/media/Images/AOPA-Main/News-and-Media/2018/October/1031_aopa_colombia.jpg",
				alt: "Hero background",
			}}
			primaryCta={{ label: "Contact Info", href: "#" }}
			lockupOverlayOpacity={0.9}
		/>
		<HubSubnav label={medicalSubnavLabel} columns={medicalColumns} />
		<HubSections columns={medicalColumns} />
		<section class="hub-code" aria-label="Component code">
			<div class="hub-code__actions">
				<button type="button" class="hub-code__copy" data-hub-copy>
					<span aria-hidden="true">⧉</span>
					<span>Copy</span>
				</button>
			</div>
			<pre><code data-hub-code>{codeSnippet}</code></pre>
		</section>
		<script>
			const copyBtn = document.querySelector<HTMLButtonElement>("[data-hub-copy]");
			const codeEl = document.querySelector<HTMLElement>("[data-hub-code]");
			if (copyBtn && codeEl) {
				copyBtn.addEventListener("click", async () => {
					try {
						await navigator.clipboard.writeText(codeEl.textContent ?? "");
						copyBtn.textContent = "Copied";
					} catch {
						copyBtn.textContent = "Copy failed";
					}
					window.setTimeout(() => {
						copyBtn.innerHTML = '<span aria-hidden="true">⧉</span><span>Copy</span>';
					}, 1200);
				});
			}
		</script>
	</body>
</html>

