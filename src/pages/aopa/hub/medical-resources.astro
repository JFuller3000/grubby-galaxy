---
import HubLayout from "../../../layouts/HubLayout.astro";
import { slugify } from "../../../lib/slugify";

const base = "/aopa/hub/medical-resources";

const columns = [
	{
		links: ["BasicMed Pilot Resources", "Airman Medical", "Certification"].map((label) => ({
			label,
			href: `${base}/${slugify(label)}`,
		})),
	},
	{
		links: [
			"Health Conditions",
			"Submitting to the FAA Medications Database",
			"Special Issuance",
		].map((label) => ({ label, href: `${base}/${slugify(label)}` })),
	},
	{
		links: ["Special Issuance Renewals"].map((label) => ({
			label,
			href: `${base}/${slugify(label)}`,
		})),
	},
];

const blockCode = `
<div class="contact-box">
  <p><strong>Contact AOPA's Medical Certification Specialists.</strong></p>
  <p>
    <strong>Hours:</strong> M-F 8:30 a.m. to 6 p.m. EST<br />
    800-USA-AOPA (872-2672)<br />
    medicalassist@aopa.org
  </p>
</div>

<h2 class="section-heading--center">Wingman Med</h2>

<div class="wingman-cols">
  <div class="wingman-cols__col">
    <p>AOPA has partnered with Wingman Med to provide a MedXPress simulator, AME database, and discount on specialized medical services.</p>
  </div>
  <div class="wingman-cols__col">
    <img class="wingman-logo" src="https://www.aopa.org/-/media/Images/AOPA-Main/Go-Fly/Medical/Wingman-Med-Logo.png" alt="Wingman Med" />
  </div>
</div>

<div class="wingman-cols">
  <div class="wingman-cols__col">
    <div class="video-wrap">
      <iframe width="560" height="315" src="https://www.youtube.com/embed/Yop4fLr6bpo?si=mgp-tXyS_pGgtpZB" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
    </div>
  </div>
  <div class="wingman-cols__col">
    <p>Free access to the MedXPress Simulator and result review by AOPA's Medical Specialists (a $50 value!). Plus a $300 discount on services provided by Wingman Med when referred by AOPA.</p>
    <div class="wingman-btns">
      <a href="#" class="wingman-btn">MedXPress Simulator</a>
      <a href="#" class="wingman-btn">AME Database</a>
    </div>
  </div>
</div>
`.trim();
---

<HubLayout
	pageTitle="AOPA hub — medical resources"
	hubName="Medical Resources"
	pillarName="Fly"
	heroTitle="Find answers here"
	heroDescription="Do you have questions or need information about an airman medical topic? Look through the information on these pages, and feel free to contact AOPA's Medical Certification Specialists."
	heroVariant="full"
	heroMinHeight="tall"
	heroImageWidth="half"
	heroImageAlign="left"
	heroImage={{
		src: "https://www.aopa.org/-/media/Images/AOPA-Main/News-and-Media/2018/October/1031_aopa_colombia.jpg",
		alt: "Hero background",
	}}
	heroPrimaryCta={{ label: "Contact Info", href: "#" }}
	heroLockupOverlayOpacity={0.9}
	subnavLabel="Medical\nResource\nLinks"
	columns={columns}
	blockCode={blockCode}
>
	<Fragment set:html={blockCode} />
	<style is:global>
		.contact-box {
			margin-bottom: 1.5rem;
			background: #d4ecf7;
			border-radius: 0.375rem;
			padding: 2rem;
			text-align: center;
			font-family: "Gotham Book", Gotham, "Helvetica Neue", Arial, sans-serif;
			font-size: 0.9375rem;
			line-height: 1.7;
			color: #1f2937;
		}

		.contact-box p {
			max-width: none !important;
			margin: 0 0 0.5rem;
		}

		.contact-box p:first-child {
			margin-bottom: 1.25rem;
		}

		.contact-box p:last-child {
			margin-bottom: 0;
		}

		.contact-box strong {
			font-family: "Gotham Bold", Gotham, "Helvetica Neue", Arial, sans-serif;
			font-weight: normal;
		}

		.section-heading--center {
			text-align: center;
		}

		.wingman-cols {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
			margin-top: 1rem;
			align-items: center;
		}

		.wingman-cols__col:first-child p {
			font-size: 1.25rem;
			line-height: 1.5;
		}

		.wingman-logo {
			display: block;
			width: 33%;
			margin: 0 auto;
		}

		.video-wrap {
			position: relative;
			padding-bottom: 56.25%;
			height: 0;
			overflow: hidden;
		}

		.video-wrap iframe {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
		}

		.wingman-btns {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			margin-top: 1.25rem;
		}

		.wingman-btn {
			display: inline-flex;
			align-items: center;
			padding: 0.65em 1.35em 0.6em;
			background: #1d6fa4;
			color: #fff;
			font-family: "Gotham Bold", Gotham, "Helvetica Neue", Arial, sans-serif;
			font-size: 0.875rem;
			font-weight: normal;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			text-decoration: none;
			border-radius: 9999px;
			transition: filter 0.15s ease;
		}

		.wingman-btn:hover {
			filter: brightness(1.08);
		}
	</style>
</HubLayout>
