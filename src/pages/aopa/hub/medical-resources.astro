---
import HubLayout from "../../../layouts/HubLayout.astro";
import { slugify } from "../../../lib/slugify";

const base = "/aopa/hub/medical-resources";

const columns = [
	{
		links: ["BasicMed Pilot Resources", "Airman Medical", "Certification"].map((label) => ({
			label,
			href: `${base}/${slugify(label)}`,
		})),
	},
	{
		links: [
			"Health Conditions",
			"Submitting to the FAA Medications Database",
			"Special Issuance",
		].map((label) => ({ label, href: `${base}/${slugify(label)}` })),
	},
	{
		links: ["Special Issuance Renewals"].map((label) => ({
			label,
			href: `${base}/${slugify(label)}`,
		})),
	},
];
---

<HubLayout
	pageTitle="AOPA hub — medical resources"
	hubName="Medical Resources"
	pillarName="Fly"
	title="Find answers here"
	description="Do you have questions or need information about an airman medical topic? Look through the information on these pages, and feel free to contact AOPA's Medical Certification Specialists."
	variant="full"
	minHeight="tall"
	imageWidth="half"
	imageAlign="left"
	image={{
		src: "https://www.aopa.org/-/media/Images/AOPA-Main/News-and-Media/2018/October/1031_aopa_colombia.jpg",
		alt: "Hero background",
	}}
	primaryCta={{ label: "Contact Info", href: "#" }}
	lockupOverlayOpacity={0.9}
	subnavLabel="Medical\nResource\nLinks"
	columns={columns}
	blockCode={`<h2>About Medical Resources</h2>\n<p>\n  Do you have questions or need information about an airman medical topic? Look through the\n  information on these pages, and feel free to contact AOPA's Medical Certification Specialists.\n</p>`}
>
	<h2>About Medical Resources</h2>
	<p>
		Do you have questions or need information about an airman medical topic? Look through the
		information on these pages, and feel free to contact AOPA's Medical Certification Specialists.
	</p>
</HubLayout>
