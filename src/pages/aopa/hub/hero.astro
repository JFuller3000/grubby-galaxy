---
import MainNav from "../../../components/aopa/MainNav.astro";
import HubHero from "../../../components/aopa/HubHero.astro";
import HubHeroDevToolbar from "../../../components/aopa/HubHeroDevToolbar.astro";
import {
	DEFAULT_HUB_HERO_LOCKUP_OVERLAY_COLOR,
	DEFAULT_HUB_HERO_PRIMARY_COLOR,
	hubHeroUrlOverridesActive,
	isHubHeroPreviewQueryEnabled,
	resolveHubHeroFromUrl,
	type HubHeroResolvedFromUrl,
} from "../../../lib/hubHeroSearchParams";

const defaults: HubHeroResolvedFromUrl = {
	hubName: "Content hub",
	columnName: "Content hub",
	title: "Placeholder headline",
	description:
		"This page exists to preview the hub hero. Use the hero options button at the bottom of the page to change props via the URL or click a link below for some examples of pre built heroes in various configurations.",
	primaryColor: DEFAULT_HUB_HERO_PRIMARY_COLOR,
	lockupOverlayColor: DEFAULT_HUB_HERO_LOCKUP_OVERLAY_COLOR,
	minHeight: "tall",
	variant: "full",
	imageSrc: undefined,
	imageAlt: "Hero background",
	imageWidth: "full",
	imageAlign: "left",
	primaryLabel: "Primary action",
	primaryHref: "#",
	secondaryLabel: "Secondary",
	secondaryHref: "#",
	copyTone: "dark",
	lockupCopyTone: "dark",
};

const resolved = resolveHubHeroFromUrl(Astro.url.searchParams, defaults);
const sp = Astro.url.searchParams;
const hubHeroPreviewOverrides =
	import.meta.env.DEV && hubHeroUrlOverridesActive(sp);
const clearQueryHref = Astro.url.pathname || "/";
const syncUrlDefault = isHubHeroPreviewQueryEnabled(sp);

const image =
	resolved.imageSrc && resolved.imageSrc.length > 0
		? { src: resolved.imageSrc, alt: resolved.imageAlt || "Hero background" }
		: undefined;

const primaryCta =
	resolved.primaryLabel.trim().length > 0
		? { label: resolved.primaryLabel.trim(), href: resolved.primaryHref || "#" }
		: undefined;

const secondaryCta =
	resolved.secondaryLabel.trim().length > 0
		? { label: resolved.secondaryLabel.trim(), href: resolved.secondaryHref || "#" }
		: undefined;

const advocateCampaignHref =
	"/aopa/hub/hero?hh=1&hubName=Legislative+Campaigns&columnName=Advocate&title=For+AOPA%2C+advocacy+is+more+than+just+lobbying+Congress+or+negotiating+with+the+FAA.&description=It%E2%80%99s+about+staying+engaged+with+hundreds+of+state+agencies+and+legislatures.+It%E2%80%99s+about+maintaining+a+network+of+pilots+to+monitor+thousands+of+airports.+It%E2%80%99s+about+putting+the+combined+weight+of+hundreds+of+thousands+of+pilots+behind+you.&primaryColor=%23115678&lockupOverlayColor=%23eaeaea&minHeight=viewport&variant=split&copyTone=light&lockupCopyTone=dark&imageWidth=half&imageAlign=left&imageSrc=https%3A%2F%2Faopa.org%2F-%2Fmedia%2FImages%2FAOPA-Main%2FNews-and-Media%2FPublications%2FPilot-Magazine%2F2026%2F2605%2F2605p_missionmountain%2F2605p_mission001%2F2605p_mission001_16x9.jpg%3Fh%3D675%26w%3D1200%26la%3Den%26hash%3D50FF572C113460EBFB871504DF2044D7&imageAlt=Hero+background&primaryLabel=Donate+Today&primaryHref=https%3A%2F%2Fwww.aopa.org%2Fdonation%2Foneclickpac%3Fkeycode%3DV1512WP01&secondaryLabel=&secondaryHref=%23&lockupOpacity=0.9";
const trainingSafetyHref =
	"/aopa/hub/hero?hh=1&hubName=Training+%26+Safety&columnName=Learn&title=&description=Whether+it%E2%80%99s+prepping+for+a+checkride%2C+perfecting+an+instrument+approach%2C+or+just+going+out+for+a+proficiency+flight%2C+a+good+pilot+is+always+learning.+To+make+that+easier%2C+AOPA+and+the+Air+Safety+Institute+offer+a+wide+variety+of+resources+specifically+tailored+to+your+flying+life.&primaryColor=%23115678&lockupOverlayColor=%23eaeaea&minHeight=viewport&variant=full&copyTone=dark&lockupCopyTone=dark&imageWidth=full&imageAlign=left&imageSrc=https%3A%2F%2Fwww.aopa.org%2F-%2Fmedia%2FImages%2FAOPA-Main%2FNews-and-Media%2F2022%2FSeptember%2F220902_training_tip.jpg&imageAlt=Hero+background&primaryLabel=Choose+your+path&primaryHref=%23paths&secondaryLabel=&secondaryHref=%23&lockupOpacity=0.9";
const careersEducationHref =
	"http://localhost:4321/aopa/hub/hero?hh=1&hubName=Careers+%26+Education&columnName=Learn&title=Resources+for+Career+Pilots&description=Many+aspiring+pilots+have+dreams+of+taking+their+passion+for+aviation+and+making+it+into+a+career.+The+good+news+is+that+the+outlook+has+never+been+better+for+hopeful+commercial+pilots.+In+2018%2C+Boeing+projected+a+demand+for+790%2C000+pilots+over+the+next+20+years%2C+thanks+in+part+to+rapid+expansion+of+the+global+commercial+airplane+fleet.&primaryColor=%23115678&lockupOverlayColor=%23333333&minHeight=tall&variant=full&copyTone=light&lockupCopyTone=light&imageWidth=full&imageAlign=left&imageSrc=https%3A%2F%2Fwww.aopa.org%2Ftraining-and-safety%2F-%2Fmedia%2Fimages%2Faopa-main%2Ftraining-and-safety%2Flearn-to-fly%2Ffly_for_career&imageAlt=Hero+background&primaryLabel=Choose+your+path&primaryHref=%23paths&secondaryLabel=&secondaryHref=%23&lockupOpacity=0.9";
const rustyPilotsHref =
	"/aopa/hub/hero?hh=1&hubName=Rusty+Pilots&columnName=Learn&title=If+you%E2%80%99ve+been+out+of+the+flight+deck+for+a+while%2C+we%E2%80%99ll+help+you+get+back+in&description=On+behalf+of+AOPA%2C+the+Rusty+Pilots+team+congratulates+the+13%2C000-plus+pilots+who+returned+to+flying+after+attending+a+Rusty+Pilots+seminar%2C+webinar%2C+or+took+the+online+course+and+completed+their+flight+review.+We+celebrate+with+you%21&primaryColor=%23cde3e4&lockupOverlayColor=%232e5261&minHeight=tall&variant=full&copyTone=light&lockupCopyTone=light&imageWidth=half&imageAlign=left&imageSrc=https%3A%2F%2Fwww.aopa.org%2F-%2Fmedia%2FImages%2FAOPA-Main%2FTraining-and-Safety%2Frustypilotseminar3.jpg&imageAlt=Hero+background&primaryLabel=Meet+Our+Instructors&primaryHref=%23paths&secondaryLabel=&secondaryHref=%23&lockupOpacity=0.9";
const aircraftBuyingOwnershipHref =
	"/aopa/hub/hero?hh=1&hubName=Aircraft+Buying+%26+Ownership&columnName=fly&title=Whether+you%27re+interested+in+purchasing+your+first+aircraft%2C+or+upgrading+to+another%2C+AOPA+offers+a+wealth+of+resources+to+assist.&description=Need+help+with+buying+or+selling+an+aircraft%3F+Find+it+here.+Check+out+the+resource+pages+for+an+overview+of+all+aspects+of+the+purchasing+process+or+click+on+the+Quick+Links+to+access+specific+information.&primaryColor=%232079a2&lockupOverlayColor=%231d356d&minHeight=tall&variant=full&copyTone=light&lockupCopyTone=light&imageWidth=full&imageAlign=left&imageSrc=https%3A%2F%2Fwww.aopa.org%2F-%2Fmedia%2FImages%2FAOPA-Main%2FNews-and-Media%2F2023%2FMar%2FSNF2023%2F23_SNF_Tue_328_3595F_c.jpg&imageAlt=Hero+background&primaryLabel=Selling+a+Plane&primaryHref=%23&secondaryLabel=Buying+A+Plane&secondaryHref=%23&lockupOpacity=0.88";

const quoted = (v: string | undefined) => JSON.stringify(v ?? "");
const lockupOpacityLiteral =
	resolved.lockupOverlayOpacity != null && Number.isFinite(resolved.lockupOverlayOpacity)
		? String(resolved.lockupOverlayOpacity)
		: "undefined";
const imageLiteral = image
	? `{ src: ${JSON.stringify(image.src)}, alt: ${JSON.stringify(image.alt)} }`
	: "undefined";
const primaryCtaLiteral = primaryCta
	? `{ label: ${JSON.stringify(primaryCta.label)}, href: ${JSON.stringify(primaryCta.href)} }`
	: "undefined";
const secondaryCtaLiteral = secondaryCta
	? `{ label: ${JSON.stringify(secondaryCta.label)}, href: ${JSON.stringify(secondaryCta.href)} }`
	: "undefined";

const hubHeroExampleCode = `<HubHero
  hubName=${quoted(resolved.hubName)}
  columnName=${quoted(resolved.columnName)}
  title=${quoted(resolved.title)}
  description=${quoted(resolved.description)}
  variant=${quoted(resolved.variant)}
  minHeight=${quoted(resolved.minHeight)}
  primaryColor=${quoted(resolved.primaryColor)}
  lockupOverlayColor=${quoted(resolved.lockupOverlayColor)}
  lockupOverlayOpacity={${lockupOpacityLiteral}}
  copyTone=${quoted(resolved.copyTone)}
  lockupCopyTone=${quoted(resolved.lockupCopyTone)}
  image={${imageLiteral}}
  imageWidth=${quoted(resolved.imageWidth)}
  imageAlign=${quoted(resolved.imageAlign)}
  primaryCta={${primaryCtaLiteral}}
  secondaryCta={${secondaryCtaLiteral}}
/>`;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>AOPA hub — hero</title>
		<style is:global>
			body {
				margin: 0;
				padding: 0 0 8rem;
				min-height: 100vh;
				background: #e8e8e8;
			}

			.hh-dev-query-banner {
				margin: 0;
				padding: 0.5rem 1rem;
				font-family: system-ui, sans-serif;
				font-size: 0.8125rem;
				line-height: 1.4;
				color: #3d2f00;
				background: #ffe08a;
				border-bottom: 1px solid #e6c04d;
			}

			.hh-dev-query-banner a {
				color: #0b5cab;
				font-weight: 600;
			}

			.hh-hero-columns {
				max-width: 72rem;
				margin: 2rem auto 0;
				padding: 0 1rem;
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.875rem;
			}

			.hh-hero-columns__heading {
				max-width: 72rem;
				margin: 1.5rem auto 0.75rem;
				padding: 0 1rem;
				font-family: "Gotham Bold", Gotham, "Gotham", "Helvetica Neue", Arial, sans-serif;
				font-size: clamp(1rem, 0.92rem + 0.35vw, 1.125rem);
				line-height: 1.2;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: #1f2937;
			}

			.hh-hero-columns__item {
				padding: 1rem 1.1rem;
				background: rgba(255, 255, 255, 0.72);
				border: 1px solid rgba(0, 0, 0, 0.08);
				border-radius: 0.5rem;
				font-family: "Gotham Bold", Gotham, "Gotham", "Helvetica Neue", Arial, sans-serif;
				font-size: 1rem;
				line-height: 1.2;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: #1f2937;
			}

			.hh-hero-columns__link {
				display: block;
				margin-top: 0.65rem;
				font-family: "Gotham Book", Gotham, "Gotham", "Helvetica Neue", Arial, sans-serif;
				font-size: 0.875rem;
				line-height: 1.35;
				text-transform: none;
				letter-spacing: normal;
				color: #0b5cab;
				text-decoration: underline;
				text-underline-offset: 0.15em;
			}

			.hh-hero-code {
				max-width: 72rem;
				margin: 1rem auto 0;
				padding: 0 1rem;
				position: relative;
			}

			.hh-hero-code__actions {
				position: absolute;
				top: 0.55rem;
				right: 1.55rem;
				z-index: 1;
			}

			.hh-hero-code__copy {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.25rem 0.45rem;
				border: 1px solid rgba(255, 255, 255, 0.22);
				border-radius: 0.35rem;
				background: rgba(15, 23, 42, 0.45);
				font-family: "Gotham Book", Gotham, "Gotham", "Helvetica Neue", Arial, sans-serif;
				font-size: 0.8125rem;
				line-height: 1.2;
				color: #e2e8f0;
				text-decoration: none;
				cursor: pointer;
			}

			.hh-hero-code__copy:hover {
				background: rgba(15, 23, 42, 0.7);
			}

			.hh-hero-code__copy-icon {
				font-size: 0.9em;
				line-height: 1;
			}

			.hh-hero-code pre {
				margin: 0;
				padding: 0.85rem 1rem;
				border-radius: 0.5rem;
				border: 1px solid rgba(0, 0, 0, 0.1);
				background: #0f172a;
				color: #e2e8f0;
				font-size: 0.8rem;
				line-height: 1.45;
				overflow-x: auto;
			}

			.hh-hero-code .hh-code-tag {
				color: #7dd3fc;
			}

			.hh-hero-code .hh-code-prop {
				color: #f8fafc;
			}

			.hh-hero-code .hh-code-op {
				color: #93c5fd;
			}

			.hh-hero-code .hh-code-string {
				color: #86efac;
			}

			.hh-hero-code .hh-code-expr {
				color: #fbbf24;
			}

			@media (min-width: 860px) {
				.hh-hero-columns {
					grid-template-columns: repeat(4, minmax(0, 1fr));
				}
			}

		</style>
	</head>
	<body>
		{
			hubHeroPreviewOverrides && (
				<p class="hh-dev-query-banner" role="status">
					<strong>Hub hero query params are active.</strong> Known keys in the URL override{" "}
					<code>defaults</code> in <code>hero.astro</code>. Toolbar <strong>Update URL now</strong>{" "}
					also adds <code>hh=1</code> for shareable links.
					<a href={clearQueryHref}>Use code defaults only (strip query)</a>
				</p>
			)
		}
		<MainNav />
		<HubHero
			hubName={resolved.hubName}
			columnName={resolved.columnName}
			title={resolved.title}
			description={resolved.description}
			primaryColor={resolved.primaryColor}
			minHeight={resolved.minHeight}
			variant={resolved.variant}
			image={image}
			imageWidth={resolved.imageWidth}
			imageAlign={resolved.imageAlign}
			primaryCta={primaryCta}
			secondaryCta={secondaryCta}
			lockupOverlayOpacity={resolved.lockupOverlayOpacity}
			lockupOverlayColor={resolved.lockupOverlayColor}
			copyTone={resolved.copyTone}
			lockupCopyTone={resolved.lockupCopyTone}
		/>
		<h2 class="hh-hero-columns__heading">Sample heroes</h2>
		<section class="hh-hero-columns" aria-label="Hub sections">
			<div class="hh-hero-columns__item">
				Advocate
				<a class="hh-hero-columns__link" href={advocateCampaignHref}>legislative campaigns</a>
			</div>
			<div class="hh-hero-columns__item">
				Learn
				<a class="hh-hero-columns__link" href={trainingSafetyHref}>training &amp; safety</a>
				<a class="hh-hero-columns__link" href={careersEducationHref}>careers &amp; education</a>
				<a class="hh-hero-columns__link" href={rustyPilotsHref}>rusty pilots</a>
			</div>
			<div class="hh-hero-columns__item">
				Fly
				<a class="hh-hero-columns__link" href={aircraftBuyingOwnershipHref}
					>aircraft buying &amp; ownership</a
				>
			</div>
			<div class="hh-hero-columns__item">Community</div>
		</section>
		<section class="hh-hero-code" aria-label="HubHero component example">
			<div class="hh-hero-code__actions">
				<button type="button" class="hh-hero-code__copy" data-hh-copy-code>
					<span class="hh-hero-code__copy-icon" aria-hidden="true">⧉</span>
					<span>Copy</span>
				</button>
			</div>
			<pre><code data-hh-code-text>{hubHeroExampleCode}</code></pre>
		</section>
		<HubHeroDevToolbar
			pathname={Astro.url.pathname}
			resolved={resolved}
			syncUrlDefault={syncUrlDefault}
		/>
		<script type="application/json" id="hh-hub-defaults" set:html={JSON.stringify(defaults)} />
		<script>
			import {
				hydrateHubHeroFromCurrentUrl,
				readHubHeroForm,
				wireHubHeroLivePreview,
			} from "../../../scripts/hub-hero-live";

			const raw = document.getElementById("hh-hub-defaults")?.textContent;
			if (raw) {
				try {
					hydrateHubHeroFromCurrentUrl(JSON.parse(raw));
				} catch {
					/* ignore malformed embedded defaults */
				}
			}
			wireHubHeroLivePreview();

			const form = document.querySelector<HTMLFormElement>("[data-hh-dev-form]");
			const codeEl = document.querySelector<HTMLElement>("[data-hh-code-text]");
			const quote = (v: string | undefined) => JSON.stringify(v ?? "");
			const escapeHtml = (v: string) =>
				v
					.replace(/&/g, "&amp;")
					.replace(/</g, "&lt;")
					.replace(/>/g, "&gt;")
					.replace(/"/g, "&quot;")
					.replace(/'/g, "&#39;");
			const formatCodeValue = (raw: string) => {
				const v = raw.trim();
				if (v.startsWith('"') && v.endsWith('"')) {
					return `<span class="hh-code-string">${escapeHtml(v)}</span>`;
				}
				if (v.startsWith("{") && v.endsWith("}")) {
					return `<span class="hh-code-expr">${escapeHtml(v)}</span>`;
				}
				return escapeHtml(raw);
			};
			const renderHighlightedSnippet = (code: string) => {
				const lines = code.split("\n");
				return lines
					.map((line) => {
						const trimmed = line.trim();
						if (trimmed === "<HubHero") {
							return `<span class="hh-code-tag">&lt;HubHero</span>`;
						}
						if (trimmed === "/>") {
							return `<span class="hh-code-tag">/&gt;</span>`;
						}
						const m = line.match(/^(\s*)([A-Za-z_][\w]*)(=)(.*)$/);
						if (!m) return escapeHtml(line);
						const [, indent, prop, op, value] = m;
						return `${escapeHtml(indent)}<span class="hh-code-prop">${escapeHtml(prop)}</span><span class="hh-code-op">${escapeHtml(op)}</span>${formatCodeValue(value)}`;
					})
					.join("\n");
			};
			const renderHubHeroSnippet = (state: ReturnType<typeof readHubHeroForm>) => {
				const lockupOpacityLiteral =
					state.lockupOverlayOpacity != null && Number.isFinite(state.lockupOverlayOpacity)
						? String(state.lockupOverlayOpacity)
						: "undefined";
				const imageLiteral = state.imageSrc
					? `{ src: ${JSON.stringify(state.imageSrc)}, alt: ${JSON.stringify(state.imageAlt || "Hero background")} }`
					: "undefined";
				const primaryCtaLiteral = state.primaryLabel.trim()
					? `{ label: ${JSON.stringify(state.primaryLabel.trim())}, href: ${JSON.stringify(state.primaryHref || "#")} }`
					: "undefined";
				const secondaryCtaLiteral = state.secondaryLabel.trim()
					? `{ label: ${JSON.stringify(state.secondaryLabel.trim())}, href: ${JSON.stringify(state.secondaryHref || "#")} }`
					: "undefined";
				return `<HubHero
  hubName=${quote(state.hubName)}
  columnName=${quote(state.columnName)}
  title=${quote(state.title)}
  description=${quote(state.description)}
  variant=${quote(state.variant)}
  minHeight=${quote(state.minHeight)}
  primaryColor=${quote(state.primaryColor)}
  lockupOverlayColor=${quote(state.lockupOverlayColor)}
  lockupOverlayOpacity={${lockupOpacityLiteral}}
  copyTone=${quote(state.copyTone)}
  lockupCopyTone=${quote(state.lockupCopyTone)}
  image={${imageLiteral}}
  imageWidth=${quote(state.imageWidth)}
  imageAlign=${quote(state.imageAlign)}
  primaryCta={${primaryCtaLiteral}}
  secondaryCta={${secondaryCtaLiteral}}
/>`;
			};
			const syncCodeSnippet = () => {
				if (!form || !codeEl) return;
				const snippet = renderHubHeroSnippet(readHubHeroForm(form));
				codeEl.dataset.raw = snippet;
				codeEl.innerHTML = renderHighlightedSnippet(snippet);
			};
			syncCodeSnippet();
			form?.addEventListener("input", syncCodeSnippet);
			form?.addEventListener("change", syncCodeSnippet);

			const copyBtn = document.querySelector<HTMLButtonElement>("[data-hh-copy-code]");
			if (copyBtn && codeEl) {
				copyBtn.addEventListener("click", async () => {
					try {
						await navigator.clipboard.writeText(codeEl.dataset.raw ?? codeEl.textContent ?? "");
						copyBtn.textContent = "Copied";
					} catch {
						copyBtn.textContent = "Copy failed";
					}
					window.setTimeout(() => {
						copyBtn.innerHTML =
							'<span class="hh-hero-code__copy-icon" aria-hidden="true">⧉</span><span>Copy</span>';
					}, 1200);
				});
			}
		</script>
	</body>
</html>
