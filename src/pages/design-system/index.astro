---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Aopa Design System" description="Aopa Design System — documentation and decks.">
	<main>
		<h1 class="ds-index-title">Aopa Design System</h1>
		<ul class="ds-index-list">
			<li>
				<a href="/design-system/documentation">design documentation</a>
			</li>
			<li>
				<a href="/design-system/decks">decks</a>
			</li>
		</ul>
	</main>
</Layout>
<style>
	.ds-index {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.ds-index-title {
		font-family: var(--font-serif);
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 400;
		margin: 0 0 1.5rem;
		letter-spacing: 0.02em;
	}

	.ds-index-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.ds-index-list a {
		display: block;
		font-size: 1.1rem;
		color: var(--color-accent);
		text-decoration: none;
		padding: 0.5em 0;
		border-bottom: 1px solid var(--color-border);
	}

	.ds-index-list a:hover {
		text-decoration: underline;
	}
</style>
