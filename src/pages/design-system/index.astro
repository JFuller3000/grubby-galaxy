---
import SiteNav from '../../components/SiteNav.astro';
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content="Aopa Design System — documentation and decks." />
		<title>Aopa Design System</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
		<style is:global>
			:root {
				--color-bg: #faf9f7;
				--color-text: #1a1a1a;
				--color-muted: #5c5c5c;
				--color-accent: #2d5a4a;
				--color-border: #e5e3e0;
				--font-sans: 'DM Sans', system-ui, sans-serif;
				--font-serif: 'DM Serif Display', Georgia, serif;
				--max-width: 720px;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				padding: 2rem 1.5rem 4rem;
				font-family: var(--font-sans);
				font-size: 1rem;
				line-height: 1.6;
				color: var(--color-text);
				background: var(--color-bg);
			}

			.ds-index {
				max-width: var(--max-width);
				margin: 0 auto;
			}

			.ds-index h1 {
				font-family: var(--font-serif);
				font-size: clamp(1.75rem, 4vw, 2.25rem);
				font-weight: 400;
				margin: 0 0 1.5rem;
				letter-spacing: 0.02em;
			}

			.ds-index-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.ds-index-list a {
				display: block;
				font-size: 1.1rem;
				color: var(--color-accent);
				text-decoration: none;
				padding: 0.5em 0;
				border-bottom: 1px solid var(--color-border);
			}

			.ds-index-list a:hover {
				text-decoration: underline;
			}
		</style>
	</head>
	<body>
		<div class="ds-index">
			<SiteNav currentPath={currentPath} />
			<main>
				<h1>Aopa Design System</h1>
				<ul class="ds-index-list">
					<li>
						<a href="/design-system/documentation">design documentation</a>
					</li>
					<li>
						<a href="/design-system/decks">decks</a>
					</li>
				</ul>
			</main>
		</div>
	</body>
</html>
