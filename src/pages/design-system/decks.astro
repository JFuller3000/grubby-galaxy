---
import '../../styles/global.css';
import SiteNav from '../../components/SiteNav.astro';
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content="Aopa Design System — Decks." />
		<title>Aopa Design System — Decks</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen bg-[#faf9f7] px-6 py-8 pb-16 font-sans text-base leading-relaxed text-[#1a1a1a]">
		<div class="mx-auto max-w-[720px]">
			<SiteNav currentPath={currentPath} />
			<main>
				<h1 class="font-serif text-[clamp(1.75rem,4vw,2.25rem)] font-normal tracking-wide mb-4">Decks</h1>
				<p class="text-muted m-0">Design system decks and presentations. Add links or embed content here.</p>
			</main>
		</div>
	</body>
</html>
