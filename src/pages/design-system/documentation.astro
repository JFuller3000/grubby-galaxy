		<script>
			// Optional: highlight TOC link for current section on scroll
			const tocLinks = document.querySelectorAll('[data-doc="toc"] a[href^="#"]');
			const sections = Array.from(tocLinks).map(a => document.querySelector(a.getAttribute('href'))).filter(Boolean);

			function updateActive() {
				let current = tocLinks[0];
				for (let i = sections.length - 1; i >= 0; i--) {
					if (sections[i] && sections[i].getBoundingClientRect().top <= 120) {
						current = tocLinks[i];
						break;
					}
				}
				tocLinks.forEach(a => a.classList.remove('active'));
				if (current) current.classList.add('active');
			}

			window.addEventListener('scroll', updateActive, { passive: true });
			updateActive();

			// Tabs: color palettes + headings (each tab group scoped to its container)
			document.querySelectorAll('[data-doc="tablist"] [role="tab"]').forEach((tab) => {
				tab.addEventListener('click', () => {
					const panelId = tab.getAttribute('aria-controls');
					if (!panelId) return;
					const panel = document.getElementById(panelId);
					const container = panel?.closest('[data-doc="color-tabs"], [data-doc="headers-tabs"]');
					if (!container) return;
					container.querySelectorAll('[role="tab"]').forEach((t) => t.setAttribute('aria-selected', t.getAttribute('aria-controls') === panelId ? 'true' : 'false'));
					container.querySelectorAll('[data-doc="tabpanel"]').forEach((p) => { p.hidden = p.id !== panelId; });
				});
			});
		</script>
