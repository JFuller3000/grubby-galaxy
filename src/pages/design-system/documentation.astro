		<script>
			// Optional: highlight TOC link for current section on scroll
			const tocLinks = document.querySelectorAll('.doc-toc a[href^="#"]');
			const sections = Array.from(tocLinks).map(a => document.querySelector(a.getAttribute('href'))).filter(Boolean);

			function updateActive() {
				const scrollY = window.scrollY;
				let current = tocLinks[0];
				for (let i = sections.length - 1; i >= 0; i--) {
					if (sections[i] && sections[i].getBoundingClientRect().top <= 120) {
						current = tocLinks[i];
						break;
					}
				}
				tocLinks.forEach(a => a.classList.remove('active'));
				if (current) current.classList.add('active');
			}

			window.addEventListener('scroll', updateActive, { passive: true });
			updateActive();

			// Color palette tabs
			const colorTabs = document.querySelectorAll('.doc-tablist [role="tab"]');
			colorTabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					const panelId = tab.getAttribute('aria-controls');
					if (!panelId) return;
					colorTabs.forEach((t) => t.setAttribute('aria-selected', 'false'));
					tab.setAttribute('aria-selected', 'true');
					document.querySelectorAll('.doc-color-tabs .doc-tabpanel').forEach((panel) => {
						panel.hidden = panel.id !== panelId;
					});
				});
			});
		</script>
