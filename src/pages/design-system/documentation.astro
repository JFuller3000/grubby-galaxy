---
import '../../styles/global.css';
import SiteNav from '../../components/SiteNav.astro';
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content="Design System. Single source of truth for visual and interaction design." />
		<title>Design System</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
		<style is:global>
			@font-face {
				font-family: "Knockout 94";
				src: url("/fonts/knockout/Knockout-HTF94-UltmtSumo.otf") format("opentype");
				font-weight: normal;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Knockout 47";
				src: url("/fonts/knockout/Knockout-HTF47-Bantamweight.otf") format("opentype");
				font-weight: normal;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Gotham Book";
				src: url("/fonts/gotham/gothambook-webfont.woff") format("woff");
				font-weight: normal;
				font-style: normal;
				font-display: swap;
			}
			@font-face {
				font-family: "Gotham Bold";
				src: url("/fonts/gotham/gothambold-webfont.woff") format("woff");
				font-weight: 700;
				font-style: normal;
				font-display: swap;
			}
			[data-doc="toc-trigger"]::-webkit-details-marker {
				display: none;
			}
			[data-doc="toc-accordion"][open] [data-doc="toc-chevron"] {
				transform: rotate(90deg);
			}
			[data-doc="toc-accordion"]:has([data-doc="toc-trigger"] a.active) [data-doc="toc-trigger"] {
				border-left-color: #2d5a4a;
			}
			[data-doc="font-usage"] li::before {
				content: "– ";
				color: #2d5a4a;
			}
			[data-doc="toc-item"]:not([data-doc="toc-accordion"]):has(a.active) {
				border-left-color: #2d5a4a;
			}
		</style>
	</head>
	<body class="m-0 py-8 px-6 pb-16 font-body text-base leading-relaxed text-doc-text bg-doc-bg">
		<div class="w-full max-w-[988px] mx-auto">
			<SiteNav currentPath={currentPath} />
			<div class="w-full grid grid-cols-1 md:grid-cols-[220px_1fr] gap-6 md:gap-12 items-start">
			<aside data-doc="toc" class="min-w-0 sticky top-8 pb-4 border-b border-doc-border md:pb-0 md:border-b-0" aria-label="Table of contents">
				<p class="text-xs  uppercase tracking-widest text-doc-muted m-0 mb-3">On this page</p>
				<nav class="flex flex-col gap-0.5">
					<details data-doc="toc-accordion" class="border-0 p-0 m-0" open>
						<summary data-doc="toc-trigger" class="flex items-center justify-between w-full py-[0.35em] pl-2 -ml-2 text-[0.9rem] text-doc-muted text-left bg-transparent border-0 border-l-2 border-l-transparent cursor-pointer font-inherit gap-2 hover:text-doc-accent md:py-[0.4em] md:px-2 md:ml-0 md:border-l-0 md:rounded-sm md:bg-doc-border">
							<a href="#overview-heading" onclick="event.stopPropagation()" class="flex-1 text-inherit no-underline hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">1. Overview &amp; principles</a>
							<span data-doc="toc-chevron" class="shrink-0 transition-transform duration-200 ease-in-out opacity-70" aria-hidden="true">▸</span>
						</summary>
						<div data-doc="toc-panel" class="flex flex-col gap-0.5 pt-1 pb-2 pl-3 ml-1 border-l border-doc-border md:ml-0 md:pl-4">
							<a href="#purpose" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">1.1 Purpose</a>
							<a href="#principles" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">1.2 Design principles</a>
							<a href="#brand" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">1.3 Brand positioning</a>
						</div>
					</details>
					<details data-doc="toc-accordion" class="border-0 p-0 m-0">
						<summary data-doc="toc-trigger" class="flex items-center justify-between w-full py-[0.35em] pl-2 -ml-2 text-[0.9rem] text-doc-muted text-left bg-transparent border-0 border-l-2 border-l-transparent cursor-pointer font-inherit gap-2 hover:text-doc-accent md:py-[0.4em] md:px-2 md:ml-0 md:border-l-0 md:rounded-sm md:bg-doc-border">
							<a href="#foundations-heading" onclick="event.stopPropagation()" class="flex-1 text-inherit no-underline hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">2. Foundations</a>
							<span data-doc="toc-chevron" class="shrink-0 transition-transform duration-200 ease-in-out opacity-70" aria-hidden="true">▸</span>
						</summary>
						<div data-doc="toc-panel" class="flex flex-col gap-0.5 pt-1 pb-2 pl-3 ml-1 border-l border-doc-border md:ml-0 md:pl-4">
							<a href="#color" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">2.1 Color</a>
							<a href="#typography" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">2.2 Typography</a>
							<a href="#typography-fonts" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">Font families</a>
							<a href="#typography-headers" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">Headings and subheads</a>
							<a href="#spacing" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">2.3 Spacing &amp; layout</a>
							<a href="#motion" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">2.4 Motion &amp; animation</a>
							<a href="#iconography" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">2.5 Iconography</a>
							<a href="#imagery" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">2.6 Imagery &amp; media</a>
						</div>
					</details>
					<details data-doc="toc-accordion" class="border-0 p-0 m-0">
						<summary data-doc="toc-trigger" class="flex items-center justify-between w-full py-[0.35em] pl-2 -ml-2 text-[0.9rem] text-doc-muted text-left bg-transparent border-0 border-l-2 border-l-transparent cursor-pointer font-inherit gap-2 hover:text-doc-accent md:py-[0.4em] md:px-2 md:ml-0 md:border-l-0 md:rounded-sm md:bg-doc-border">
							<a href="#components-heading" onclick="event.stopPropagation()" class="flex-1 text-inherit no-underline hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">3. Components</a>
							<span data-doc="toc-chevron" class="shrink-0 transition-transform duration-200 ease-in-out opacity-70" aria-hidden="true">▸</span>
						</summary>
						<div data-doc="toc-panel" class="flex flex-col gap-0.5 pt-1 pb-2 pl-3 ml-1 border-l border-doc-border md:ml-0 md:pl-4">
							<a href="#component-template" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">3.1 Component template</a>
						</div>
					</details>
					<details data-doc="toc-accordion" class="border-0 p-0 m-0">
						<summary data-doc="toc-trigger" class="flex items-center justify-between w-full py-[0.35em] pl-2 -ml-2 text-[0.9rem] text-doc-muted text-left bg-transparent border-0 border-l-2 border-l-transparent cursor-pointer font-inherit gap-2 hover:text-doc-accent md:py-[0.4em] md:px-2 md:ml-0 md:border-l-0 md:rounded-sm md:bg-doc-border">
							<a href="#patterns-heading" onclick="event.stopPropagation()" class="flex-1 text-inherit no-underline hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">4. Patterns</a>
							<span data-doc="toc-chevron" class="shrink-0 transition-transform duration-200 ease-in-out opacity-70" aria-hidden="true">▸</span>
						</summary>
						<div data-doc="toc-panel" class="flex flex-col gap-0.5 pt-1 pb-2 pl-3 ml-1 border-l border-doc-border md:ml-0 md:pl-4">
							<a href="#layout-patterns" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">4.1 Layout patterns</a>
							<a href="#navigation" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">4.2 Navigation</a>
							<a href="#forms" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">4.3 Forms &amp; inputs</a>
							<a href="#feedback" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">4.4 Feedback &amp; status</a>
							<a href="#content-patterns" class="text-[0.8rem] text-doc-muted no-underline py-[0.2em] block hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium">4.5 Content patterns</a>
						</div>
					</details>
					<div data-doc="toc-item" class="py-[0.35em] pl-2 -ml-2 border-l-2 border-l-transparent md:py-[0.25em] md:px-2 md:ml-0 md:border-l-0 md:rounded-sm">
						<a href="#a11y-heading" class="block text-[0.9rem] text-doc-muted no-underline hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium md:py-[0.25em] md:px-2 md:bg-doc-border">5. Accessibility</a>
					</div>
					<div data-doc="toc-item" class="py-[0.35em] pl-2 -ml-2 border-l-2 border-l-transparent md:py-[0.25em] md:px-2 md:ml-0 md:border-l-0 md:rounded-sm">
						<a href="#responsive-heading" class="block text-[0.9rem] text-doc-muted no-underline hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium md:py-[0.25em] md:px-2 md:bg-doc-border">6. Responsive &amp; platform</a>
					</div>
					<div data-doc="toc-item" class="py-[0.35em] pl-2 -ml-2 border-l-2 border-l-transparent md:py-[0.25em] md:px-2 md:ml-0 md:border-l-0 md:rounded-sm">
						<a href="#governance-heading" class="block text-[0.9rem] text-doc-muted no-underline hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium md:py-[0.25em] md:px-2 md:bg-doc-border">7. Governance &amp; maintenance</a>
					</div>
					<div data-doc="toc-item" class="py-[0.35em] pl-2 -ml-2 border-l-2 border-l-transparent md:py-[0.25em] md:px-2 md:ml-0 md:border-l-0 md:rounded-sm">
						<a href="#appendix-heading" class="block text-[0.9rem] text-doc-muted no-underline hover:text-doc-accent [&.active]:text-doc-accent [&.active]:font-medium md:py-[0.25em] md:px-2 md:bg-doc-border">8. Appendix</a>
					</div>
				</nav>
			</aside>
			<article class="min-w-0 max-w-doc w-full prose prose-instruction text-doc-text">
			<header class="mb-10 pb-8 border-b border-doc-border">
				<h1 class="">AOPA Design System </h1>
				<p class="text-[1.05rem] text-doc-muted m-0 italic">Single source of truth for visual and interaction design. Use this to keep Figma, brand, and product work consistent. Code implementation references this document.</p>
			</header>

			<section class="mb-10" aria-labelledby="overview-heading">
				<h2 id="overview-heading" class="font-body">1. Overview &amp; principles</h2>

				<h3 id="purpose" class="font-bold uppercase  mt-6 mb-2">1.1 Purpose</h3>
				<ul class="m-0 mb-4 pl-5">
					<li class="mb-[0.35rem] text-doc-muted">This system is for AOPA's digital design & branding.</li>
					<li class="mb-[0.35rem] text-doc-muted">It serves devs, design and content producers.</li>
				</ul>

				<h3 id="principles" class="text-base  mt-6 mb-2">1.2 Design principles</h3>
				<ul class="m-0 mb-4 pl-5">
					<li class="mb-[0.35rem] text-doc-muted">Clear Communication</li>
					<li class="mb-[0.35rem] text-doc-muted">Simplified Structures</li>
					<li class="mb-[0.35rem] text-doc-muted">Impactful Patterns</li>
					<li class="mb-[0.35rem] text-doc-muted">Refined Typography</li>
				</ul>

				<h3 id="brand" class="text-base  mt-6 mb-2 text-doc-text">1.3 Brand positioning</h3>
				<ul class="m-0 mb-4 pl-5">
					<li class="mb-[0.35rem] text-doc-muted">Mission, voice, and personality in 1–2 paragraphs.</li>
					<li class="mb-[0.35rem] text-doc-muted">How the design system supports the brand (tone of UI, imagery, motion).</li>
				</ul>
			</section>

			<hr class="border-0 border-t border-doc-border my-8" />

			<section class="mb-10" aria-labelledby="foundations-heading">
				<h2 id="foundations-heading" class="">2. Foundations</h2>

				<h3 id="color" class="text-base  mt-6 mb-2 text-doc-text">2.1 Color</h3>
				<div data-doc="color-tabs" class="my-4 mb-6">
					<div data-doc="tablist" class="flex flex-wrap gap-1 mb-4 border-b border-doc-border" role="tablist" aria-label="Color palettes">
						<button type="button" role="tab" aria-selected="true" aria-controls="color-panel-primary" id="color-tab-primary" class="px-4 py-2 text-[0.9rem] font-inherit text-doc-muted bg-transparent border-0 border-b-2 border-b-transparent -mb-px cursor-pointer hover:text-doc-text [&[aria-selected=true]]:text-doc-accent [&[aria-selected=true]]:font-medium [&[aria-selected=true]]:border-b-doc-accent">Primary</button>
						<button type="button" role="tab" aria-selected="false" aria-controls="color-panel-ycf" id="color-tab-ycf" class="px-4 py-2 text-[0.9rem] font-inherit text-doc-muted bg-transparent border-0 border-b-2 border-b-transparent -mb-px cursor-pointer hover:text-doc-text [&[aria-selected=true]]:text-doc-accent [&[aria-selected=true]]:font-medium [&[aria-selected=true]]:border-b-doc-accent">You Can Fly</button>
						<button type="button" role="tab" aria-selected="false" aria-controls="color-panel-foundation" id="color-tab-foundation" class="px-4 py-2 text-[0.9rem] font-inherit text-doc-muted bg-transparent border-0 border-b-2 border-b-transparent -mb-px cursor-pointer hover:text-doc-text [&[aria-selected=true]]:text-doc-accent [&[aria-selected=true]]:font-medium [&[aria-selected=true]]:border-b-doc-accent">Foundation</button>
						<button type="button" role="tab" aria-selected="false" aria-controls="color-panel-asi" id="color-tab-asi" class="px-4 py-2 text-[0.9rem] font-inherit text-doc-muted bg-transparent border-0 border-b-2 border-b-transparent -mb-px cursor-pointer hover:text-doc-text [&[aria-selected=true]]:text-doc-accent [&[aria-selected=true]]:font-medium [&[aria-selected=true]]:border-b-doc-accent">Air Safety Institute</button>
					</div>
					<div id="color-panel-primary" role="tabpanel" aria-labelledby="color-tab-primary" data-doc="tabpanel" class="pt-1">
						<h4 class="text-[0.95rem]  mt-4 mb-[0.35rem] text-doc-muted">Primary palette</h4>
						<div class="grid grid-cols-5 gap-6 my-4 mb-6 p-0">
							<div class="flex flex-col items-center gap-3">
								<span class="inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0" style="background: rgb(22, 51, 114);" aria-hidden="true"></span>
								<dl class="m-0 p-0 text-center">
									<dt class=" text-sm text-doc-text m-0 mb-1">aopa-dkblue</dt>
									<dd class="m-0 text-[0.8rem] text-doc-muted leading-snug"><code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">rgb(22, 51, 114)</code> / <code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">#163372</code></dd>
								</dl>
							</div>
							<div class="flex flex-col items-center gap-3">
								<span class="inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0" style="background: rgb(15, 37, 84);" aria-hidden="true"></span>
								<dl class="m-0 p-0 text-center">
									<dt class=" text-sm text-doc-text m-0 mb-1">aopa-deep-blue</dt>
									<dd class="m-0 text-[0.8rem] text-doc-muted leading-snug"><code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">rgb(15, 37, 84)</code> / <code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">#0f2554</code></dd>
								</dl>
							</div>
							<div class="flex flex-col items-center gap-3">
								<span class="inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0" style="background: #0f4c5c;" aria-hidden="true"></span>
								<dl class="m-0 p-0 text-center">
									<dt class=" text-sm text-doc-text m-0 mb-1">aopa-darkgreen</dt>
									<dd class="m-0 text-[0.8rem] text-doc-muted leading-snug"><code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">#0f4c5c</code></dd>
								</dl>
							</div>
							<div class="flex flex-col items-center gap-3">
								<span class="inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0" style="background: rgb(0, 134, 184);" aria-hidden="true"></span>
								<dl class="m-0 p-0 text-center">
									<dt class=" text-sm text-doc-text m-0 mb-1">aopa-ltblue</dt>
									<dd class="m-0 text-[0.8rem] text-doc-muted leading-snug"><code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">rgb(0, 134, 184)</code> / <code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">#0086b8</code></dd>
								</dl>
							</div>
							<div class="flex flex-col items-center gap-3">
								<span class="inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0 bg-[#f3f4f6]" aria-hidden="true"></span>
								<dl class="m-0 p-0 text-center">
									<dt class=" text-sm text-doc-text m-0 mb-1">aopa-bg-grey</dt>
									<dd class="m-0 text-[0.8rem] text-doc-muted leading-snug"><code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">bg-grey-100</code> / <code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">#f3f4f6</code></dd>
								</dl>
							</div>
						</div>
					</div>
					<div id="color-panel-ycf" role="tabpanel" aria-labelledby="color-tab-ycf" data-doc="tabpanel" class="pt-1" hidden>
						<h4 class="text-[0.95rem]  mt-4 mb-[0.35rem] text-doc-muted">You Can Fly palette</h4>
						<div class="grid grid-cols-4 gap-6 my-4 mb-6 p-0">
							<div class="flex flex-col items-center gap-3">
								<span class="inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0" style="background: #f6c655;" aria-hidden="true"></span>
								<dl class="m-0 p-0 text-center">
									<dt class=" text-sm text-doc-text m-0 mb-1">ycf-yellow</dt>
									<dd class="m-0 text-[0.8rem] text-doc-muted leading-snug"><code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">#f6c655</code></dd>
								</dl>
							</div>
							<div class="flex flex-col items-center gap-3">
								<span class="inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0" style="background: #575859;" aria-hidden="true"></span>
								<dl class="m-0 p-0 text-center">
									<dt class=" text-sm text-doc-text m-0 mb-1">ycf-grey</dt>
									<dd class="m-0 text-[0.8rem] text-doc-muted leading-snug"><code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">#575859</code></dd>
								</dl>
							</div>
							<div class="flex flex-col items-center gap-3">
								<span class="inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0" style="background: #5d0066;" aria-hidden="true"></span>
								<dl class="m-0 p-0 text-center">
									<dt class=" text-sm text-doc-text m-0 mb-1">ycf-accent</dt>
									<dd class="m-0 text-[0.8rem] text-doc-muted leading-snug"><code class="text-[0.9em] bg-doc-border py-[0.15em] px-[0.4em] rounded-sm">#5d0066</code></dd>
								</dl>
							</div>
							<div class="doc-palette-item flex flex-col items-center gap-3">
								<span class="doc-swatch doc-swatch-lg inline-block w-28 h-28 rounded-lg border border-doc-border shrink-0 bg-[#f3f4f6]" aria-hidden="true"></span>
