---
import '../../styles/global.css';
import SiteNav from '../../components/SiteNav.astro';
import Accordion from '../../components/Accordion.astro';
import Button from '../../components/Button.astro';
const currentPath = Astro.url.pathname;

// Faked accordion data for design system demo (future: from WP)
const accordionItems = [
  { title: 'When to use', content: '<p>Use the accordion for FAQs, optional details, or content that benefits from progressive disclosure. Avoid for critical information that should always be visible.</p>' },
  { title: 'Behavior', content: '<p>Only one panel is open at a time (single). Click the header to toggle. The plus icon rotates to indicate expanded state. Animations respect <code>prefers-reduced-motion</code> where implemented.</p>' },
  { title: 'Accessibility', content: '<p>Headers use <code>aria-expanded</code> and <code>aria-controls</code>. Content panels are associated via <code>aria-labelledby</code>. Keyboard support: focus and activate with Enter or Space.</p>' },
];
---
<!DOCTYPE html>
<html lang="en">
	<head>
