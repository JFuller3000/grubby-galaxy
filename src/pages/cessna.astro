---
---

<div id="cessna-sim">
  <div id="hud" aria-live="polite"></div>
  <div id="high-score-modal" role="dialog" aria-modal="true" aria-labelledby="high-score-title" hidden>
    <form id="high-score-form" class="high-score-card">
      <p id="high-score-kicker" class="high-score-kicker">Level 1-1 complete</p>
      <h2 id="high-score-title">High Score</h2>
      <div class="high-score-stats">
        <div>
          <span>Score</span>
          <strong id="final-score">0</strong>
        </div>
        <div>
          <span>Time</span>
          <strong id="final-time">0.0 s</strong>
        </div>
      </div>
      <label class="initials-field">
        <span>Initials</span>
        <input id="initials-input" name="initials" maxlength="3" autocomplete="off" inputmode="text" />
      </label>
      <div class="high-score-actions">
        <button id="save-score-button" type="submit">Save score</button>
        <button id="restart-course-button" type="button">Fly again</button>
        <button id="next-level-button" type="button">Level 1-2</button>
      </div>
      <ol id="high-score-list" class="high-score-list" aria-label="Local high scores"></ol>
    </form>
  </div>
</div>

<style>
  :global(html),
  :global(body) {
    margin: 0 !important;
    padding: 0 !important;
    width: 100%;
    height: 100%;
    min-height: 100%;
    overflow: hidden;
    background: #000;
  }

  #cessna-sim {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    isolation: isolate;
  }

  #hud {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
    max-width: min(36rem, calc(100vw - 2rem));
    color: white;
    font: 14px/1.45 monospace;
    background: rgba(0, 0, 0, 0.55);
    padding: 10px 12px;
    border-radius: 8px;
    pointer-events: none;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(6px);
  }

  #high-score-modal {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: grid;
    place-items: center;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.36);
    backdrop-filter: blur(8px);
  }

  #high-score-modal[hidden] {
    display: none;
  }

  .high-score-card {
    width: min(28rem, 100%);
    border: 1px solid rgba(255, 212, 71, 0.36);
    border-radius: 8px;
    background: rgba(9, 12, 18, 0.88);
    color: white;
    padding: 1.25rem;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
    font-family: system-ui, sans-serif;
  }

  .high-score-kicker {
    margin: 0 0 0.3rem;
    color: #ffd447;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .high-score-card h2 {
    margin: 0;
    font-size: clamp(2rem, 8vw, 3rem);
    line-height: 1;
  }

  .high-score-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .high-score-stats div {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 6px;
    padding: 0.75rem;
    background: rgba(255, 255, 255, 0.06);
  }

  .high-score-stats span,
  .initials-field span {
    display: block;
    margin-bottom: 0.25rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .high-score-stats strong {
    display: block;
    font-size: 1.6rem;
    line-height: 1.1;
  }

  .initials-field input {
    width: 100%;
    border: 1px solid rgba(255, 212, 71, 0.5);
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.34);
    color: #ffd447;
    padding: 0.65rem 0.75rem;
    font: 800 1.6rem/1 monospace;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .initials-field input:focus-visible,
  .high-score-actions button:focus-visible {
    outline: 2px solid #ffd447;
    outline-offset: 2px;
  }

  .high-score-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .high-score-actions button {
    flex: 1 1 9rem;
    border: 0;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    color: #111;
    background: #ffd447;
    font-weight: 800;
    cursor: pointer;
  }

  .high-score-actions button + button {
    color: white;
    background: rgba(255, 255, 255, 0.14);
  }

  .high-score-list {
    display: grid;
    gap: 0.45rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    color: rgba(255, 255, 255, 0.82);
  }

  #high-score-modal :global(.high-score-row) {
    display: grid;
    grid-template-columns: 2.5rem minmax(3.5rem, 1fr) minmax(5rem, auto) minmax(4rem, auto);
    column-gap: 1rem;
    align-items: baseline;
    font: 700 0.9rem/1.2 monospace;
  }

  #high-score-modal :global(.high-score-row__score),
  #high-score-modal :global(.high-score-row__time) {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  #high-score-modal :global(.empty-score) {
    grid-template-columns: 1fr;
    color: rgba(255, 255, 255, 0.56);
  }

  #cessna-sim :global(canvas) {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100% !important;
    height: 100% !important;
  }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { Water } from 'three/examples/jsm/objects/Water.js';
  import { Sky } from 'three/examples/jsm/objects/Sky.js';

  const container = document.getElementById('cessna-sim');
  const hud = document.getElementById('hud');
  const highScoreModal = document.getElementById('high-score-modal');
  const highScoreForm = document.getElementById('high-score-form');
  const highScoreKicker = document.getElementById('high-score-kicker');
  const initialsInput = document.getElementById('initials-input');
  const finalScore = document.getElementById('final-score');
  const finalTime = document.getElementById('final-time');
  const highScoreList = document.getElementById('high-score-list');
  const saveScoreButton = document.getElementById('save-score-button');
  const restartCourseButton = document.getElementById('restart-course-button');
  const nextLevelButton = document.getElementById('next-level-button');
  const currentLevel = new URLSearchParams(window.location.search).get('level') === '1-2' ? '1-2' : '1-1';
  const nextLevel = currentLevel === '1-1' ? '1-2' : null;

  const scene = new THREE.Scene();

  const camera = new THREE.PerspectiveCamera(
    65,
    window.innerWidth / window.innerHeight,
    1,
    9000
  );

  const renderer = new THREE.WebGLRenderer({
    antialias: true,
    logarithmicDepthBuffer: true,
  });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.shadowMap.enabled = true;
  Object.assign(renderer.domElement.style, {
    position: 'absolute',
    inset: '0',
    zIndex: '0',
    width: '100%',
    height: '100%',
  });
  container.appendChild(renderer.domElement);

  const sun = new THREE.Vector3();

  const sky = new Sky();
  sky.scale.setScalar(10000);
  scene.add(sky);

  sky.material.uniforms.turbidity.value = 4;
  sky.material.uniforms.rayleigh.value = 2;
  sky.material.uniforms.mieCoefficient.value = 0.003;
  sky.material.uniforms.mieDirectionalG.value = 0.8;

  sun.setFromSphericalCoords(
    1,
    THREE.MathUtils.degToRad(88),
    THREE.MathUtils.degToRad(180)
  );

  sky.material.uniforms.sunPosition.value.copy(sun);

  const waterNormals = new THREE.TextureLoader().load(
    '/waternormals.jpg',
    texture => {
      texture.wrapS = texture.wrapT = THREE.RepeatWrapping;
      texture.minFilter = THREE.LinearMipmapLinearFilter;
      texture.magFilter = THREE.LinearFilter;
      texture.anisotropy = Math.min(renderer.capabilities.getMaxAnisotropy(), 8);
      texture.needsUpdate = true;
    }
  );

  const water = new Water(
    new THREE.PlaneGeometry(12000, 12000),
    {
      textureWidth: 1024,
      textureHeight: 1024,
      clipBias: 0.003,
      waterNormals,
      sunDirection: sun.clone().normalize(),
      sunColor: 0xffffff,
      waterColor: 0x174a6a,
      distortionScale: 1.45,
      fog: false,
    }
  );

  water.rotation.x = -Math.PI / 2;
  water.material.uniforms.size.value = 0.45;
  scene.add(water);

  scene.add(new THREE.HemisphereLight(0xffffff, 0x334455, 2.2));

  const dir = new THREE.DirectionalLight(0xffffff, 2.4);
  dir.position.set(-300, 500, 200);
  scene.add(dir);

  const ground = new THREE.Mesh(
    new THREE.PlaneGeometry(1400, 2400, 40, 40),
    new THREE.MeshStandardMaterial({ color: 0x31552e, roughness: 1 })
  );
  ground.rotation.x = -Math.PI / 2;
  ground.position.set(0, 2, -900);
  // scene.add(ground);

  const runway = new THREE.Mesh(
    new THREE.BoxGeometry(70, 1, 900),
    new THREE.MeshStandardMaterial({ color: 0x222222 })
  );
  runway.position.set(0, 3, -900);
  // scene.add(runway);

  const plane = new THREE.Group();
  plane.position.set(0, 80, 150);
  scene.add(plane);

  const boat = new THREE.Group();
  boat.position.set(80, -4, -150);
  scene.add(boat);

  new GLTFLoader().load('/models/sailboat.glb', gltf => {
    const model = gltf.scene;
    model.scale.setScalar(1.5);
    boat.add(model);
  });

  const ducky = new THREE.Group();
  ducky.position.set(400, -1, -750);
  scene.add(ducky);

  new GLTFLoader().load('/models/rubber_ducky.glb', gltf => {
    const model = gltf.scene;
    model.scale.setScalar(100.5);
    ducky.add(model);
  });

  const lighthouse = new THREE.Group();
  lighthouse.position.set(-360, -3, -1250);
  scene.add(lighthouse);

  new GLTFLoader().load('/models/lighthouse.glb', gltf => {
    const model = gltf.scene;
    model.scale.setScalar(20);
    lighthouse.add(model);
  });

  const pirateIsland = new THREE.Group();
  pirateIsland.position.set(-1720, 2, -2180);
  scene.add(pirateIsland);

  new GLTFLoader().load('/models/pirate_island.glb', gltf => {
    const model = gltf.scene;
    model.scale.setScalar(1.5);
    model.rotation.y = THREE.MathUtils.degToRad(-12);
    pirateIsland.add(model);
  });

  const ringCourse = new THREE.Group();
  scene.add(ringCourse);

  const ringGeometry = new THREE.TorusGeometry(18, 2.2, 16, 64);
  const ringGlowGeometry = new THREE.TorusGeometry(18.4, 4.2, 12, 64);
  const ringMaterial = new THREE.MeshStandardMaterial({
    color: 0xffd447,
    emissive: 0xff9b00,
    emissiveIntensity: 1.8,
    metalness: 0.15,
    roughness: 0.28,
  });
  const ringGlowMaterial = new THREE.MeshBasicMaterial({
    color: 0xffc928,
    transparent: true,
    opacity: 0.24,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
  });
  const levelConfigs = {
    '1-1': {
      label: 'Level 1-1',
      ringPositions: [
        new THREE.Vector3(0, 92, -80),
        new THREE.Vector3(-55, 98, -260),
        new THREE.Vector3(-140, 112, -450),
        new THREE.Vector3(-265, 126, -650),
        new THREE.Vector3(-430, 134, -850),
        new THREE.Vector3(-630, 128, -1060),
        new THREE.Vector3(-865, 116, -1280),
        new THREE.Vector3(-1120, 110, -1510),
        new THREE.Vector3(-1390, 98, -1760),
        new THREE.Vector3(-1600, 92, -2010),
      ],
    },
    '1-2': {
      label: 'Level 1-2',
      ringPositions: [
        new THREE.Vector3(35, 106, -120),
        new THREE.Vector3(120, 138, -330),
        new THREE.Vector3(40, 168, -540),
        new THREE.Vector3(-130, 142, -760),
        new THREE.Vector3(-350, 104, -980),
        new THREE.Vector3(-610, 152, -1180),
        new THREE.Vector3(-850, 182, -1390),
        new THREE.Vector3(-1110, 128, -1625),
        new THREE.Vector3(-1360, 96, -1880),
        new THREE.Vector3(-1680, 118, -2160),
      ],
    },
  };
  const currentLevelConfig = levelConfigs[currentLevel];
  const ringPositions = currentLevelConfig.ringPositions;
  const rings = ringPositions.map((position, index) => {
    const group = new THREE.Group();
    group.position.copy(position);

    const glow = new THREE.Mesh(ringGlowGeometry, ringGlowMaterial);
    const ring = new THREE.Mesh(ringGeometry, ringMaterial);
    group.add(glow, ring);

    const target = ringPositions[index + 1] ?? position.clone().add(new THREE.Vector3(-120, 0, -160));
    group.lookAt(target);
    ringCourse.add(group);

    return {
      group,
      ring,
      glow,
      collected: false,
      pulseOffset: index * 0.65,
    };
  });
  const ringHitRadius = 26;
  const courseStartTime = 0;
  let score = 0;
  let ringsCollected = 0;
  let scoreFlashTime = 0;
  let lastRingScore = 0;
  let lastCenterAccuracy = 0;
  let lastCenterBonus = 0;
  let courseComplete = false;
  let highScoreOpen = false;
  let finalCourseTime = 0;
  const highScoreStorageKey = `cessna-ring-high-scores-${currentLevel}`;

  const sanitizeInitials = value => value.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 3);

  const getHighScores = () => {
    try {
      const scores = JSON.parse(localStorage.getItem(highScoreStorageKey) || '[]');
      return Array.isArray(scores) ? scores : [];
    } catch {
      return [];
    }
  };

  const setHighScores = scores => {
    try {
      localStorage.setItem(highScoreStorageKey, JSON.stringify(scores));
    } catch {
      // Local storage can be unavailable in private browsing; the modal still works for this run.
    }
  };

  const renderHighScores = () => {
    highScoreList.replaceChildren();
    const scores = getHighScores();

    if (scores.length === 0) {
      const empty = document.createElement('li');
      empty.className = 'high-score-row empty-score';
      empty.textContent = 'No scores yet';
      highScoreList.append(empty);
      return;
    }

    scores.forEach((entry, index) => {
      const item = document.createElement('li');
      const rank = document.createElement('span');
      const initials = document.createElement('span');
      const points = document.createElement('span');
      const time = document.createElement('span');

      item.className = 'high-score-row';
      rank.className = 'high-score-row__rank';
      initials.className = 'high-score-row__initials';
      points.className = 'high-score-row__score';
      time.className = 'high-score-row__time';

      rank.textContent = `${index + 1}.`;
      initials.textContent = entry.initials;
      points.textContent = String(entry.score);
      time.textContent = `${Number(entry.time).toFixed(1)}s`;

      item.append(rank, initials, points, time);
      highScoreList.append(item);
    });
  };

  const saveHighScore = initials => {
    const entry = {
      initials: sanitizeInitials(initials) || 'ACE',
      score,
      time: finalCourseTime,
      date: Date.now(),
    };
    const scores = [entry, ...getHighScores()]
      .sort((a, b) => b.score - a.score || a.time - b.time)
      .slice(0, 5);

    setHighScores(scores);
    renderHighScores();
  };

  const showHighScoreModal = courseTime => {
    highScoreOpen = true;
    finalCourseTime = Number(courseTime.toFixed(1));
    highScoreKicker.textContent = `${currentLevelConfig.label} complete`;
    finalScore.textContent = String(score);
    finalTime.textContent = `${finalCourseTime.toFixed(1)} s`;
    highScoreForm.dataset.saved = 'false';
    saveScoreButton.textContent = 'Save score';
    nextLevelButton.hidden = !nextLevel;
    nextLevelButton.textContent = nextLevel ? `Level ${nextLevel}` : '';
    initialsInput.value = '';
    Object.keys(keys).forEach(code => {
      keys[code] = false;
    });
    renderHighScores();
    highScoreModal.hidden = false;
    requestAnimationFrame(() => initialsInput.focus());
  };

  let propellerPivotLeft = null;
  let propellerPivotRight = null;
  let rudderPivot = null;
  let rudderNeutralRotation = 0;
  const rudderMaxDeflection = THREE.MathUtils.degToRad(30);

  const fallback = new THREE.Mesh(
    new THREE.BoxGeometry(4, 1, 8),
    new THREE.MeshStandardMaterial({ color: 0xffffff })
  );
  plane.add(fallback);

  new GLTFLoader().load(
    '/models/cessna-3.glb',
    gltf => {
      plane.remove(fallback);
      const model = gltf.scene;
      model.scale.setScalar(2);
      model.rotation.y = Math.PI;
      plane.add(model);

      plane.updateWorldMatrix(true, true);

      const propLeft = model.getObjectByName('node159_78');
      const propRight = model.getObjectByName('node159001_79');

      [propLeft, propRight].forEach((prop, i) => {
        if (!prop) return;
        const blade = prop.getObjectByName(i === 0 ? 'Object_99' : 'Object_101') || prop;
        const worldCenter = new THREE.Vector3();
        new THREE.Box3().setFromObject(blade).getCenter(worldCenter);
        const parent = prop.parent || model;

        const pivot = new THREE.Object3D();
        pivot.position.copy(parent.worldToLocal(worldCenter.clone()));
        parent.add(pivot);
        pivot.attach(prop);

        if (i === 0) propellerPivotLeft = pivot; else propellerPivotRight = pivot;
      });

      const rudderMesh = model.getObjectByName('node166_85');

      if (rudderMesh) {
        const rudderBounds = new THREE.Box3().setFromObject(rudderMesh);
        const rudderSize = rudderBounds.getSize(new THREE.Vector3());
        const rudderCenter = rudderBounds.getCenter(new THREE.Vector3());
        const rudderDepth = THREE.MathUtils.clamp(rudderSize.z * 0.42, 0.8, 1.8);
        const rudderHeight = THREE.MathUtils.clamp(rudderSize.y * 0.78, 1.8, 4.5);
        const rudderThickness = THREE.MathUtils.clamp(rudderSize.x * 0.75, 0.08, 0.22);
        const hingeWorld = new THREE.Vector3(
          rudderCenter.x,
          rudderCenter.y,
          rudderBounds.max.z - rudderDepth
        );

        rudderPivot = new THREE.Object3D();
        rudderPivot.position.copy(plane.worldToLocal(hingeWorld.clone()));
        plane.add(rudderPivot);

        const rudderFlap = new THREE.Mesh(
          new THREE.BoxGeometry(rudderThickness, rudderHeight, rudderDepth),
          new THREE.MeshStandardMaterial({
            color: 0xf2f4f5,
            roughness: 0.8,
            metalness: 0,
          })
        );
        rudderFlap.position.set(0, 0, rudderDepth / 2);
        rudderPivot.add(rudderFlap);
        rudderNeutralRotation = rudderPivot.rotation.y;
      }
    },
    undefined,
    error => {
      console.warn('Could not load /models/cessna-3.glb', error);
    }
  );

  const keys = {};

  initialsInput.addEventListener('input', () => {
    initialsInput.value = sanitizeInitials(initialsInput.value);
  });

  highScoreForm.addEventListener('submit', e => {
    e.preventDefault();
    if (highScoreForm.dataset.saved === 'true') return;

    saveHighScore(initialsInput.value);
    highScoreForm.dataset.saved = 'true';
    saveScoreButton.textContent = 'Saved';
  });

  restartCourseButton.addEventListener('click', () => {
    window.location.reload();
  });

  nextLevelButton.addEventListener('click', () => {
    if (!nextLevel) return;
    window.location.assign(`${window.location.pathname}?level=${nextLevel}`);
  });

  window.addEventListener('keydown', e => {
    if (highScoreOpen) return;
    if (e.repeat) return;
    keys[e.code] = true;

    const now = performance.now();
    if (e.code === 'ArrowLeft' && now - lastLeftTap < doubleTapWindow && lastLeftTap > 0) {
      if (barrelRoll === 0) barrelRoll = -1;
    }
    if (e.code === 'ArrowRight' && now - lastRightTap < doubleTapWindow && lastRightTap > 0) {
      if (barrelRoll === 0) barrelRoll = 1;
    }
    if (e.code === 'ArrowLeft') lastLeftTap = now;
    if (e.code === 'ArrowRight') lastRightTap = now;
  });

  window.addEventListener('keyup', e => {
    keys[e.code] = false;
  });

  window.addEventListener('keyup', e => {
    keys[e.code] = false;
  });

  let throttle = 0.45;
  let speed = 0;
  let pitch = 0;
  let roll = 0;
  let yaw = 0;
  let barrelRoll = 0;
  let barrelRollYaw = 0;

  const velocity = new THREE.Vector3();
  const forward = new THREE.Vector3();
  const clock = new THREE.Clock();

  let lastLeftTap = 0;
  let lastRightTap = 0;
  const doubleTapWindow = 250;

  window.addEventListener('keydown', e => {
    if (highScoreOpen) return;
    if (e.repeat) return;
    if (keys[e.code]) return;
    keys[e.code] = true;

    const now = performance.now();
    if (e.code === 'ArrowLeft' && now - lastLeftTap < doubleTapWindow && lastLeftTap > 0) {
      if (barrelRoll === 0) barrelRoll = -1;
    }
    if (e.code === 'ArrowRight' && now - lastRightTap < doubleTapWindow && lastRightTap > 0) {
      if (barrelRoll === 0) barrelRoll = 1;
    }
    if (e.code === 'ArrowLeft') lastLeftTap = now;
    if (e.code === 'ArrowRight') lastRightTap = now;
  });

  function animate() {
    requestAnimationFrame(animate);

    const dt = Math.min(clock.getDelta(), 0.033);

    if (keys.KeyW) throttle += dt * 0.25;
    if (keys.KeyS) throttle -= dt * 0.25;

    throttle = THREE.MathUtils.clamp(throttle, 0, 1);

    const pitchInput = (keys.ArrowUp ? 1 : 0) - (keys.ArrowDown ? 1 : 0);
    const rollInput = (keys.ArrowRight ? 1 : 0) - (keys.ArrowLeft ? 1 : 0);
    const yawInput = (keys.KeyA ? 1 : 0) - (keys.KeyD ? 1 : 0);

    const climbRate = ((keys.ArrowUp ? 1 : 0) - (keys.ArrowDown ? 1 : 0)) * 45;

    pitch += pitchInput * dt * 0.8;
    roll += rollInput * dt * 1.4;
    yaw += yawInput * dt * 0.6;

    pitch *= 0.985;
    roll *= 0.985;
    yaw *= 0.985;

    if (rudderPivot) {
      const rudderTarget = rudderNeutralRotation - yawInput * rudderMaxDeflection;
      rudderPivot.rotation.y = THREE.MathUtils.lerp(
        rudderPivot.rotation.y,
        rudderTarget,
        Math.min(1, dt * 10)
      );
    }

    speed += throttle * dt * 22;
    speed -= dt * (2.5 + speed * 0.15);
    speed = THREE.MathUtils.clamp(speed, 0, 132);

    velocity.y = climbRate;

    plane.rotation.order = 'YXZ';
    
    if (barrelRoll !== 0) {
      plane.rotation.z += barrelRoll * dt * Math.PI * 2;
      barrelRollYaw += barrelRoll * dt * 1.5;
      if (Math.abs(plane.rotation.z) >= Math.PI * 2) {
        plane.rotation.z = 0;
        barrelRoll = 0;
        barrelRollYaw = 0;
      }
    } else {
      plane.rotation.z = roll;
    }
    
    plane.rotation.y += yaw * dt + roll * dt * 0.35 + barrelRollYaw * dt * 0.5;
    plane.rotation.x = pitch;

    forward.set(0, 0, -1).applyQuaternion(plane.quaternion);

    velocity.x = forward.x * speed;
    velocity.z = forward.z * speed;

    plane.position.addScaledVector(velocity, dt);

    if (plane.position.y < 7) {
      plane.position.y = 7;
      velocity.y = Math.max(0, velocity.y);
      speed *= 0.998;
    }

    const camOffset = new THREE.Vector3(0, 18, 55);
    camOffset.applyQuaternion(plane.quaternion);

    camera.position.lerp(
      plane.position.clone().add(camOffset),
      0.08
    );

    camera.lookAt(
      plane.position.clone().add(new THREE.Vector3(0, 4, 0))
    );

    water.material.uniforms.time.value += dt * 0.4;

    const boatBobbing = Math.sin(clock.getElapsedTime() * 1.5);
    boat.position.y = -4 + boatBobbing * 1.0;
    boat.rotation.z = Math.cos(clock.getElapsedTime() * 1.5) * 0.12 + 0.06;
    boat.position.z += 3.09 * dt;
    if (boat.position.z > 200) boat.position.z = -200;

    const bobbing = Math.sin(clock.getElapsedTime() * 2.0);
    ducky.position.y = -1 + bobbing * 1.15;
    ducky.rotation.z = Math.cos(clock.getElapsedTime() * 2.0) * 0.1;

    const propSpin = (10 + throttle * 70) * dt;

    if (propellerPivotLeft) {
      propellerPivotLeft.rotation.y += propSpin;
    }
    if (propellerPivotRight) {
      propellerPivotRight.rotation.y += propSpin;
    }

    scoreFlashTime = Math.max(0, scoreFlashTime - dt);
    const ringPulseTime = clock.getElapsedTime();
    rings.forEach(ringTarget => {
      if (ringTarget.collected) return;

      const pulse = 1 + Math.sin(ringPulseTime * 4 + ringTarget.pulseOffset) * 0.08;
      ringTarget.group.scale.setScalar(pulse);
      ringTarget.ring.rotation.z += dt * 2.6;
      ringTarget.glow.rotation.z -= dt * 1.7;

      const ringDistance = plane.position.distanceTo(ringTarget.group.position);

      if (ringDistance < ringHitRadius) {
        const courseTime = clock.getElapsedTime() - courseStartTime;
        const speedMph = speed * 2.237;
        const speedBonus = Math.round(speedMph * 3);
        const timeBonus = Math.max(0, Math.round(600 - courseTime * 8));
        const centerAccuracy = 1 - ringDistance / ringHitRadius;
        const centerBonus = Math.round(centerAccuracy * 500);
        const ringScore = 100 + speedBonus + timeBonus + centerBonus;

        ringTarget.collected = true;
        ringTarget.group.visible = false;
        score += ringScore;
        lastRingScore = ringScore;
        lastCenterAccuracy = centerAccuracy;
        lastCenterBonus = centerBonus;
        ringsCollected += 1;
        scoreFlashTime = 0.9;
      }
    });

    const courseTime = clock.getElapsedTime() - courseStartTime;
    if (!courseComplete && ringsCollected === rings.length) {
      courseComplete = true;
      showHighScoreModal(courseTime);
    }

    const scoreFlash = scoreFlashTime > 0 ? ` <span style="color:#ffd447">+${lastRingScore}</span>` : '';
    const centerFlash = scoreFlashTime > 0 ? `Center: ${(lastCenterAccuracy * 100).toFixed(0)}% (+${lastCenterBonus})<br>` : '';
    const courseStatus = ringsCollected === rings.length ? ' complete' : '';

    hud.innerHTML =
      `${currentLevelConfig.label}<br>` +
      `Score: ${score}${scoreFlash}<br>` +
      centerFlash +
      `Rings: ${ringsCollected}/${rings.length}${courseStatus}<br>` +
      `Time: ${courseTime.toFixed(1)} s<br>` +
      `W/S throttle: ${(throttle * 100).toFixed(0)}%<br>` +
      `Speed: ${(speed * 2.237).toFixed(1)} mph<br>` +
      `Alt: ${plane.position.y.toFixed(1)} m<br>` +
      `Heading: ${(((plane.rotation.y * 180 / Math.PI) % 360 + 360) % 360).toFixed(0)}°<br>` +
      `Rudder: ${(rudderPivot ? ((rudderPivot.rotation.y - rudderNeutralRotation) * 180 / Math.PI) : 0).toFixed(0)}°<br>` +
      `Controls: W/S throttle, arrows climb/dive, A/D yaw, double-tap arrows for barrel roll`;

    renderer.render(scene, camera);
  }

  animate();

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();

    renderer.setSize(window.innerWidth, window.innerHeight);
  });
</script>
