---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/homepage/Hero.astro';
import FeaturedProject from '../components/homepage/FeaturedProject.astro';
import SelectedWork from '../components/homepage/SelectedWork.astro';
import GithubActivity from '../components/GithubActivity.astro';
import ImageComparisonSlider from '../components/homepage/ImageComparisonSlider.astro';
import LogoGrid from '../components/homepage/LogoGrid.astro';
import SectionHeading from '../components/homepage/SectionHeading.astro';
import HowIWork from '../components/homepage/HowIWork.astro';
import BuildingWithAI from '../components/homepage/BuildingWithAI.astro';
import Principles from '../components/homepage/Principles.astro';
import About from '../components/homepage/About.astro';
---
<Layout title="John S Fuller — Front End Visual & UX Designer" description="John S Fuller — Front End Visual & UX Designer. Resume and portfolio." bodyClass="bg-[#17171c] text-gray-200">
  <Hero
    name="John Fuller"
    title="Product Design Engineer"
    description="I design and build products from idea to production."
  />
  <LogoGrid />
  <section class="mt-16">
    <SectionHeading text="Featured Project" class="mb-6 text-3xl md:text-4xl" />    
    <FeaturedProject
        title="AOPA Platform Migration & Website Redesign"
        description="Led the redesign of AOPA’s digital platform, modernizing the organization’s web presence to improve performance, scalability, and user experience for millions of pilots and aviation enthusiasts."
        body="The project involved transitioning legacy systems to a modern content management architecture, redesigning key user journeys, and implementing a responsive, accessible design system. Working across cross-functional teams, including product, design, development, and stakeholders, I helped ensure a seamless migration of content, functionality, and integrations while minimizing disruption to users."
        stats={[
          { value: "45k", label: "articles migrated" },
          { value: "3k", label: "pages migrated" },
          { value: "4", label: "person team" },
          { value: "4", label: "month timeline" },
        ]}
      >
      <ImageComparisonSlider 
        slot="media"
        beforeImage='/images/homepage/aopa-homepage-old.jpg'
        afterImage='/images/homepage/aopa-homepage-new.jpg'
        aspectRatio='921/650'
      />
    </FeaturedProject>
  </section>

  <section class="mt-12">
    <SectionHeading text="Selected Work" class="mb-6 text-4xl" />
    <div class="grid grid-cols-2 divide-x divide-[#34343d] border border-[#34343d]">
      <SelectedWork
        title="AOP Design System"
        description="Comprehensive design system for AOPA including documentation, components, and usage guidelines."
        href="/design-system"
        image="/images/homepage/design-system.png"
        imageAlt="AOPA Design System documentation homepage"
        tags={["Design System", "Documentation", "Components"]}
      />
      <SelectedWork
        title="Hub Hero Component"
        description="Customizable hero component with preview capabilities for AOPA's content hubs."
        href="/aopa/hub/hero"
        image="/images/homepage/hub-hero.png"
        imageAlt="Hub Hero component preview interface"
        tags={["React", "Component Library", "Preview"]}
      />
    </div>
  </section>
  <HowIWork
    title="How I Work"
    description="A glimpse into my design and development process"
    steps={[
      {
        title: "Research & Discovery",
        description: "I begin by understanding project goals, target users, and requirements through stakeholder interviews, user research, and competitive analysis."
      },
      {
        title: "Design & Prototyping",
        description: "I create wireframes, mockups, and interactive prototypes to visualize ideas and gather feedback before finalizing designs."
      },
      {
        title: "Development",
        description: "I build accessible, performant web experiences using modern technologies like Astro, React, and CSS-in-JS frameworks."
      },
      {
        title: "Testing & Refinement",
        description: "I conduct usability testing and iterate on designs and code to ensure optimal performance and user satisfaction."
      }
    ]}
  />
  <div class="mt-12 grid grid-cols-2 gap-8">
    <BuildingWithAI
      title="Building with AI"
      items={[
        "Automated bug triage",
        "Research synthesis",
        "Design system generation",
        "Internal productivity tools",
        "Agent workflows"
      ]}
    />
    <Principles
      title="Principles"
      principles={[
        "Ship before perfect.",
        "Measure before debating.",
        "Design systems scale teams.",
        "Documentation is a feature.",
        "User feedback beats assumptions."
      ]}
    />
  </div>

  <About
    title="About"
    description="A brief overview of my work and interests"
    content="I'm a Product Design Engineer working at the intersection of design, engineering, and product strategy. I enjoy turning ambiguous problems into shipped experiences, especially when I can own the entire process from discovery through implementation and measurement. Lately I've been exploring AI-assisted workflows, analytics-driven product development, and tools that help teams move faster."
  />
  <div class="text-center mt-8 mb-8">
    <a href="/resume" data-astro-transition="page" class="rounded-md bg-blue-600 px-4 py-2 text-white no-underline">View Resume</a>
  </div>
</Layout>
