---
import SiteNav from '../components/SiteNav.astro';
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="John S Fuller — Front End Visual & UX Designer. Resume and portfolio." />
		<title>John S Fuller — Front End Visual &amp; UX Designer</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />
		<style is:global>
			:root {
				--color-bg: #faf9f7;
				--color-text: #1a1a1a;
				--color-muted: #5c5c5c;
				--color-accent: #2d5a4a;
				--color-border: #e5e3e0;
				--font-sans: 'DM Sans', system-ui, sans-serif;
				--font-serif: 'DM Serif Display', Georgia, serif;
				--max-width: 720px;
				--page-max-with-sidebar: min(1100px, 100%);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				padding: 2rem 1.5rem 4rem;
				font-family: var(--font-sans);
				font-size: 1rem;
				line-height: 1.6;
				color: var(--color-text);
				background: var(--color-bg);
			}

			.page {
				max-width: var(--page-max-with-sidebar);
				margin: 0 auto;
			}

			.page-body {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5rem;
				align-items: start;
			}

			@media (min-width: 900px) {
				.page-body {
					grid-template-columns: minmax(0, 1fr) 220px;
					gap: 2rem;
				}
			}

			.resume header {
				text-align: center;
				margin-bottom: 2.5rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--color-border);
			}

			.name {
				font-family: var(--font-serif);
				font-size: clamp(2rem, 5vw, 2.75rem);
				font-weight: 400;
				margin: 0 0 0.25rem;
				letter-spacing: 0.02em;
			}

			.title {
				font-size: 1.1rem;
				color: var(--color-muted);
				font-weight: 500;
				margin: 0 0 1rem;
			}

			.contact {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.5rem 1.25rem;
				font-size: 0.9rem;
				color: var(--color-muted);
			}

			.contact a {
				color: var(--color-accent);
				text-decoration: none;
			}

			.contact a:hover {
				text-decoration: underline;
			}

			.contact span:not(.sep) {
				opacity: 0.85;
			}

			.auth-gravity {
				display: flex;
				flex-direction: column;
				align-items: stretch;
				gap: 0.65rem;
				margin-bottom: 0;
				padding: 0.85rem 1rem;
				border: 1px solid var(--color-border);
				border-radius: 0.5rem;
				background: #fff;
			}

			@media (min-width: 900px) {
				.auth-gravity {
					position: sticky;
					top: 1.25rem;
				}
			}

			.auth-gravity__label {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: var(--color-muted);
				margin: 0;
				text-align: center;
			}

			.auth-gravity button {
				font-family: inherit;
				font-size: 0.85rem;
				font-weight: 600;
				padding: 0.5rem 0.75rem;
				border-radius: 0.35rem;
				cursor: pointer;
				border: 2px solid var(--color-accent);
				background: var(--color-accent);
				color: #fff;
				width: 100%;
			}

			.auth-gravity button:hover:not(:disabled) {
				filter: brightness(1.05);
			}

			.auth-gravity button:disabled {
				opacity: 0.45;
				cursor: not-allowed;
			}

			.auth-gravity button[data-variant="secondary"] {
				background: transparent;
				color: var(--color-accent);
			}

			#auth-status {
				width: 100%;
				margin: 0;
				font-size: 0.75rem;
				line-height: 1.4;
				color: var(--color-muted);
				text-align: center;
				min-height: 1.25em;
			}

			.resume {
				max-width: var(--max-width);
				margin: 0;
				width: 100%;
			}

			.resume section {
				margin-bottom: 2rem;
			}

			.resume h2 {
				font-family: var(--font-serif);
				font-size: 1.25rem;
				font-weight: 400;
				margin: 0 0 1rem;
				color: var(--color-text);
				letter-spacing: 0.02em;
			}

			.summary p {
				margin: 0;
				color: var(--color-muted);
				font-size: 0.95rem;
			}

			.skills-grid {
				display: grid;
				gap: 1.25rem 2rem;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
			}

			.skill-group h3 {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-accent);
				margin: 0 0 0.5rem;
			}

			.skill-group p {
				font-size: 0.9rem;
				color: var(--color-muted);
				margin: 0;
				line-height: 1.5;
			}

			.job {
				margin-bottom: 1.75rem;
			}

			.job:last-child {
				margin-bottom: 0;
			}

			.job-header {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				justify-content: space-between;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}

			.job-company {
				font-weight: 600;
				font-size: 1rem;
			}

			.job-role {
				font-size: 0.95rem;
				color: var(--color-muted);
			}

			.job-date {
				font-size: 0.85rem;
				color: var(--color-muted);
			}

			.job ul {
				margin: 0;
				padding-left: 1.25rem;
				color: var(--color-muted);
				font-size: 0.9rem;
				line-height: 1.55;
			}

			.job li {
				margin-bottom: 0.35rem;
			}

			.education p {
				margin: 0 0 0.5rem;
				font-size: 0.95rem;
				color: var(--color-muted);
			}

			.education p:last-child {
				margin-bottom: 0;
			}

			@media print {
				body {
					background: #fff;
					padding: 1rem;
				}
				.contact a {
					color: var(--color-text);
				}
				.site-nav,
				.auth-gravity {
					display: none;
				}

				.page-body {
					display: block;
				}

				.resume {
					max-width: none;
				}
			}
		</style>
	</head>
	<body>
		<div class="page">
			<SiteNav currentPath={currentPath} />
			<div class="page-body">
			<aside class="auth-gravity" aria-label="AuthGravity passkey demo">
				<p class="auth-gravity__label">Passkey (AuthGravity)</p>
				<button type="button" id="auth-register" data-variant="secondary">Register (passkey)</button>
				<button type="button" id="auth-login">Sign in</button>
				<p id="auth-status" role="status" aria-live="polite"></p>
			</aside>
			</div>
		</div>
		<script>
			import { startRegistration, startAuthentication } from "@simplewebauthn/browser";

			const publicAuthUrl = (
				import.meta.env.PUBLIC_AUTHGRAVITY_URL ?? ""
			).replace(/\/$/, "");
			// astro dev: same-origin proxy (see astro.config.mjs) avoids CORS to authgravity.*.
			const API = import.meta.env.DEV
				? `${globalThis.location.origin}/api/authgravity`
				: publicAuthUrl;
			const registerBtn = document.getElementById("auth-register");
			const loginBtn = document.getElementById("auth-login");
			const statusEl = document.getElementById("auth-status");

			function setStatus(msg: string) {
				if (statusEl) statusEl.textContent = msg;
			}

			if (!publicAuthUrl) {
				setStatus(
					"Set PUBLIC_AUTHGRAVITY_URL in .env (dev uses it for the Vite proxy; prod calls it directly).",
				);
				registerBtn?.setAttribute("disabled", "true");
				loginBtn?.setAttribute("disabled", "true");
			} else {
				registerBtn?.addEventListener("click", async () => {
					try {
						setStatus("Registering…");
						const optRes = await fetch(`${API}/register/options`, {
							credentials: "include",
						});
						if (!optRes.ok) {
							const t = await optRes.text();
							throw new Error(t || `register/options failed: ${optRes.status}`);
						}
						const opts = await optRes.json();
						const attResp = await startRegistration({ optionsJSON: opts });
						const verRes = await fetch(`${API}/register/verify`, {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							credentials: "include",
							body: JSON.stringify({
								response: attResp,
								userId: opts.userId,
							}),
						});
						const verText = await verRes.text();
						let body = {};
						try {
							body = JSON.parse(verText);
						} catch {
							/* non-JSON body */
						}
						if (!verRes.ok) {
							const err =
								typeof body === "object" &&
								body !== null &&
								"error" in body &&
								typeof body.error === "string"
									? body.error
									: verText;
							throw new Error(err || `register/verify failed: ${verRes.status}`);
						}
						const uid =
							typeof body === "object" &&
							body !== null &&
							"user" in body &&
							body.user &&
							typeof body.user === "object" &&
							"id" in body.user &&
							typeof body.user.id === "string"
								? body.user.id
								: undefined;
						setStatus(
							uid
								? `Registered; session set. User id: ${uid}`
								: "Registered; session set.",
						);
					} catch (e) {
						setStatus(e instanceof Error ? e.message : String(e));
					}
				});

				loginBtn?.addEventListener("click", async () => {
					try {
						setStatus("Signing in…");
						const optRes = await fetch(`${API}/login/options`, {
							credentials: "include",
						});
						if (!optRes.ok) {
							const t = await optRes.text();
							throw new Error(t || `login/options failed: ${optRes.status}`);
						}
						const opts = await optRes.json();
						const assertResp = await startAuthentication({ optionsJSON: opts });
						const verRes = await fetch(`${API}/login/verify`, {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							credentials: "include",
							body: JSON.stringify({
								response: assertResp,
								challengeId: opts.challengeId,
							}),
						});
						const verText = await verRes.text();
						let body = {};
						try {
							body = JSON.parse(verText);
						} catch {
							/* non-JSON body */
						}
						if (!verRes.ok) {
							const err =
								typeof body === "object" &&
								body !== null &&
								"error" in body &&
								typeof body.error === "string"
									? body.error
									: verText;
							throw new Error(err || `login/verify failed: ${verRes.status}`);
						}
						const uid =
							typeof body === "object" &&
							body !== null &&
							"user" in body &&
							body.user &&
							typeof body.user === "object" &&
							"id" in body.user &&
							typeof body.user.id === "string"
								? body.user.id
								: undefined;
						setStatus(
							uid
								? `Signed in. User id: ${uid}`
								: "Signed in.",
						);
					} catch (e) {
						setStatus(e instanceof Error ? e.message : String(e));
					}
				});
			}
		</script>
	</body>
</html>
