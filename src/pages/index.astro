---
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="John S Fuller — Front End Visual & UX Designer. Resume and portfolio." />
		<title>John S Fuller — Front End Visual &amp; UX Designer</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />
		<style is:global>
			@media print {
				body { @apply bg-white p-4; }
				.print\:hidden { display: none !important; }
				.contact a { color: #1a1a1a; }
			}
		</style>
	</head>
	<body class="min-h-screen bg-[#faf9f7] px-6 py-8 pb-16 font-sans text-base leading-relaxed text-[#1a1a1a] md:px-6">
		<div class="mx-auto max-w-[720px]">
			<SiteNav currentPath={currentPath} />
			<main class="resume">
				<header class="mb-10 border-b border-divider pb-8 text-center">
					<h1 class="font-serif text-[clamp(2rem,5vw,2.75rem)] font-normal tracking-wide">John S Fuller</h1>
					<p class="text-lg font-medium text-muted mb-4">Front End Visual &amp; UX Designer</p>
					<div class="contact flex flex-wrap justify-center gap-x-5 gap-y-2 text-sm text-muted">
						<a href="mailto:Johnsfuller@gmail.com" class="text-accent no-underline hover:underline">Johnsfuller@gmail.com</a>
						<span class="sep">|</span>
						<a href="tel:+12026818640" class="text-accent no-underline hover:underline">202-681-8640</a>
						<span class="sep">|</span>
						<a href="https://www.linkedin.com/in/john-fuller-74410631" target="_blank" rel="noopener noreferrer" class="text-accent no-underline hover:underline">LinkedIn</a>
						<span class="sep">|</span>
						<a href="https://github.com/JFuller3000" target="_blank" rel="noopener noreferrer" class="text-accent no-underline hover:underline">Github</a>
					</div>
				</header>

				<section class="summary mb-8" aria-labelledby="summary-heading">
					<h2 id="summary-heading" class="font-serif text-xl font-normal tracking-wide text-[#1a1a1a] mb-4">Summary</h2>
					<p class="text-[#1a1a1a] text-[0.95rem] m-0 text-muted">
						Front-end engineer and visual designer specializing in content driven large scale web apps. Ships with Astro, TypeScript, and Tailwind; comfortable with headless CMS, GraphQL, and static-first/Jamstack architecture.
					</p>
				</section>

				<section class="skills mb-8" aria-labelledby="skills-heading">
					<h2 id="skills-heading" class="font-serif text-xl font-normal tracking-wide text-[#1a1a1a] mb-4">Skills</h2>
					<div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-5">
						<div class="skill-group">
							<h3 class="text-accent text-xs font-semibold uppercase tracking-wider mb-2">Frontend</h3>
							<p class="text-muted text-sm leading-snug m-0">Astro, TypeScript, TSX, Preact, React (hooks), Tailwind CSS, CSS custom properties, responsive design</p>
						</div>
						<div class="skill-group">
							<h3 class="text-accent text-xs font-semibold uppercase tracking-wider mb-2">Design systems</h3>
							<p class="text-muted text-sm leading-snug m-0">Design tokens (typography, color, spacing), component libraries, Tailwind theme extension, prose/editorial styling, accessibility (ARIA, semantic HTML)</p>
						</div>
						<div class="skill-group">
							<h3 class="text-accent text-xs font-semibold uppercase tracking-wider mb-2">Data &amp; APIs</h3>
							<p class="text-muted text-sm leading-snug m-0">GraphQL, Apollo Client, headless CMS (WordPress / WPGraphQL), REST</p>
						</div>
						<div class="skill-group">
							<h3 class="text-accent text-xs font-semibold uppercase tracking-wider mb-2">Auth &amp; tooling</h3>
							<p class="text-muted text-sm leading-snug m-0">OIDC / Ory, Prettier, Vitest, Git</p>
						</div>
						<div class="skill-group">
							<h3 class="text-accent text-xs font-semibold uppercase tracking-wider mb-2">Platform / infra</h3>
							<p class="text-muted text-sm leading-snug m-0">Jamstack, static site generation, Cloudflare, Node</p>
						</div>
					</div>
				</section>

				<section class="experience mb-8" aria-labelledby="experience-heading">
					<h2 id="experience-heading" class="font-serif text-xl font-normal tracking-wide text-[#1a1a1a] mb-4">Work Experience</h2>

					<article class="job mb-7 last:mb-0">
						<div class="job-header flex flex-wrap items-baseline justify-between gap-2 mb-2">
							<span class="job-company font-semibold text-base">AOPA</span>
							<span class="job-date text-sm text-muted">2021–present</span>
						</div>
						<p class="job-role text-[0.95rem] text-muted">Senior Front End</p>
						<ul class="list-[disc] pl-5 text-muted text-sm leading-snug my-0 [&>li]:mb-1.5">
							<li>Lead UX and visual design for a major platform redesign; own end-to-end design from concept to implementation</li>
							<li>Define and build the design system (tokens, components, typography) that powers the new member-facing product</li>
							<li>Partner with engineering to ship a mobile-first, conversion-focused front end (Astro, Tailwind, headless CMS)</li>
							<li>Drive UX and visual direction for landing pages, sign-up flows, and editorial experiences</li>
						</ul>
					</article>

					<article class="job mb-7 last:mb-0">
						<div class="job-header flex flex-wrap items-baseline justify-between gap-2 mb-2">
							<span class="job-company font-semibold text-base">Solas AI</span>
							<span class="job-date text-sm text-muted">2019–2021</span>
						</div>
						<p class="job-role text-[0.95rem] text-muted">Principal Designer</p>
						<ul class="list-[disc] pl-5 text-muted text-sm leading-snug my-0 [&>li]:mb-1.5">
							<li>Served as sole designer on a small team; owned branding, visual identity, and key go-to-market materials</li>
							<li>Designed and produced pitch decks and sales collateral that supported fundraising and client conversations</li>
							<li>Established brand guidelines and reusable templates for a fast-moving early-stage team</li>
						</ul>
					</article>

					<article class="job mb-7 last:mb-0">
						<div class="job-header flex flex-wrap items-baseline justify-between gap-2 mb-2">
							<span class="job-company font-semibold text-base">Freelance</span>
							<span class="job-date text-sm text-muted">2017–2019</span>
						</div>
						<p class="job-role text-[0.95rem] text-muted">Design &amp; Front-end</p>
						<ul class="list-[disc] pl-5 text-muted text-sm leading-snug my-0 [&>li]:mb-1.5">
							<li>Delivered brand identity, web design, and front-end implementation for startups and small businesses</li>
							<li>Shipped responsive sites and design systems across industries including media and technology</li>
						</ul>
					</article>

					<article class="job mb-7 last:mb-0">
						<div class="job-header flex flex-wrap items-baseline justify-between gap-2 mb-2">
							<span class="job-company font-semibold text-base">Vox Media Inc.</span>
							<span class="job-date text-sm text-muted">2009–2017</span>
						</div>
						<p class="job-role text-[0.95rem] text-muted">Principal Front End Designer</p>
						<ul class="list-[disc] pl-5 text-muted text-sm leading-snug my-0 [&>li]:mb-1.5">
							<li>First design hire; helped scale the design org from 1 to a 40-person, multi-location team</li>
							<li>Led design of major rebrand initiatives and long-term brand platforms for flagship properties</li>
							<li>Created and evolved brand systems and design standards that supported growth and consistency across properties</li>
							<li>Shipped high-impact brand and product work that defined visual identity and audience experience</li>
						</ul>
					</article>

					<article class="job mb-7 last:mb-0">
						<div class="job-header flex flex-wrap items-baseline justify-between gap-2 mb-2">
							<span class="job-company font-semibold text-base">AOL</span>
							<span class="job-date text-sm text-muted">2007–2009</span>
						</div>
						<p class="job-role text-[0.95rem] text-muted">Junior Designer</p>
						<ul class="list-[disc] pl-5 text-muted text-sm leading-snug my-0 [&>li]:mb-1.5">
							<li>Designed and supported content brands at scale across a large portfolio of properties</li>
							<li>Delivered UX and visual design for high-traffic, editorially driven products</li>
							<li>Collaborated with senior design leadership and cross-functional teams in a fast-paced, scaled environment</li>
						</ul>
					</article>
				</section>

				<section class="education" aria-labelledby="education-heading">
					<h2 id="education-heading" class="font-serif text-xl font-normal tracking-wide text-[#1a1a1a] mb-4">Education</h2>
					<p class="text-[0.95rem] text-muted mb-2 last:mb-0"><strong class="text-[#1a1a1a]">Corcoran College of Art &amp; Design</strong> | BA Graphic design | Washington DC</p>
					<p class="text-[0.95rem] text-muted mb-2 last:mb-0"><strong class="text-[#1a1a1a]">University of Tallin</strong> | 1yr Study Abroad, CS | Tallinn, Estonia</p>
				</section>
			</main>
		</div>
	</body>
</html>
