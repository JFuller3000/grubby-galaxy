---
import SiteNav from '../components/SiteNav.astro';
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="John S Fuller — Front End Visual & UX Designer. Resume and portfolio." />
		<title>John S Fuller — Front End Visual &amp; UX Designer</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet" />
		<style is:global>
			:root {
				--color-bg: #faf9f7;
				--color-text: #1a1a1a;
				--color-muted: #5c5c5c;
				--color-accent: #2d5a4a;
				--color-border: #e5e3e0;
				--font-sans: 'DM Sans', system-ui, sans-serif;
				--font-serif: 'DM Serif Display', Georgia, serif;
				--max-width: 720px;
				--page-max-with-sidebar: min(1100px, 100%);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				padding: 2rem 1.5rem 4rem;
				font-family: var(--font-sans);
				font-size: 1rem;
				line-height: 1.6;
				color: var(--color-text);
				background: var(--color-bg);
			}

			.page {
				max-width: var(--page-max-with-sidebar);
				margin: 0 auto;
			}

			.page-body {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5rem;
				align-items: start;
			}

			@media (min-width: 900px) {
				.page-body {
					grid-template-columns: minmax(0, 1fr) 220px;
					gap: 2rem;
				}
			}

			.resume header {
				text-align: center;
				margin-bottom: 2.5rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--color-border);
			}

			.name {
				font-family: var(--font-serif);
				font-size: clamp(2rem, 5vw, 2.75rem);
				font-weight: 400;
				margin: 0 0 0.25rem;
				letter-spacing: 0.02em;
			}

			.title {
				font-size: 1.1rem;
				color: var(--color-muted);
				font-weight: 500;
				margin: 0 0 1rem;
			}

			.contact {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.5rem 1.25rem;
				font-size: 0.9rem;
				color: var(--color-muted);
			}

			.contact a {
				color: var(--color-accent);
				text-decoration: none;
			}

			.contact a:hover {
				text-decoration: underline;
			}

			.contact span:not(.sep) {
				opacity: 0.85;
			}

			.auth-gravity {
				display: flex;
				flex-direction: column;
				align-items: stretch;
				gap: 0.65rem;
				margin-bottom: 0;
				padding: 0.85rem 1rem;
				border: 1px solid var(--color-border);
				border-radius: 0.5rem;
				background: #fff;
			}

			@media (min-width: 900px) {
				.auth-gravity {
					position: sticky;
					top: 1.25rem;
				}
			}

			.auth-gravity__label {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: var(--color-muted);
				margin: 0;
				text-align: center;
			}

			.auth-gravity button {
				font-family: inherit;
				font-size: 0.85rem;
				font-weight: 600;
				padding: 0.5rem 0.75rem;
				border-radius: 0.35rem;
				cursor: pointer;
				border: 2px solid var(--color-accent);
				background: var(--color-accent);
				color: #fff;
				width: 100%;
			}

			.auth-gravity button:hover:not(:disabled) {
				filter: brightness(1.05);
			}

			.auth-gravity button:disabled {
				opacity: 0.45;
				cursor: not-allowed;
			}

			.auth-gravity button[data-variant="secondary"] {
				background: transparent;
				color: var(--color-accent);
			}

			#auth-status {
				width: 100%;
				margin: 0;
				font-size: 0.75rem;
				line-height: 1.4;
				color: var(--color-muted);
				text-align: center;
				min-height: 1.25em;
			}

			.resume {
				max-width: var(--max-width);
				margin: 0;
				width: 100%;
			}

			.resume section {
				margin-bottom: 2rem;
			}

			.resume h2 {
				font-family: var(--font-serif);
				font-size: 1.25rem;
				font-weight: 400;
				margin: 0 0 1rem;
				color: var(--color-text);
				letter-spacing: 0.02em;
			}

			.summary p {
				margin: 0;
				color: var(--color-muted);
				font-size: 0.95rem;
			}

			.skills-grid {
				display: grid;
				gap: 1.25rem 2rem;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
			}

			.skill-group h3 {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-accent);
				margin: 0 0 0.5rem;
			}

			.skill-group p {
				font-size: 0.9rem;
				color: var(--color-muted);
				margin: 0;
				line-height: 1.5;
			}

			.job {
				margin-bottom: 1.75rem;
			}

			.job:last-child {
				margin-bottom: 0;
			}

			.job-header {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				justify-content: space-between;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}

			.job-company {
				font-weight: 600;
				font-size: 1rem;
			}

			.job-role {
				font-size: 0.95rem;
				color: var(--color-muted);
			}

			.job-date {
				font-size: 0.85rem;
				color: var(--color-muted);
			}

			.job ul {
				margin: 0;
				padding-left: 1.25rem;
				color: var(--color-muted);
				font-size: 0.9rem;
				line-height: 1.55;
			}

			.job li {
				margin-bottom: 0.35rem;
			}

			.education p {
				margin: 0 0 0.5rem;
				font-size: 0.95rem;
				color: var(--color-muted);
			}

			.education p:last-child {
				margin-bottom: 0;
			}

			@media print {
				body {
					background: #fff;
					padding: 1rem;
				}
				.contact a {
					color: var(--color-text);
				}
				.site-nav,
				.auth-gravity {
					display: none;
				}

				.page-body {
					display: block;
				}

				.resume {
					max-width: none;
				}
			}
		</style>
	</head>
	<body>
		<div class="page">
			<SiteNav currentPath={currentPath} />
			<div class="page-body">
				<main class="resume">
				<header>
					<h1 class="name">John S Fuller</h1>
					<p class="title">Product Designer</p>
					<div class="contact">
						<a href="mailto:Johnsfuller@gmail.com">Johnsfuller@gmail.com</a>
						<span class="sep">|</span>
						<a href="tel:+12026818640">202-681-8640</a>
						<span class="sep">|</span>
						<a href="https://www.linkedin.com/in/john-fuller-74410631" target="_blank" rel="noopener noreferrer">LinkedIn</a>
						<span class="sep">|</span>
						<a href="https://github.com/JFuller3000" target="_blank" rel="noopener noreferrer">Github</a>
					</div>
				</header>

				<section class="summary" aria-labelledby="summary-heading">
					<h2 id="summary-heading">Summary</h2>
					<p>
						Front-end engineer and visual designer specializing in content driven large scale web apps. Ships with Astro, TypeScript, and Tailwind; comfortable with headless CMS, GraphQL, and static-first/Jamstack architecture.
					</p>
				</section>

				<section class="skills" aria-labelledby="skills-heading">
					<h2 id="skills-heading">Skills</h2>
					<div class="skills-grid">
						<div class="skill-group">
							<h3>Frontend</h3>
							<p>Astro, TypeScript, TSX, Preact, React (hooks), Tailwind CSS, CSS custom properties, responsive design</p>
						</div>
						<div class="skill-group">
							<h3>Design systems</h3>
							<p>Design tokens (typography, color, spacing), component libraries, Tailwind theme extension, prose/editorial styling, accessibility (ARIA, semantic HTML)</p>
						</div>
						<div class="skill-group">
							<h3>Data &amp; APIs</h3>
							<p>GraphQL, Apollo Client, headless CMS (WordPress / WPGraphQL), REST</p>
						</div>
						<div class="skill-group">
							<h3>Auth &amp; tooling</h3>
							<p>OIDC / Ory, Prettier, Vitest, Git</p>
						</div>
						<div class="skill-group">
							<h3>Platform / infra</h3>
							<p>Jamstack, static site generation, Cloudflare, Node</p>
						</div>
					</div>
				</section>

				<section class="experience" aria-labelledby="experience-heading">
					<h2 id="experience-heading">Work Experience</h2>

					<article class="job">
						<div class="job-header">
							<span class="job-company">AOPA</span>
							<span class="job-date">2021–present</span>
						</div>
						<p class="job-role">Design System Engineer</p>
						<ul>
							<li>Lead UX and visual design for a major platform redesign; own end-to-end design from concept to implementation</li>
							<li>Define and build the design system (tokens, components, typography) that powers the new member-facing product</li>
							<li>Partner with engineering to ship a mobile-first, conversion-focused front end (Astro, Tailwind, headless CMS)</li>
							<li>Drive UX and visual direction for landing pages, sign-up flows, and editorial experiences</li>
						</ul>
					</article>

					<article class="job">
						<div class="job-header">
							<span class="job-company">Solas AI</span>
							<span class="job-date">2019–2021</span>
						</div>
						<p class="job-role">Principal Designer</p>
						<ul>
							<li>Served as sole designer on a small team; owned branding, visual identity, and key go-to-market materials</li>
							<li>Designed and produced pitch decks and sales collateral that supported fundraising and client conversations</li>
							<li>Established brand guidelines and reusable templates for a fast-moving early-stage team</li>
						</ul>
					</article>

					<article class="job">
						<div class="job-header">
							<span class="job-company">Freelance</span>
							<span class="job-date">2017–2019</span>
						</div>
						<p class="job-role">Design &amp; Front-end</p>
						<ul>
							<li>Delivered brand identity, web design, and front-end implementation for startups and small businesses</li>
							<li>Shipped responsive sites and design systems across industries including media and technology</li>
						</ul>
					</article>

					<article class="job">
						<div class="job-header">
							<span class="job-company">Vox Media Inc.</span>
							<span class="job-date">2009–2017</span>
						</div>
						<p class="job-role">Principal Front End Designer</p>
						<ul>
							<li>First design hire; helped scale the design org from 1 to a 40-person, multi-location team</li>
							<li>Led design of major rebrand initiatives and long-term brand platforms for flagship properties</li>
							<li>Created and evolved brand systems and design standards that supported growth and consistency across properties</li>
							<li>Shipped high-impact brand and product work that defined visual identity and audience experience</li>
						</ul>
					</article>

					<article class="job">
						<div class="job-header">
							<span class="job-company">AOL</span>
							<span class="job-date">2007–2009</span>
						</div>
						<p class="job-role">Junior Designer</p>
						<ul>
							<li>Designed and supported content brands at scale across a large portfolio of properties</li>
							<li>Delivered UX and visual design for high-traffic, editorially driven products</li>
							<li>Collaborated with senior design leadership and cross-functional teams in a fast-paced, scaled environment</li>
						</ul>
					</article>
				</section>

				<section class="education" aria-labelledby="education-heading">
					<h2 id="education-heading">Education</h2>
					<p><strong>Corcoran College of Art &amp; Design</strong> | BA Graphic design | Washington DC</p>
					<p><strong>University of Tallin</strong> | 1yr Study Abroad, CS | Tallinn, Estonia</p>
				</section>
			</main>
			<aside class="auth-gravity" aria-label="AuthGravity passkey demo">
				<p class="auth-gravity__label">Passkey (AuthGravity)</p>
				<button type="button" id="auth-register" data-variant="secondary">Register (passkey)</button>
				<button type="button" id="auth-login">Sign in</button>
				<p id="auth-status" role="status" aria-live="polite"></p>
			</aside>
			</div>
		</div>
		<script>
			import { startRegistration, startAuthentication } from "@simplewebauthn/browser";

			const publicAuthUrl = (
				import.meta.env.PUBLIC_AUTHGRAVITY_URL ?? ""
			).replace(/\/$/, "");
			// astro dev: same-origin proxy (see astro.config.mjs) avoids CORS to authgravity.*.
			const API = import.meta.env.DEV
				? `${globalThis.location.origin}/api/authgravity`
				: publicAuthUrl;
			const registerBtn = document.getElementById("auth-register");
			const loginBtn = document.getElementById("auth-login");
			const statusEl = document.getElementById("auth-status");

			function setStatus(msg) {
				if (statusEl) statusEl.textContent = msg;
			}

			if (!publicAuthUrl) {
				setStatus(
					"Set PUBLIC_AUTHGRAVITY_URL in .env (dev uses it for the Vite proxy; prod calls it directly).",
				);
				registerBtn?.setAttribute("disabled", "true");
				loginBtn?.setAttribute("disabled", "true");
			} else {
				registerBtn?.addEventListener("click", async () => {
					try {
						setStatus("Registering…");
						const optRes = await fetch(`${API}/register/options`, {
							credentials: "include",
						});
						if (!optRes.ok) {
							const t = await optRes.text();
							throw new Error(t || `register/options failed: ${optRes.status}`);
						}
						const opts = await optRes.json();
						const attResp = await startRegistration({ optionsJSON: opts });
						const verRes = await fetch(`${API}/register/verify`, {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							credentials: "include",
							body: JSON.stringify({
								response: attResp,
								userId: opts.userId,
							}),
						});
						const verText = await verRes.text();
						let body = {};
						try {
							body = JSON.parse(verText);
						} catch {
							/* non-JSON body */
						}
						if (!verRes.ok) {
							const err =
								typeof body === "object" &&
								body !== null &&
								"error" in body &&
								typeof body.error === "string"
									? body.error
									: verText;
							throw new Error(err || `register/verify failed: ${verRes.status}`);
						}
						const uid =
							typeof body === "object" &&
							body !== null &&
							"user" in body &&
							body.user &&
							typeof body.user === "object" &&
							"id" in body.user &&
							typeof body.user.id === "string"
								? body.user.id
								: undefined;
						setStatus(
							uid
								? `Registered; session set. User id: ${uid}`
								: "Registered; session set.",
						);
					} catch (e) {
						setStatus(e instanceof Error ? e.message : String(e));
					}
				});

				loginBtn?.addEventListener("click", async () => {
					try {
						setStatus("Signing in…");
						const optRes = await fetch(`${API}/login/options`, {
							credentials: "include",
						});
						if (!optRes.ok) {
							const t = await optRes.text();
							throw new Error(t || `login/options failed: ${optRes.status}`);
						}
						const opts = await optRes.json();
						const assertResp = await startAuthentication({ optionsJSON: opts });
						const verRes = await fetch(`${API}/login/verify`, {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							credentials: "include",
							body: JSON.stringify({
								response: assertResp,
								challengeId: opts.challengeId,
							}),
						});
						const verText = await verRes.text();
						let body = {};
						try {
							body = JSON.parse(verText);
						} catch {
							/* non-JSON body */
						}
						if (!verRes.ok) {
							const err =
								typeof body === "object" &&
								body !== null &&
								"error" in body &&
								typeof body.error === "string"
									? body.error
									: verText;
							throw new Error(err || `login/verify failed: ${verRes.status}`);
						}
						const uid =
							typeof body === "object" &&
							body !== null &&
							"user" in body &&
							body.user &&
							typeof body.user === "object" &&
							"id" in body.user &&
							typeof body.user.id === "string"
								? body.user.id
								: undefined;
						setStatus(
							uid
								? `Signed in. User id: ${uid}`
								: "Signed in.",
						);
					} catch (e) {
						setStatus(e instanceof Error ? e.message : String(e));
					}
				});
			}
		</script>
	</body>
</html>
